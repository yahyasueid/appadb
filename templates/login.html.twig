{# templates/login.html.twig #}
{# LAYOUT LOGIN — Multilingue FR/AR/EN #}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('ar') }}" dir="{{ app.request.locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ADB-MR — {{ 'login.title'|trans }}{% endblock %}</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        :root{--green-deep:#14532D;--green-dark:#166534;--green-mid:#2E7D32;--green-light:#4CAF50;--green-pale:#A5D6A7;--green-ghost:rgba(46,125,50,.06);--blue:#0288D1;--gold:#D4A017;--gold-light:#F5DEB3;--sand:#FBF7F0;--sand-dark:#F0E8D8;--text:#1B2A1B;--text-mid:#4A6B4A;--text-light:#7A8F7A;--white:#FFFFFF;--red:#D32F2F;--radius:16px}
        body{font-family:'Outfit',sans-serif;background:var(--sand);color:var(--text);min-height:100vh;display:flex;overflow:hidden}
        html[dir="rtl"] body{font-family:'Noto Sans Arabic',sans-serif}

        /* ═══ LEFT PANEL ═══ */
        .login-left{flex:1;background:linear-gradient(160deg,var(--green-deep) 0%,var(--green-dark) 40%,var(--green-mid) 100%);position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px;overflow:hidden}
        .login-left::before{content:'';position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(165,214,167,.08) 0%,transparent 70%);top:-100px;right:-200px;animation:float 20s ease-in-out infinite}
        .login-left::after{content:'';position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(2,136,209,.06) 0%,transparent 70%);bottom:-50px;left:-100px;animation:float 15s ease-in-out infinite reverse}
        @keyframes float{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(20px,-30px) scale(1.05)}}
        .map-deco{position:absolute;width:320px;height:320px;opacity:.04;border:3px solid #fff;border-radius:30% 70% 60% 40% / 50% 30% 70% 50%;top:50%;left:50%;transform:translate(-50%,-50%);animation:morph 25s ease-in-out infinite}
        @keyframes morph{0%,100%{border-radius:30% 70% 60% 40% / 50% 30% 70% 50%}25%{border-radius:60% 40% 30% 70% / 40% 60% 50% 50%}50%{border-radius:40% 60% 70% 30% / 60% 40% 30% 70%}75%{border-radius:70% 30% 40% 60% / 30% 70% 60% 40%}}
        .dots-pattern{position:absolute;top:40px;left:40px;display:grid;grid-template-columns:repeat(5,1fr);gap:12px;opacity:.15}
        .dots-pattern span{width:4px;height:4px;background:#fff;border-radius:50%;display:block}

        /* ── Logo amélioré ── */
        .login-left-content{position:relative;z-index:2;text-align:center;color:#fff;width:100%;max-width:100%}

        .logo-wrapper{
            margin:0 auto 28px;
            display:flex;
            flex-direction:column;
            align-items:center;
            width:50%;
            animation:logoReveal .9s cubic-bezier(.16,1,.3,1) forwards;
            opacity:0;
            transform:translateY(24px);
        }

        /* Halo lumineux derrière le logo */
        .logo-halo{
            position:relative;
            width:100%;
            aspect-ratio:1/1;
            display:flex;
            align-items:center;
            justify-content:center;
        }
        .logo-halo::before{
            content:'';
            position:absolute;
            inset:-5%;
            border-radius:28%;
            background:radial-gradient(circle at 50% 40%, rgba(165,214,167,.30) 0%, transparent 70%);
            animation:haloBreath 4s ease-in-out infinite;
        }
        .logo-halo::after{
            content:'';
            position:absolute;
            inset:-1%;
            border-radius:22%;
            background:linear-gradient(135deg,rgba(255,255,255,.18) 0%,rgba(255,255,255,.04) 50%,rgba(212,160,23,.12) 100%);
            border:1px solid rgba(255,255,255,.16);
        }
        @keyframes haloBreath{
            0%,100%{transform:scale(1);opacity:.8}
            50%{transform:scale(1.04);opacity:1}
        }

        /* Cadre du logo — 80% du panneau gauche */
        .logo-frame{
            position:relative;
            z-index:2;
            width:100%;
            aspect-ratio:1/1;
            border-radius:20%;
            background:rgba(255,255,255,.97);
            backdrop-filter:blur(20px);
            display:flex;
            align-items:center;
            justify-content:center;
            box-shadow:
                0 40px 100px rgba(0,0,0,.35),
                0 10px 30px rgba(0,0,0,.20),
                inset 0 1px 0 rgba(255,255,255,.9);
            overflow:hidden;
            border:2px solid rgba(255,255,255,.30);
        }

        .logo-frame img{
            width:92%;
            height:92%;
            object-fit:contain;
            display:block;
        }

        /* Fallback si l'image ne charge pas */
        .logo-frame .logo-fallback{
            font-size:2.2rem;
            font-weight:800;
            color:var(--green-dark);
            letter-spacing:.03em;
            display:none; /* affiché via onerror JS */
        }

        /* Ligne décorative sous le logo */
        .logo-line{
            width:48px;
            height:3px;
            background:linear-gradient(90deg, rgba(255,255,255,0), rgba(165,214,167,.7) 40%, rgba(212,160,23,.5) 70%, rgba(255,255,255,0));
            border-radius:2px;
            margin-top:18px;
            animation:lineReveal 1s .5s cubic-bezier(.16,1,.3,1) forwards;
            opacity:0;
            transform:scaleX(.3);
        }
        @keyframes lineReveal{to{opacity:1;transform:scaleX(1)}}

        @keyframes logoReveal{to{opacity:1;transform:translateY(0)}}

        .login-left h1{font-size:1.6rem;font-weight:700;line-height:1.3;margin-bottom:12px;letter-spacing:-.02em;animation:fadeUp .8s .2s cubic-bezier(.16,1,.3,1) forwards;opacity:0;transform:translateY(15px)}
        .login-left h1 em{font-style:normal;background:linear-gradient(135deg,var(--green-pale),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .login-left p{font-size:.88rem;font-weight:300;color:rgba(255,255,255,.6);line-height:1.6;animation:fadeUp .8s .35s cubic-bezier(.16,1,.3,1) forwards;opacity:0;transform:translateY(15px)}
        @keyframes fadeUp{to{opacity:1;transform:translateY(0)}}

        .left-badges{position:absolute;bottom:40px;left:0;right:0;display:flex;justify-content:center;gap:24px;z-index:2;animation:fadeUp .8s .5s cubic-bezier(.16,1,.3,1) forwards;opacity:0}
        .left-badge{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.5);font-size:.72rem;font-weight:500}
        .left-badge i{font-size:.9rem;color:var(--green-pale)}

        /* ═══ RIGHT PANEL ═══ */
        .login-right{width:520px;min-width:520px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px;background:var(--white);position:relative}
        .login-right::before{content:'';position:absolute;top:0;left:40px;right:40px;height:3px;background:linear-gradient(90deg,var(--green-mid),var(--blue),var(--gold));border-radius:0 0 4px 4px;opacity:.6}
        .login-form-wrapper{width:100%;max-width:380px;animation:formSlide .7s .2s cubic-bezier(.16,1,.3,1) forwards;opacity:0;transform:translateX(20px)}
        @keyframes formSlide{to{opacity:1;transform:translateX(0)}}
        .login-greeting{margin-bottom:36px}
        .login-greeting .wave{font-size:1.5rem;display:inline-block;animation:wave 2s ease-in-out infinite;transform-origin:70% 70%}
        @keyframes wave{0%,60%,100%{transform:rotate(0)}10%,30%{transform:rotate(14deg)}20%{transform:rotate(-8deg)}40%{transform:rotate(-4deg)}50%{transform:rotate(10deg)}}
        .login-greeting h2{font-size:1.7rem;font-weight:700;margin:8px 0 6px;letter-spacing:-.03em;color:var(--green-deep)}
        .login-greeting p{font-size:.88rem;color:var(--text-light);font-weight:400}
        .login-error{background:rgba(211,47,47,.06);border:1px solid rgba(211,47,47,.15);border-radius:12px;padding:12px 16px;margin-bottom:20px;display:flex;align-items:center;gap:10px;font-size:.82rem;color:var(--red);animation:shake .5s ease}
        @keyframes shake{10%,90%{transform:translateX(-1px)}20%,80%{transform:translateX(2px)}30%,50%,70%{transform:translateX(-3px)}40%,60%{transform:translateX(3px)}}
        .field-group{margin-bottom:20px;position:relative}
        .field-group label{display:block;font-size:.78rem;font-weight:600;color:var(--text-mid);margin-bottom:8px;letter-spacing:.02em}
        .field-group label i{margin-right:6px;font-size:.72rem;color:var(--green-mid)}
        .input-wrap{position:relative}
        .input-wrap input{width:100%;background:var(--sand);border:2px solid transparent;border-radius:12px;padding:14px 16px 14px 46px;font-size:.9rem;font-family:inherit;color:var(--text);outline:none;transition:all .3s cubic-bezier(.16,1,.3,1)}
        .input-wrap input::placeholder{color:var(--text-light);font-weight:300}
        .input-wrap input:focus{background:var(--white);border-color:var(--green-mid);box-shadow:0 0 0 4px rgba(46,125,50,.08)}
        .input-wrap .input-icon{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:var(--text-light);font-size:1rem;transition:.3s;pointer-events:none}
        .input-wrap input:focus ~ .input-icon{color:var(--green-mid)}
        .toggle-pw{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-light);cursor:pointer;font-size:1rem;padding:4px;transition:.2s}
        .toggle-pw:hover{color:var(--text-mid)}
        .form-extras{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px}
        .remember-check{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:.8rem;color:var(--text-mid)}
        .remember-check input[type="checkbox"]{display:none}
        .check-box{width:18px;height:18px;border:2px solid var(--sand-dark);border-radius:5px;display:flex;align-items:center;justify-content:center;transition:.2s;flex-shrink:0}
        .check-box i{font-size:.65rem;color:var(--white);opacity:0;transition:.2s}
        .remember-check input:checked ~ .check-box{background:var(--green-mid);border-color:var(--green-mid)}
        .remember-check input:checked ~ .check-box i{opacity:1}
        .forgot-link{font-size:.78rem;color:var(--blue);text-decoration:none;font-weight:500;transition:.2s}
        .forgot-link:hover{color:var(--green-mid);text-decoration:underline}
        .btn-login{width:100%;background:linear-gradient(135deg,var(--green-dark),var(--green-mid));color:#fff;border:none;border-radius:14px;padding:16px;font-size:.95rem;font-weight:600;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .3s cubic-bezier(.16,1,.3,1);box-shadow:0 8px 30px rgba(46,125,50,.25);position:relative;overflow:hidden}
        .btn-login::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);transition:.6s}
        .btn-login:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(46,125,50,.35)}
        .btn-login:hover::before{left:100%}
        .btn-login:active{transform:translateY(0);box-shadow:0 4px 15px rgba(46,125,50,.2)}
        .btn-login .spinner{display:none;width:20px;height:20px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite}
        .btn-login.loading .spinner{display:block}
        .btn-login.loading .btn-text{display:none}
        @keyframes spin{to{transform:rotate(360deg)}}
        .divider{display:flex;align-items:center;gap:16px;margin:24px 0;color:var(--text-light);font-size:.75rem;font-weight:500}
        .divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--sand-dark)}
        .lang-select{display:flex;justify-content:center;gap:4px;margin-top:6px}
        .lang-chip{padding:6px 14px;border:1px solid var(--sand-dark);border-radius:20px;background:transparent;color:var(--text-light);font-size:.72rem;font-weight:600;font-family:inherit;cursor:pointer;transition:.2s;text-decoration:none}
        .lang-chip:hover{border-color:var(--green-mid);color:var(--green-mid)}
        .lang-chip.active{background:var(--green-mid);color:#fff;border-color:var(--green-mid)}
        .postes-info{margin-top:24px;padding:14px 16px;background:var(--green-ghost);border-radius:12px;border:1px solid rgba(46,125,50,.08)}
        .postes-info h4{font-size:.72rem;font-weight:600;color:var(--green-mid);margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em}
        .poste-row{display:flex;align-items:center;gap:8px;padding:4px 0;font-size:.74rem;color:var(--text-mid)}
        .poste-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
        .login-footer{margin-top:32px;text-align:center;font-size:.72rem;color:var(--text-light);line-height:1.6}
        .login-footer a{color:var(--green-mid);text-decoration:none;font-weight:500}

        /* ── Badge nom application ADB-MR ── */
        .app-name-badge{
            display:inline-flex;
            align-items:center;
            gap:8px;
            background:rgba(255,255,255,.1);
            border:1px solid rgba(255,255,255,.18);
            border-radius:30px;
            padding:7px 18px 7px 10px;
            margin-bottom:22px;
            animation:fadeUp .8s .05s cubic-bezier(.16,1,.3,1) forwards;
            opacity:0;
            transform:translateY(10px);
            backdrop-filter:blur(8px);
        }
        .app-name-badge .app-dot{
            width:28px;height:28px;border-radius:50%;
            background:linear-gradient(135deg,var(--green-pale),var(--gold-light));
            display:flex;align-items:center;justify-content:center;
            font-size:.65rem;font-weight:800;color:var(--green-deep);
            letter-spacing:.03em;flex-shrink:0;
        }
        .app-name-badge .app-label{
            font-size:.82rem;font-weight:700;
            color:rgba(255,255,255,.9);
            letter-spacing:.08em;
            text-transform:uppercase;
        }

        /* RTL overrides */
        html[dir="rtl"] .input-wrap input{padding-left:16px;padding-right:46px}
        html[dir="rtl"] .input-wrap .input-icon{left:auto;right:16px}
        html[dir="rtl"] .toggle-pw{right:auto;left:14px}
        html[dir="rtl"] .field-group label i{margin-right:0;margin-left:6px}
        html[dir="rtl"] .login-form-wrapper{transform:translateX(-20px)}

        @media(max-width:1024px){.login-left{display:none}.login-right{width:100%;min-width:100%}}
        @media(max-width:480px){.login-right{padding:40px 24px}.login-greeting h2{font-size:1.4rem}}
        {% block extra_css %}{% endblock %}
    </style>
</head>
<body>

    {# ═══ LEFT PANEL ═══ #}
    <div class="login-left">
        <div class="map-deco"></div>
        <div class="dots-pattern">{% for i in 1..25 %}<span></span>{% endfor %}</div>

        <div class="login-left-content">

            {# ── Badge nom de l'application ── #}
            <div class="app-name-badge">
                <span class="app-dot">ADB</span>
                <span class="app-label">ADB-MR</span>
            </div>

            {# ── Logo de l'association ── #}
            {% block logo %}
            <div class="logo-wrapper">
                <div class="logo-halo">
                    <div class="logo-frame">
                        <img
                            src="{{ asset('img/logo.png') }}"
                            alt="{{ 'left.association_name_fr'|trans }}"
                            id="assocLogo"
                            onerror="this.style.display='none';document.getElementById('logoFallback').style.display='block';"
                        >
                        <div class="logo-fallback" id="logoFallback">{{ 'left.association_initials'|trans }}</div>
                    </div>
                </div>
                <div class="logo-line"></div>
            </div>
            {% endblock %}

            {% block left_title %}
            <h1>{{ 'left.association_name_ar'|trans }}<br>و<em>{{ 'left.association_highlight_ar'|trans }}</em></h1>
            <p>{{ 'left.association_name_fr'|trans }}<br>{{ 'left.association_subtitle'|trans }}</p>
            {% endblock %}
        </div>

        <div class="left-badges">
            <div class="left-badge"><i class="bi bi-shield-check"></i><span>{{ 'left.badge_secure'|trans }}</span></div>
            <div class="left-badge"><i class="bi bi-journal-text"></i><span>{{ 'left.badge_audit'|trans }}</span></div>
            <div class="left-badge"><i class="bi bi-translate"></i><span>{{ 'left.badge_multilang'|trans }}</span></div>
        </div>
    </div>

    {# ═══ RIGHT PANEL ═══ #}
    <div class="login-right">
        <div class="login-form-wrapper">
            {% block greeting %}
            <div class="login-greeting">
              
                <h2>{{ 'login.greeting'|trans }}</h2>
                <p>{{ 'login.subtitle'|trans }}</p>
            </div>
            {% endblock %}

            {% block body %}{% endblock %}

            <div class="divider">{{ 'login.lang_divider'|trans }}</div>
            {% block lang_select %}
            <div class="lang-select">
                <a href="{{ app.request.pathInfo }}?_locale=fr" class="lang-chip {{ app.request.locale == 'fr' ? 'active' : '' }}">Français</a>
                <a href="{{ app.request.pathInfo }}?_locale=ar" class="lang-chip {{ app.request.locale == 'ar' ? 'active' : '' }}">العربية</a>
                <a href="{{ app.request.pathInfo }}?_locale=en" class="lang-chip {{ app.request.locale == 'en' ? 'active' : '' }}">English</a>
            </div>
            {% endblock %}

            {% block footer %}
            <div class="login-footer">
                <p>{{ 'login.footer_version'|trans }} — <strong>ADB-MR</strong></p>
                <p>{{ 'login.footer_copyright'|trans }}</p>
            </div>
            {% endblock %}
        </div>
    </div>

    <script>
    function togglePassword(){var pw=document.getElementById('inputPassword'),icon=document.getElementById('eyeIcon');if(pw.type==='password'){pw.type='text';icon.className='bi bi-eye-slash'}else{pw.type='password';icon.className='bi bi-eye'}}
    document.querySelectorAll('.input-wrap input').forEach(function(input){input.addEventListener('focus',function(){this.closest('.field-group').style.transform='scale(1.01)';this.closest('.field-group').style.transition='.3s'});input.addEventListener('blur',function(){this.closest('.field-group').style.transform='scale(1)'})});
    {% block extra_js %}{% endblock %}
    </script>
</body>
</html>
