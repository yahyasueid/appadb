// ═══════════════════════════════════════
// UPLOAD HELPERS
// ═══════════════════════════════════════
function updateUL(inputId, labelId) {
  const i = document.getElementById(inputId);
  const l = document.getElementById(labelId);
  if (!i || !l) return;
  if (i.files.length === 1) l.textContent = i.files[0].name;
  else if (i.files.length > 1) l.textContent = i.files.length + ' fichiers';
}
function handleDrop(e, inputId, labelId) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag');
  const i = document.getElementById(inputId);
  if (i && e.dataTransfer.files.length) {
    i.files = e.dataTransfer.files;
    updateUL(inputId, labelId);
  }
}

// ═══════════════════════════════════════
// YOUTUBE
// ═══════════════════════════════════════
function ytExtract(url) {
  if (!url) return null;
  const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/);
  return m ? m[1] : null;
}
function previewYT(url) {
  const id = ytExtract(url);
  const prev = document.getElementById('ytPrev');
  const thumb = document.getElementById('ytThumb');
  if (id) { thumb.src = `https://img.youtube.com/vi/${id}/mqdefault.jpg`; prev.style.display='block'; }
  else prev.style.display = 'none';
}

// ═══════════════════════════════════════
// LIGHTBOX
// ═══════════════════════════════════════
function openLB(src) {
  document.getElementById('lbImg').src = src;
  document.getElementById('lb').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLB() {
  document.getElementById('lb').classList.remove('open');
  document.body.style.overflow = '';
}

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  // Animer toutes les barres de progression
  document.querySelectorAll('.pbar-f,.prfin-f').forEach(b => {
    const w = getComputedStyle(b).getPropertyValue('--pw').trim() || b.style.width;
    b.style.width = '0';
    setTimeout(() => { b.style.width = w; }, 300 + Math.random()*200);
  });
});
</script>
