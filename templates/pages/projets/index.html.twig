{% block javascripts %}
<script>
// ═══════════════════════════════════════
// ÉTAT COURANT
// ═══════════════════════════════════════
let curView = 'grid';
let curProjetId = null;

// ═══════════════════════════════════════
// MODALES
// ═══════════════════════════════════════
function openMo(id) {
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeMo(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
}
document.querySelectorAll('.mo').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) closeMo(m.id); });
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.mo.open').forEach(m => closeMo(m.id));
});

// ═══════════════════════════════════════
// FILTRE + VUE
// ═══════════════════════════════════════
function setView(v) {
  curView = v;
  document.getElementById('bGrid').classList.toggle('active', v === 'grid');
  document.getElementById('bList').classList.toggle('active', v === 'list');
  filter();
}

function filter() {
  const q   = document.getElementById('q').value.toLowerCase();
  const st  = document.getElementById('fStatut').value;
  const ty  = document.getElementById('fType').value;
  const aid = document.getElementById('fAssoc').value;
  let vis = 0;

  // Projets
  document.querySelectorAll('[id^="c"]').forEach(el => {
    if (!/^c\d+$/.test(el.id)) return;
    const show = (!q || el.dataset.nom.includes(q) || el.dataset.num.includes(q) ||
                  el.dataset.lieu.includes(q) || el.dataset.don.includes(q)) &&
                 (!st || el.dataset.statut === st) &&
                 (!ty || el.dataset.type === ty) &&
                 (!aid || el.dataset.aid === aid);
    el.style.display = show && curView === 'grid' ? '' : 'none';
    if (show) vis++;
  });

  document.querySelectorAll('[id^="r"]').forEach(el => {
    if (!/^r\d+$/.test(el.id)) return;
    const show = (!q || el.dataset.nom.includes(q) || el.dataset.num.includes(q) ||
                  el.dataset.lieu.includes(q) || el.dataset.don.includes(q)) &&
                 (!st || el.dataset.statut === st) &&
                 (!ty || el.dataset.type === ty) &&
                 (!aid || el.dataset.aid === aid);
    el.style.display = show && curView === 'list' ? '' : 'none';
  });

  // Basculer grid/list containers
  document.querySelectorAll('[id^="pgrid"]').forEach(g => {
    g.style.display = curView === 'grid' ? 'grid' : 'none';
  });
  document.querySelectorAll('[id^="plist"]').forEach(l => {
    l.style.display = curView === 'list' ? 'flex' : 'none';
  });

  // Groupes
  document.querySelectorAll('.ag').forEach(ag => {
    const aMatch = !aid || ag.dataset.aid === aid;
    const hasVis = aMatch && Array.from(ag.querySelectorAll('[id^="c"],[id^="r"]')).some(e => e.style.display !== 'none');
    ag.style.display = hasVis ? '' : 'none';
  });

  document.getElementById('cnt').textContent = vis + ' résultats';
  const eg = document.getElementById('eg');
  eg.classList.toggle('vis', vis === 0);
}

// ═══════════════════════════════════════
// VISUALISER PROJET (modale)
// ═══════════════════════════════════════
function ouvrirVisu(id) {
  const p = PROJETS[id];
  if (!p) return;
  curProjetId = id;

  // Header
  document.getElementById('visuTitre').textContent = p.nom;
  document.getElementById('visuSub').textContent   = p.numero + ' · ' + p.assocNom;
  document.getElementById('visuRapportLink').href  = `/projet/${id}`;

  // Bilan
  const fmt = n => Number(n).toLocaleString('fr-FR', {maximumFractionDigits:0}) + ' MRU';
  document.getElementById('vBudget').textContent  = fmt(p.coutTotal);
  document.getElementById('vPaye').textContent    = fmt(p.montantPaye);
  document.getElementById('vRestant').textContent = fmt(p.montantRestant);
  document.getElementById('vTaux').textContent    = p.tauxPaiement.toFixed(1) + '%';
  const bar = document.getElementById('vProgBar');
  bar.style.width = '0%';
  setTimeout(() => { bar.style.width = p.tauxPaiement + '%'; }, 200);

  // Compteurs tabs
  document.getElementById('vtcPai').textContent = p.paiements.length;
  document.getElementById('vtcPho').textContent = p.photos.length;
  document.getElementById('vtcFi').textContent  = p.fichiers.length;
  document.getElementById('vtcVi').textContent  = p.videos.length;

  // Infos
  document.getElementById('visuInfos').innerHTML = `
    <div class="irow"><span class="ilbl">N° projet</span><span class="ival" style="font-family:monospace;font-weight:700">${p.numero}</span></div>
    <div class="irow"><span class="ilbl">Association</span><span class="ival">${p.assocNom}</span></div>
    <div class="irow"><span class="ilbl">Type</span><span class="ival"><i class="bi ${p.typeIcone}" style="color:${p.typeCouleur};margin-right:4px"></i>${p.typeLabel}</span></div>
    <div class="irow"><span class="ilbl">Statut</span><span class="ival"><span class="spill" style="background:${p.statutCouleur}18;color:${p.statutCouleur}"><i class="bi ${p.statutIcone}"></i>${p.statutLabel}</span></span></div>
    <div class="irow"><span class="ilbl">Lieu</span><span class="ival">${p.lieu}, ${p.pays}</span></div>
    <div class="irow"><span class="ilbl">Donateur</span><span class="ival">${p.donateur}</span></div>
    <div class="irow"><span class="ilbl">Durée</span><span class="ival">${p.duree || '—'}</span></div>
    <div class="irow"><span class="ilbl">Contrat</span><span class="ival">${p.dateContrat || '—'}</span></div>
    <div class="irow"><span class="ilbl">Fin prévue</span><span class="ival">${p.dateFin || '—'}</span></div>
    <div class="irow"><span class="ilbl">Progression</span><span class="ival">${p.progression}%</span></div>
    ${p.description ? `<div class="irow"><span class="ilbl">Description</span><span class="ival" style="line-height:1.6">${p.description}</span></div>` : ''}
  `;

  // Paiements
  let hPai = p.paiements.length === 0
    ? '<div style="text-align:center;padding:24px;color:var(--txt3);font-size:.78rem"><i class="bi bi-cash" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:8px"></i>Aucun paiement</div>'
    : p.paiements.map(pa => `
      <div class="pair">
        <div class="pai-ico" style="background:${pa.modeCouleur}18">
          <i class="bi ${pa.modeIcone}" style="color:${pa.modeCouleur}"></i>
        </div>
        <div class="pai-info">
          <div class="pai-mt">${Number(pa.montant).toLocaleString('fr-FR',{maximumFractionDigits:2})} MRU</div>
          <div class="pai-sub">${pa.date} · <span class="pmode" style="background:${pa.modeCouleur}18;color:${pa.modeCouleur}">${pa.modeLabel}</span>${pa.reference ? ' · ' + pa.reference : ''}</div>
        </div>
        ${pa.justif ? `<a href="${pa.justif}" target="_blank" class="pac" title="Justificatif"><i class="bi bi-file-earmark-pdf"></i></a>` : ''}
        <form method="POST" action="${ROUTES_PAIEMENT_DEL.replace('__ID__',pa.id)}" style="display:inline">
          <input type="hidden" name="_token" value="${pa.csrfDel}">
          <input type="hidden" name="_from" value="index">
          <button type="submit" class="pac rd" title="Supprimer" onclick="return confirm('Supprimer ce paiement ?')"><i class="bi bi-trash3"></i></button>
        </form>
      </div>`).join('');
  document.getElementById('visuPaiements').innerHTML = hPai;

  // Photos
  let hPho = p.photos.length === 0
    ? '<div style="text-align:center;padding:24px;color:var(--txt3);font-size:.78rem"><i class="bi bi-images" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:8px"></i>Aucune photo</div>'
    : `<div class="pgal">${p.photos.map((ph,i) => `
        <div class="pgal-item" onclick="openLB('${ph.path}')">
          <img src="${ph.path}" alt="${ph.legende}" loading="lazy">
          ${i===0?'<span style="position:absolute;top:5px;left:5px;background:var(--go);color:#fff;font-size:.58rem;font-weight:700;padding:2px 6px;border-radius:8px">★ Cover</span>':''}
        </div>`).join('')}</div>`;
  document.getElementById('visuPhotos').innerHTML = hPho;

  // Fichiers
  let hFi = p.fichiers.length === 0
    ? '<div style="text-align:center;padding:24px;color:var(--txt3);font-size:.78rem"><i class="bi bi-file-earmark" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:8px"></i>Aucun fichier</div>'
    : p.fichiers.map(fi => `
      <div class="frow2">
        <div class="f-ico" style="background:${fi.catCouleur}18"><i class="bi ${fi.catIcone}" style="color:${fi.catCouleur}"></i></div>
        <div style="flex:1;min-width:0">
          <div class="f-name">${fi.nom}</div>
          <div class="f-sub"><span style="background:${fi.catCouleur}18;color:${fi.catCouleur};padding:1px 6px;border-radius:6px;font-size:.6rem">${fi.cat}</span>${fi.taille ? ' · '+fi.taille : ''}</div>
        </div>
        <a href="${fi.path}" target="_blank" class="pac"><i class="bi bi-download"></i></a>
        <form method="POST" action="${ROUTES_FICHIER_DEL.replace('__ID__',fi.id)}" style="display:inline">
          <input type="hidden" name="_token" value="${fi.csrfDel}">
          <input type="hidden" name="_from" value="index">
          <button type="submit" class="pac rd" onclick="return confirm('Supprimer ce fichier ?')"><i class="bi bi-trash3"></i></button>
        </form>
      </div>`).join('');
  document.getElementById('visuFichiers').innerHTML = hFi;

  // Vidéos
  let hVi = p.videos.length === 0
    ? '<div style="text-align:center;padding:24px;color:var(--txt3);font-size:.78rem"><i class="bi bi-play-circle" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:8px"></i>Aucune vidéo</div>'
    : p.videos.map(vi => {
        const ytId = ytExtract(vi.url);
        const thumb = vi.thumb || (ytId ? `https://img.youtube.com/vi/${ytId}/mqdefault.jpg` : '');
        return `<div class="vid-item">
          <div class="vid-thumb"><img src="${thumb}" alt="" loading="lazy">
            <div class="vid-play"><a href="${vi.url}" target="_blank" class="vid-playbtn"><i class="bi bi-play-fill"></i></a></div>
          </div>
          <div class="vid-info">
            <div><div class="vid-title">${vi.titre}</div></div>
            <form method="POST" action="${ROUTES_VIDEO_DEL.replace('__ID__',vi.id)}" style="display:inline">
              <input type="hidden" name="_token" value="${vi.csrfDel}">
              <input type="hidden" name="_from" value="index">
              <button type="submit" class="pac rd" onclick="return confirm('Supprimer cette vidéo ?')"><i class="bi bi-trash3"></i></button>
            </form>
          </div>
        </div>`;
      }).join('');
  document.getElementById('visuVideos').innerHTML = hVi;

  // Reset tab infos
  visuTab('infos', document.querySelector('.vtab'));
  openMo('moVisu');
}

function visuTab(name, btn) {
  document.querySelectorAll('.vpanel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.vtab').forEach(b => b.classList.remove('active'));
  document.getElementById('vp-' + name).classList.add('active');
  btn.classList.add('active');
}

