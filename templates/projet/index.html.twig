{# templates/projet/index.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}{{ 'proj.page_title'|trans }} — ADB-MR{% endblock %}

{% block stylesheets %}
<style>
/* ═══════════════════════════════════════════════════
   VARIABLES PROJET
═══════════════════════════════════════════════════ */
:root{
  --gd:#14532D;--gk:#166534;--gm:#2E7D32;--gl:#4CAF50;--gp:#A5D6A7;
  --bl:#0288D1;--bl2:rgba(2,136,209,.1);
  --go:#D4A017;--go2:rgba(212,160,23,.1);
  --rd:#D32F2F;--rd2:rgba(211,47,47,.1);
  --pu:#7B1FA2;--pu2:rgba(123,31,162,.1);
  --sand:#FBF7F0;--sand2:#F0E8D8;
  --txt:#1B2A1B;--txt2:#4A6B4A;--txt3:#7A8F7A;
  --bg:#F2F6F2;
  --r:14px;--rs:10px;--rx:7px;
  --sh:0 2px 12px rgba(20,83,45,.07);
  --shm:0 8px 32px rgba(20,83,45,.14);
  --green-deep:#14532D;--green-dark:#166534;--green-mid:#2E7D32;
  --green-light:#4CAF50;--green-pale:#A5D6A7;
  --green-ghost:rgba(46,125,50,.07);--green-border:rgba(46,125,50,.15);
  --blue:#0288D1;--blue-light:rgba(2,136,209,.08);
  --gold:#D4A017;--gold-light:#F5DEB3;
  --sand-dark:#F0E8D8;
  --text:#1B2A1B;--text-mid:#4A6B4A;--text-light:#7A8F7A;
  --white:#FFFFFF;--red:#D32F2F;--red-light:rgba(211,47,47,.08);
  --orange:#E65100;--orange-light:rgba(230,81,0,.08);
  --radius:14px;--radius-sm:10px;--radius-xs:7px;
}
* { box-sizing:border-box; margin:0; padding:0 }

.page-header {
  background:linear-gradient(140deg, #0f3d18 0%, #1B5E20 40%, #2E7D32 75%, #388E3C 100%);
  padding:0;position:relative;overflow:hidden;
}
.page-header::before {
  content:'';position:absolute;top:-80px;right:-80px;
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,255,255,.06) 0%,transparent 70%);
  pointer-events:none;
}
.page-header::after {
  content:'';position:absolute;bottom:-60px;left:25%;
  width:220px;height:220px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,255,255,.04) 0%,transparent 70%);
  pointer-events:none;
}
.page-header .ph-grid-deco {
  position:absolute;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);
  background-size:32px 32px;
}
.ph-main {
  display:flex;align-items:center;justify-content:space-between;
  gap:16px;position:relative;z-index:1;flex-wrap:wrap;
  padding:24px 32px 20px;
}
.ph-left { display:flex;align-items:center;gap:16px;min-width:0;flex:1 }
.ph-logo {
  width:88px;height:88px;border-radius:14px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.18);
  backdrop-filter:blur(4px);overflow:hidden;
  box-shadow:0 4px 16px rgba(0,0,0,.18);
}
.ph-logo img  {background: white; width:100%;height:100%;object-fit:contain;padding:4px }
.ph-logo i    { font-size:1.5rem;color:rgba(255,255,255,.9) }
.ph-text { min-width:0;flex:1 }
.ph-breadcrumb {
  font-size:.68rem;color:rgba(255,255,255,.5);margin-bottom:6px;
  display:flex;align-items:center;gap:5px;
}
.ph-breadcrumb a { color:rgba(255,255,255,.55);text-decoration:none;transition:.15s }
.ph-breadcrumb a:hover { color:#fff }
.ph-breadcrumb i { font-size:.5rem }
.ph-breadcrumb span { color:rgba(255,255,255,.8) }
.ph-title {
  font-size:1.4rem;font-weight:800;color:#fff;
  letter-spacing:-.03em;line-height:1.15;margin:0;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.ph-title-ar {
  font-size:.9rem;font-weight:600;color:rgba(255,255,255,.65);
  font-family:'Noto Sans Arabic','GE SS Two',sans-serif;
  direction:rtl;text-align:left;margin-top:2px;line-height:1.2;
}
.ph-sub {
  font-size:1.04rem;color:#fcfefc ;margin-top:4px;
  display:flex;align-items:center;gap:8px;flex-wrap:wrap;
}
.ph-sub strong { color:rgba(255,255,255,.9) }
.ph-sub-dot { color:rgba(255,255,255,.3) }
.btn-hero {
  display:inline-flex;align-items:center;gap:8px;
  border:none;border-radius:12px;
  padding:11px 22px;font-size:.84rem;font-weight:700;
  cursor:pointer;transition:.22s;white-space:nowrap;
  font-family:inherit;flex-shrink:0;
}
.btn-hero.primary {
  background:rgba(255,255,255,.15);color:#fff;
  border:1.5px solid rgba(255,255,255,.3);
  backdrop-filter:blur(6px);
  box-shadow:0 2px 12px rgba(0,0,0,.1), inset 0 1px 0 rgba(255,255,255,.2);
}
.btn-hero.primary:hover {
  background:rgba(255,255,255,.25);
  border-color:rgba(255,255,255,.45);
  transform:translateY(-2px);
  box-shadow:0 4px 16px rgba(0,0,0,.15), inset 0 1px 0 rgba(255,255,255,.25);
}
.btn-hero.primary i { font-size:1rem }
.stats-strip {
  display:flex;gap:8px;flex-wrap:wrap;
  padding:14px 32px 18px;
  border-top:1px solid rgba(255,255,255,.1);
  position:relative;z-index:1;
}
.stat-chip {
  display:flex;align-items:center;gap:9px;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.1);
  border-radius:10px;padding:9px 14px;
  backdrop-filter:blur(4px);transition:.18s;
}
.stat-chip:hover { background:rgba(255,255,255,.14) }
.stat-chip .sc-ico {
  font-size:1.05rem;width:26px;height:26px;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.1);border-radius:7px;
}
.stat-chip .sc-v { font-size:1rem;font-weight:800;color:#fff;line-height:1;letter-spacing:-.02em }
.stat-chip .sc-l { font-size:.6rem;color:rgba(255,255,255,.5);margin-top:2px;white-space:nowrap }

/* ═══ TOOLBAR ═══ */
.crud-toolbar {
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  padding:14px 32px;
  background:linear-gradient(to bottom,#fff,#fafdf9);
  border-bottom:1px solid var(--sand-dark);
  box-shadow:0 1px 0 var(--sand-dark), 0 2px 8px rgba(20,83,45,.04);
  position:sticky;top:0;z-index:40;
}
.search-box {
  position:relative;flex:1;min-width:200px;max-width:320px;
}
.search-box i {
  position:absolute;left:10px;top:50%;transform:translateY(-50%);
  color:var(--text-light);font-size:.85rem;pointer-events:none;
}
.search-box input {
  width:100%;padding:8px 12px 8px 32px;
  border:1.5px solid var(--sand-dark);border-radius:var(--radius-xs);
  font-size:.83rem;font-family:inherit;background:var(--sand);
  color:var(--text);outline:none;transition:.2s;
}
.search-box input:focus { border-color:var(--green-mid);background:#fff;box-shadow:0 0 0 3px rgba(46,125,50,.06) }
.fsel {
  padding:8px 12px;border:1.5px solid var(--sand-dark);border-radius:var(--radius-xs);
  font-size:.8rem;font-family:inherit;background:var(--sand);color:var(--text);
  outline:none;cursor:pointer;transition:.2s;
}
.fsel:focus { border-color:var(--green-mid);background:#fff }
.tb-cnt { font-size:.75rem;color:var(--text-light);white-space:nowrap;margin-left:auto }
.vtg { display:flex;border:1.5px solid var(--sand-dark);border-radius:var(--radius-xs);overflow:hidden }
.vb {
  width:36px;height:36px;border:none;background:transparent;
  color:var(--text-light);cursor:pointer;transition:.15s;font-size:.9rem;
  display:flex;align-items:center;justify-content:center;
}
.vb:hover,.vb.active { background:var(--green-ghost);color:var(--green-mid) }

/* ═══ CONTENT ═══ */
.proj-content { padding:24px 32px }
.empty-grid {
  display:none;flex-direction:column;align-items:center;justify-content:center;
  padding:60px 20px;gap:12px;color:var(--text-light);
}
.empty-grid.vis { display:flex }
.empty-grid i { font-size:2.5rem;opacity:.3 }
.empty-grid p { font-size:.85rem }
.assoc-group {
  margin-bottom:28px;border-radius:var(--radius);
  border:1.5px solid var(--sand-dark);background:var(--white);
  overflow:hidden;box-shadow:var(--sh);
}
.assoc-header {
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px;
  background:linear-gradient(90deg,rgba(46,125,50,.06),rgba(46,125,50,.02));
  border-bottom:1px solid var(--sand-dark);flex-wrap:wrap;gap:8px;
}
.assoc-left { display:flex;align-items:center;gap:12px }
.assoc-logo {
  width:38px;height:38px;border-radius:10px;overflow:hidden;
  background:var(--sand);border:1.5px solid var(--sand-dark);
  display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;
}
.assoc-logo img { width:100%;height:100%;object-fit:contain }
.assoc-name { font-size:.92rem;font-weight:700;color:var(--text) }
.assoc-meta { font-size:.7rem;color:var(--text-light);margin-top:2px;display:flex;align-items:center;gap:6px }
.assoc-right { display:flex;gap:7px;flex-wrap:wrap }
.a-badge {
  display:inline-flex;align-items:center;gap:5px;
  padding:4px 10px;border-radius:20px;font-size:.7rem;font-weight:600;
}
.proj-grid {
  display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:16px;padding:16px 20px;
}
.proj-list { display:none;flex-direction:column;gap:0 }
.no-proj {
  padding:24px;text-align:center;font-size:.8rem;
  color:var(--text-light);display:flex;align-items:center;justify-content:center;gap:6px;
}

/* ═══ CARTE PROJET ═══ */
.proj-card {
  border-radius:16px;background:var(--white);overflow:hidden;
  transition:box-shadow .22s,transform .22s;
  display:flex;flex-direction:column;cursor:default;
  box-shadow:0 2px 8px rgba(0,0,0,.07), 0 0 0 1.5px var(--sand-dark);
}
.proj-card:hover {
  box-shadow:0 8px 28px rgba(46,125,50,.16), 0 0 0 1.5px rgba(46,125,50,.3);
  transform:translateY(-3px);
}
.pc-cover { height:160px;position:relative;overflow:hidden;flex-shrink:0 }
.pc-cover img { width:100%;height:100%;object-fit:cover;transition:transform .4s cubic-bezier(.25,.46,.45,.94) }
.proj-card:hover .pc-cover img { transform:scale(1.04) }
.pc-cover-ov {
  position:absolute;inset:0;
  background:linear-gradient(to bottom,rgba(0,0,0,.08) 0%,transparent 35%,rgba(0,0,0,.55) 100%);
}
.pc-cover-top {
  position:absolute;top:10px;left:10px;right:10px;
  display:flex;align-items:flex-start;justify-content:space-between;gap:6px;
}
.pc-type-badge {
  display:flex;align-items:center;gap:5px;
  background:rgba(255,255,255,.16);backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,.25);border-radius:20px;
  padding:4px 10px 4px 6px;
}
.pc-type-ico {
  width:22px;height:22px;border-radius:6px;
  background:rgba(255,255,255,.25);
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:.7rem;flex-shrink:0;
}
.pc-type-lbl { font-size:.62rem;font-weight:700;color:#fff;letter-spacing:.02em }
.pc-statut {
  font-size:.6rem;font-weight:700;padding:4px 9px;border-radius:20px;
  border:1px solid;backdrop-filter:blur(6px);
  display:flex;align-items:center;gap:4px;color:#fff;white-space:nowrap;flex-shrink:0;
}
.pc-cover-bottom {
  position:absolute;bottom:0;left:0;right:0;
  padding:10px 12px;display:flex;align-items:flex-end;justify-content:space-between;gap:8px;
}
.pc-num {
  font-size:1rem;font-family:'Courier New',monospace;font-weight:700;letter-spacing:.05em;
  color:rgba(255,255,255,.9);background:rgba(0,0,0,.28);
  padding:2px 8px;border-radius:6px;backdrop-filter:blur(3px);
  border:1px solid rgba(255,255,255,.12);flex-shrink:0;
}
.pc-report-btn {
  display:flex;align-items:center;gap:5px;
  padding:5px 10px;border-radius:8px;font-size:.67rem;font-weight:700;
  color:#fff;background:rgba(255,255,255,.15);backdrop-filter:blur(6px);
  border:1px solid rgba(255,255,255,.25);text-decoration:none;
  transition:background .18s,transform .18s;flex-shrink:0;
  opacity:0;transform:translateY(4px);
}
.proj-card:hover .pc-report-btn { opacity:1;transform:translateY(0) }
.pc-report-btn:hover { background:rgba(255,255,255,.3);color:#fff }
.pc-body { padding:14px 16px 10px;flex:1;display:flex;flex-direction:column }
.pc-nom {
  font-size:.92rem;font-weight:800;color:var(--text);line-height:1.25;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
  letter-spacing:-.02em;margin-bottom:8px;
}
.pc-infos { display:flex;flex-direction:column;gap:4px;margin-bottom:12px }
.pc-info { display:flex;align-items:center;gap:6px;font-size:.7rem;color:var(--text-light) }
.pc-info i { font-size:.65rem;width:12px;text-align:center;flex-shrink:0 }
.pc-info span { overflow:hidden;text-overflow:ellipsis;white-space:nowrap }
.pc-fin {
  background:linear-gradient(135deg,rgba(46,125,50,.04),rgba(46,125,50,.02));
  border:1px solid rgba(46,125,50,.1);border-radius:10px;padding:10px 12px;
}
.pc-fin-top { display:flex;align-items:baseline;justify-content:space-between;margin-bottom:6px;gap:6px }
.pc-budget-lbl { font-size:.6rem;color:var(--text-light);font-weight:500 }
.pc-budget-val {
  font-size:.94rem;font-weight:900;color:var(--green-dark);
  letter-spacing:-.03em;line-height:1;display:flex;align-items:baseline;gap:3px;
}
.pc-budget-mru { font-size:.6rem;font-weight:600;color:var(--text-light) }
.pc-taux-badge { font-size:.65rem;font-weight:800;padding:3px 8px;border-radius:10px;flex-shrink:0 }
.pc-bar-bg { height:5px;border-radius:10px;background:rgba(46,125,50,.12);overflow:hidden }
.pc-bar-f  { height:100%;border-radius:10px;background:linear-gradient(90deg,var(--green-dark),var(--gl));transition:width .9s cubic-bezier(.16,1,.3,1) }
.pc-paid-row { display:flex;justify-content:space-between;align-items:center;margin-top:5px }
.pc-paid-lbl { font-size:.6rem;color:var(--text-light) }
.pc-paid-val { font-size:.7rem;font-weight:700;color:var(--green-mid) }
.pc-footer { border-top:1px solid rgba(46,125,50,.08);display:flex;flex-direction:column }
.pc-media-row { display:flex;align-items:center;justify-content:space-between;padding:8px 14px 7px }
.pc-media-chips { display:flex;gap:5px }
.pc-chip {
  display:flex;align-items:center;gap:3px;font-size:.65rem;font-weight:600;
  padding:3px 7px;border-radius:8px;background:var(--sand);color:var(--text-light);
  transition:.15s;border:1px solid transparent;
}
.pc-chip:hover { background:var(--sand-dark) }
.pc-chip i { font-size:.6rem }
.pc-chip.has { color:var(--text-mid);font-weight:700 }
.pc-prog-lbl { font-size:.62rem;font-weight:700;color:var(--green-mid);letter-spacing:-.01em }
.pc-actions {
  display:grid;grid-template-columns:repeat(5,1fr);
  border-top:1px solid rgba(46,125,50,.08);
  border-radius:0 0 14px 14px;overflow:hidden;
}
.pca {
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:2px;padding:9px 2px 8px;
  border:none;background:transparent;color:var(--text-light);cursor:pointer;
  font-size:.55rem;font-weight:600;font-family:inherit;
  transition:background .15s,color .15s;text-decoration:none;line-height:1;
  border-right:1px solid rgba(46,125,50,.08);position:relative;overflow:hidden;
}
.pca:last-child { border-right:none }
.pca i { font-size:.95rem;display:block;margin-bottom:2px;transition:transform .2s cubic-bezier(.34,1.56,.64,1) }
.pca:hover i     { transform:translateY(-2px) scale(1.15) }
.pca:active i    { transform:scale(.88) }
.pca:hover               { background:rgba(46,125,50,.06);color:var(--gm) }
.pca.pca-view:hover      { background:rgba(2,136,209,.07);color:var(--bl) }
.pca.pca-add:hover       { background:rgba(46,125,50,.07);color:var(--gm) }
.pca.pca-edit:hover      { background:rgba(212,160,23,.07);color:var(--go) }
.pca.pca-del             { color:var(--txt3) }
.pca.pca-del:hover       { background:rgba(211,47,47,.07);color:var(--rd) }
.pca.pca-sep-before::before {
  content:'';position:absolute;left:0;top:22%;bottom:22%;
  width:1px;background:rgba(46,125,50,.12);
}
.pca[title]:hover::after {
  content:attr(title);
  position:absolute;bottom:calc(100% + 5px);left:50%;transform:translateX(-50%);
  background:rgba(20,40,20,.88);color:#fff;
  font-size:.6rem;padding:3px 8px;border-radius:6px;
  white-space:nowrap;pointer-events:none;z-index:10;
  animation:tipIn .12s ease;
}
@keyframes tipIn { from{opacity:0;transform:translateX(-50%) translateY(3px)} to{opacity:1;transform:translateX(-50%) translateY(0)} }

/* ═══ VUE LISTE ═══ */
.pac {
  width:30px;height:30px;border-radius:8px;border:none;background:transparent;
  color:var(--text-light);cursor:pointer;display:inline-flex;
  align-items:center;justify-content:center;font-size:.8rem;transition:.15s;text-decoration:none;
}
.pac:hover    { background:var(--green-ghost);color:var(--gm) }
.pac.rd:hover { background:var(--rd2);color:var(--rd) }
.pac.bl:hover { background:var(--bl2);color:var(--bl) }
.pac.go:hover { background:var(--go2);color:var(--go) }
.proj-row {
  display:flex;align-items:center;gap:12px;
  padding:11px 20px;border-bottom:1px solid rgba(46,125,50,.07);transition:.15s;
}
.proj-row:last-child { border-bottom:none }
.proj-row:hover { background:rgba(46,125,50,.03) }
.pr-type-ico { width:36px;height:36px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.9rem }
.pr-main { flex:1;min-width:0 }
.pr-nom  { font-size:.86rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.pr-sub  { display:flex;gap:8px;font-size:.68rem;color:var(--text-light);margin-top:3px;flex-wrap:wrap }
.pr-sub span { display:flex;align-items:center;gap:3px }
.pr-fin  { min-width:120px }
.pr-fin-top { display:flex;justify-content:space-between;font-size:.7rem;margin-bottom:4px }
.pr-fin-top span:last-child { color:var(--green-mid);font-weight:700 }
.pr-fin-bg { height:4px;border-radius:2px;background:var(--sand-dark) }
.pr-fin-f  { height:100%;border-radius:2px;background:var(--gm);transition:width .8s ease }
.pr-actions { display:flex;gap:3px }

/* ═══ MODALES ═══ */
.mo {
  position:fixed;inset:0;background:rgba(20,83,45,.32);
  backdrop-filter:blur(5px);z-index:1050;
  display:none;align-items:center;justify-content:center;padding:16px;
}
.mo.open { display:flex;animation:moIn .2s ease }
@keyframes moIn { from{opacity:0}to{opacity:1} }
.md {
  background:var(--white);border-radius:18px;width:100%;
  box-shadow:0 24px 80px rgba(20,83,45,.18);
  animation:mdIn .28s cubic-bezier(.16,1,.3,1);
  max-height:92vh;display:flex;flex-direction:column;overflow:hidden;
}
@keyframes mdIn { from{opacity:0;transform:translateY(18px) scale(.97)}to{opacity:1;transform:none} }
.md-sm  { max-width:420px }
.md-md  { max-width:640px }
.md-lg  { max-width:820px }
.md-xl  { max-width:960px }
.mh {
  padding:20px 24px 16px;
  background:linear-gradient(to bottom,#fff,#fafdf9);
  border-bottom:1px solid var(--sand-dark);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.mh-l  { display:flex;align-items:center;gap:10px }
.mi    { width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0 }
.mi.g  { background:rgba(46,125,50,.1);color:var(--green-mid) }
.mi.b  { background:rgba(2,136,209,.1);color:var(--blue) }
.mi.r  { background:rgba(211,47,47,.1);color:var(--red) }
.mi.o  { background:rgba(212,160,23,.1);color:var(--go) }
.mi.p  { background:rgba(123,31,162,.1);color:var(--pu) }
.mt    { font-size:.95rem;font-weight:700;color:var(--text);letter-spacing:-.02em }
.ms    { font-size:.72rem;color:var(--text-light);margin-top:1px }
.mcls  {
  width:34px;height:34px;border-radius:8px;border:none;
  background:var(--sand);color:var(--text-light);
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.95rem;transition:.15s;
}
.mcls:hover { background:var(--red-light);color:var(--red) }
.mb  { padding:22px 24px;overflow-y:auto;flex:1 }
.mf  {
  padding:14px 24px;border-top:1px solid var(--sand-dark);
  display:flex;align-items:center;justify-content:flex-end;
  gap:9px;flex-shrink:0;background:var(--sand);
}
.btn { display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-xs);border:none;font-size:.82rem;font-weight:600;cursor:pointer;font-family:inherit;transition:.2s;text-decoration:none }
.btn-p { background:linear-gradient(135deg,var(--green-dark),var(--green-mid));color:#fff;box-shadow:0 3px 12px rgba(46,125,50,.22) }
.btn-p:hover { transform:translateY(-1px);box-shadow:0 6px 20px rgba(46,125,50,.32) }
.btn-s { background:var(--sand);color:var(--text-mid);border:1.5px solid var(--sand-dark) }
.btn-s:hover { background:var(--sand-dark) }
.btn-d { background:var(--red);color:#fff }
.btn-d:hover { background:#b71c1c }
.btn-sm { padding:6px 13px;font-size:.76rem }
.fc {
  background:var(--sand);border:1.5px solid transparent;
  border-radius:var(--radius-xs);padding:10px 12px;
  font-size:.84rem;font-family:inherit;color:var(--text);
  outline:none;transition:.22s;width:100%;
}
.fc:focus { background:var(--white);border-color:var(--green-mid);box-shadow:0 0 0 3px rgba(46,125,50,.06) }
.fc::placeholder { color:var(--text-light);font-weight:300 }
.req { color:var(--red);font-size:.7rem }
.frow { display:flex;flex-direction:column;gap:5px;margin-bottom:14px }
.frow label { font-size:.74rem;font-weight:600;color:var(--text-mid) }
.frow.c2 { display:grid;grid-template-columns:1fr 1fr;gap:12px }
.frow.c2 > div { display:flex;flex-direction:column;gap:5px }
.frow.c2 > div label { font-size:.74rem;font-weight:600;color:var(--text-mid) }
.frow.c3 { display:grid;grid-template-columns:2fr 1fr 1fr;gap:12px;align-items:start }
.frow.c3 > div { display:flex;flex-direction:column;gap:5px }
.frow.c3 > div label { font-size:.74rem;font-weight:600;color:var(--text-mid) }
.fg { display:flex;flex-direction:column;gap:5px;margin-bottom:14px }
.fg label { font-size:.74rem;font-weight:600;color:var(--text-mid) }
.uzn {
  border:2px dashed var(--sand-dark);border-radius:var(--radius-xs);
  padding:20px;text-align:center;cursor:pointer;transition:.22s;
  background:var(--sand);position:relative;
}
.uzn:hover,.uzn.drag { border-color:var(--green-mid);background:var(--green-ghost) }
.uzn i      { font-size:1.6rem;color:var(--text-light);display:block;margin-bottom:6px }
.uz-t       { font-size:.78rem;font-weight:600;color:var(--text-mid) }
.uz-s       { font-size:.65rem;color:var(--text-light);margin-top:3px }
.file-ready {
  display:none;align-items:center;gap:12px;
  background:linear-gradient(135deg,rgba(46,125,50,.06),rgba(46,125,50,.03));
  border:1.5px solid rgba(46,125,50,.25);border-radius:var(--radius-xs);padding:14px 16px;
}
.file-ready.vis { display:flex }
.fr-ico { width:42px;height:42px;border-radius:10px;flex-shrink:0;background:rgba(46,125,50,.12);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--gm) }
.fr-info { flex:1;min-width:0 }
.fr-name { font-size:.82rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.fr-sub  { font-size:.68rem;color:var(--text-light);margin-top:2px;display:flex;align-items:center;gap:6px }
.fr-ok   { font-size:.65rem;font-weight:700;color:var(--gm);background:rgba(46,125,50,.1);padding:1px 7px;border-radius:8px;display:flex;align-items:center;gap:3px }
.fr-chg  { flex-shrink:0;border:none;background:var(--sand-dark);color:var(--text-mid);border-radius:7px;padding:5px 10px;font-size:.7rem;font-weight:600;cursor:pointer;transition:.15s;font-family:inherit;display:flex;align-items:center;gap:4px }
.fr-chg:hover { background:var(--sand2);color:var(--text) }

/* ═══ VISU BILAN ═══ */
.visu-bilan {
  background:linear-gradient(135deg,#0f3d1f 0%,var(--green-deep) 50%,var(--green-mid) 100%);
  border-radius:var(--radius-sm);padding:18px 20px;margin-bottom:16px;
  box-shadow:0 4px 20px rgba(20,83,45,.2);
}
.vb-row { display:flex;justify-content:space-between;align-items:center;margin-bottom:8px }
.vb-lbl { font-size:.72rem;color:rgba(255,255,255,.65) }
.vb-val { font-size:.88rem;font-weight:700;color:#fff }
.vb-sep { height:1px;background:rgba(255,255,255,.15);margin:10px 0 }
.vb-pg  { margin-top:10px }
.vb-pg-lbl { display:flex;justify-content:space-between;font-size:.65rem;color:rgba(255,255,255,.6);margin-bottom:5px }
.vb-pg-bg  { height:6px;border-radius:3px;background:rgba(255,255,255,.2) }
.vb-pg-f   { height:100%;border-radius:3px;background:linear-gradient(90deg,#A5D6A7,#69F0AE);transition:width .8s ease }
.visu-tabs {
  display:flex;gap:4px;overflow-x:auto;margin-bottom:14px;
  border-bottom:1.5px solid var(--sand-dark);padding-bottom:0;
}
.vtab {
  display:flex;align-items:center;gap:6px;padding:9px 14px;
  border:none;background:transparent;font-size:.76rem;font-weight:600;
  color:var(--text-light);cursor:pointer;transition:.15s;
  border-radius:var(--radius-xs) var(--radius-xs) 0 0;white-space:nowrap;
  font-family:inherit;border-bottom:2.5px solid transparent;margin-bottom:-1.5px;
}
.vtab:hover  { color:var(--green-mid);background:var(--green-ghost) }
.vtab.active { color:var(--green-mid);border-bottom-color:var(--green-mid);background:var(--green-ghost) }
.vtab-cnt { background:var(--green-mid);color:#fff;font-size:.58rem;padding:1px 6px;border-radius:10px;font-weight:700 }
.vpanel        { display:none }
.vpanel.active { display:block }
.irow  { display:flex;align-items:flex-start;gap:10px;padding:7px 0;border-bottom:1px solid var(--sand-dark) }
.irow:last-child { border-bottom:none }
.ilbl  { font-size:.7rem;font-weight:600;color:var(--text-light);min-width:120px;flex-shrink:0;padding-top:1px }
.ival  { font-size:.8rem;color:var(--text) }
.pair  { display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--sand-dark) }
.pair:last-child { border-bottom:none }
.pai-ico { width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0 }
.pai-info { flex:1;min-width:0 }
.pai-mt  { font-size:.85rem;font-weight:700;color:var(--text) }
.pai-sub { font-size:.68rem;color:var(--text-light);margin-top:2px }
.pmode   { padding:1px 7px;border-radius:8px;font-size:.6rem;font-weight:600 }
.pgal      { display:grid;grid-template-columns:repeat(3,1fr);gap:8px }
.pgal-item { position:relative;aspect-ratio:1;border-radius:8px;overflow:hidden;cursor:pointer;background:var(--sand) }
.pgal-item img { width:100%;height:100%;object-fit:cover;transition:.2s }
.pgal-item:hover img { transform:scale(1.05) }
.frow2   { display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--sand-dark) }
.frow2:last-child { border-bottom:none }
.f-ico   { width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0 }
.f-name  { font-size:.8rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.f-sub   { font-size:.65rem;color:var(--text-light);margin-top:2px }
.vid-item  { display:flex;gap:10px;padding:9px 0;border-bottom:1px solid var(--sand-dark);align-items:center }
.vid-item:last-child { border-bottom:none }
.vid-thumb { position:relative;width:90px;flex-shrink:0;border-radius:8px;overflow:hidden;aspect-ratio:16/9;background:var(--sand) }
.vid-thumb img { width:100%;height:100%;object-fit:cover }
.vid-play  { position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.3) }
.vid-playbtn { color:#fff;font-size:1.4rem;text-decoration:none;transition:.15s }
.vid-playbtn:hover { transform:scale(1.15) }
.vid-info  { flex:1;min-width:0;display:flex;justify-content:space-between;align-items:center }
.vid-title { font-size:.8rem;font-weight:600;color:var(--text);line-height:1.3 }
.del-prev { text-align:center;padding:24px 0 }
.del-prev .di { font-size:2.5rem;margin-bottom:12px }
.del-prev p { font-size:.88rem;color:var(--text);line-height:1.6 }
.spill { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:600 }
.lb {
  position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:2000;
  display:none;align-items:center;justify-content:center;cursor:zoom-out;
}
.lb.open { display:flex }
.lb img  { max-width:90vw;max-height:90vh;border-radius:8px;object-fit:contain }
.lb-cls  {
  position:absolute;top:16px;right:16px;background:rgba(255,255,255,.15);
  border:none;color:#fff;width:36px;height:36px;border-radius:50%;cursor:pointer;
  font-size:1rem;display:flex;align-items:center;justify-content:center;transition:.15s;
}
.lb-cls:hover { background:rgba(255,255,255,.3) }
.flashes { padding:8px 32px 0 }
.fmsg    {
  display:flex;align-items:center;gap:10px;padding:11px 16px;
  border-radius:var(--radius-xs);font-size:.82rem;font-weight:500;margin-bottom:8px;
}
.fmsg.success { background:rgba(46,125,50,.1);color:var(--green-mid);border:1px solid rgba(46,125,50,.2) }
.fmsg.error   { background:var(--red-light);color:var(--red);border:1px solid rgba(211,47,47,.2) }
.statut-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.sp-lbl{position:relative;cursor:pointer}
.sp-pill{
  display:flex;align-items:center;gap:6px;padding:8px 10px;border-radius:9px;
  font-size:.71rem;font-weight:700;border:1.5px solid var(--brd);
  background:var(--sa,#FBF7F0);color:var(--txt3);transition:.18s;
  white-space:nowrap;overflow:hidden;user-select:none;
}
.sp-pill:hover{border-color:rgba(46,125,50,.3);color:var(--txt2,#4A6B4A);background:rgba(46,125,50,.05)}
.sp-pill.active{font-weight:800}
.sp-pill i{font-size:.8rem;flex-shrink:0}
.sp-text{overflow:hidden;text-overflow:ellipsis}

@media(max-width:992px){
  .ph-main{padding:20px 24px 16px}.stats-strip{padding:12px 24px 16px}
  .crud-toolbar{padding:10px 20px}.proj-grid{grid-template-columns:repeat(auto-fill,minmax(240px,1fr));padding:14px 20px}
  .assoc-header{padding:12px 16px}
}
@media(max-width:768px){
  .ph-main{padding:16px 16px 12px;flex-direction:column;align-items:flex-start;gap:12px}.ph-left{width:100%}
  .ph-title{font-size:1.15rem}.btn-hero{width:100%;justify-content:center}
  .stats-strip{padding:10px 16px 14px;gap:6px}.stat-chip{padding:7px 10px;flex:1;min-width:calc(50% - 6px)}
  .sc-v{font-size:.9rem}.crud-toolbar{padding:10px 14px;gap:8px}.fsel{flex:1;min-width:0}
  .proj-grid{grid-template-columns:1fr 1fr;gap:10px;padding:12px 14px}
  .assoc-header{padding:10px 14px;flex-direction:column;align-items:flex-start}
  .md-lg,.md-xl{max-width:100%;margin:0;border-radius:16px 16px 0 0}.mo{align-items:flex-end;padding:0}
  .frow.c2,.frow.c3{grid-template-columns:1fr}.pgal{grid-template-columns:repeat(2,1fr)}.ilbl{min-width:90px}
}
@media(max-width:480px){
  .ph-main{padding:14px 12px 10px}.stats-strip{padding:8px 12px 12px}
  .stat-chip{min-width:calc(50% - 4px);padding:6px 8px}.crud-toolbar{padding:8px 12px}
  .proj-grid{grid-template-columns:1fr;padding:10px 12px;gap:8px}.pc-cover{height:140px}
  .pgal{grid-template-columns:1fr}.mb{padding:16px}.mh{padding:14px 16px 12px}.mf{padding:10px 16px}.assoc-header{padding:8px 12px}
}

/* ═══ VISU 3 COLONNES ═══ */
.visu-grid {
  display:grid;
  grid-template-columns:220px 1fr 220px;
  gap:14px;
  min-height:0;
}
.visu-col { display:flex;flex-direction:column;gap:12px;min-width:0;min-height:0 }
.visu-col-mid { display:flex;flex-direction:column;gap:12px;min-width:0;min-height:0 }

/* Section titre colonne */
.vc-sec {
  font-size:.6rem;font-weight:800;color:var(--text-light);
  text-transform:uppercase;letter-spacing:.1em;
  padding-bottom:6px;border-bottom:1.5px solid var(--sand-dark);
  margin-bottom:4px;display:flex;align-items:center;gap:6px;
}
.vc-sec i { font-size:.75rem;color:var(--green-mid) }

/* Card colonne */
.vc-card {
  background:var(--sand);border:1px solid var(--sand-dark);
  border-radius:var(--radius-sm);padding:12px 14px;
}

/* Média tabs dans colonne du milieu */
.vmtabs {
  display:flex;gap:3px;background:var(--sand);
  border:1.5px solid var(--sand-dark);border-radius:var(--radius-sm);
  padding:3px;flex-shrink:0;
}
.vmtab {
  flex:1;padding:7px 6px;border:none;background:none;
  font-size:.68rem;font-weight:700;color:var(--text-light);
  cursor:pointer;border-radius:var(--rxs);transition:.15s;
  font-family:inherit;display:flex;align-items:center;justify-content:center;gap:4px;
}
.vmtab:hover { background:var(--green-ghost);color:var(--green-mid) }
.vmtab.active { background:var(--green-mid);color:#fff;box-shadow:0 2px 8px rgba(46,125,50,.25) }
.vmtab .cnt { font-size:.55rem;font-weight:800;padding:1px 5px;border-radius:8px;
  background:rgba(255,255,255,.25);min-width:16px;text-align:center }
.vmtab:not(.active) .cnt { background:var(--sand-dark);color:var(--text-light) }
.vmpanel { display:none }
.vmpanel.active { display:block }

/* Photo galerie 3 colonnes dans milieu */
.pgal3 { display:grid;grid-template-columns:repeat(3,1fr);gap:6px }
.pgal3-item {
  aspect-ratio:1;border-radius:8px;overflow:hidden;cursor:pointer;
  background:var(--sand);position:relative;
}
.pgal3-item img { width:100%;height:100%;object-fit:cover;transition:.2s }
.pgal3-item:hover img { transform:scale(1.05) }

/* Plaque drapeaux en bas */
.visu-plaque {
  margin-top:14px;
  background:linear-gradient(135deg,#f8f5f0,#fff);
  border:1.5px solid var(--sand-dark);border-radius:var(--radius-sm);
  padding:14px 18px;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
  flex-wrap:wrap;
  box-shadow:0 1px 6px rgba(0,0,0,.06);
}
.vp-flags { display:flex;align-items:center;gap:10px }
.vp-flag {
  width:44px;height:30px;border-radius:5px;overflow:hidden;
  border:1px solid rgba(0,0,0,.1);
  box-shadow:0 1px 4px rgba(0,0,0,.12);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:1.3rem;
}
.vp-logos { display:flex;align-items:center;gap:8px }
.vp-logo {
  height:32px;width:auto;border-radius:4px;
  border:1px solid var(--sand-dark);padding:2px;
  background:#fff;object-fit:contain;
}
.vp-info {
  display:flex;flex-direction:column;gap:3px;text-align:center;flex:1;
}
.vp-num {
  font-size:.75rem;font-weight:800;color:var(--green-dark);
  font-family:'Courier New',monospace;letter-spacing:.05em;
}
.vp-titre {
  font-size:.82rem;font-weight:900;color:var(--text);
  letter-spacing:-.01em;
}
.vp-lieu {
  font-size:.65rem;color:var(--text-light);
}
.vp-assoc {
  font-size:.62rem;color:var(--text-mid);font-weight:600;
  border-top:1px solid var(--sand-dark);padding-top:4px;margin-top:2px;
}

@media(max-width:900px) {
  .visu-grid { grid-template-columns:1fr 1fr }
}
@media(max-width:600px) {
  .visu-grid { grid-template-columns:1fr }
}
</style>
{% endblock %}

{% block body %}

{% for label, messages in app.flashes %}
  {% for msg in messages %}
  <div class="flashes">
    <div class="fmsg {{ label }}">
      <i class="bi bi-{{ label == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>{{ msg }}
    </div>
  </div>
  {% endfor %}
{% endfor %}

{# ═══ Calcul dernière année ═══ #}
{% set annees = [] %}
{% for assoc in associations %}
  {% if assocActive is null or assocActive.id == assoc.id %}
    {% for p in projetsParAssociation[assoc.id] ?? [] %}
      {% if p.annee and p.annee not in annees %}
        {% set annees = annees|merge([p.annee]) %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}
{% set lastAnnee = annees|sort|last %}

{# ═══ PAGE HEADER ═══ #}
<div class="page-header">
  <div class="ph-grid-deco"></div>
  <div class="ph-main">
    <div class="ph-left">
      <div class="ph-logo">
        {% if assocActive and assocActive.hasLogo %}
          <img src="{{ asset(assocActive.logoPath) }}" alt="{{ assocActive.nom }}">
        {% else %}
          <i class="bi bi-folder2-open"></i>
        {% endif %}
      </div>
      <div class="ph-text">
        <div class="ph-breadcrumb">
          <a href="{{ path('app_dashboard') }}">ADB-MR</a>
          <i class="bi bi-chevron-right"></i>
          {% if assocActive %}
            <a href="{{ path('app_projets') }}">{{ 'proj.breadcrumb'|trans }}</a>
            <i class="bi bi-chevron-right"></i>
            <span>{{ assocActive.sigle ?? assocActive.nom }}</span>
          {% else %}
            <span>{{ 'proj.breadcrumb'|trans }}</span>
          {% endif %}
        </div>
        <h1 class="ph-title">
          {% if assocActive %}
            {% if app.request.locale == 'ar' and assocActive.nomAr %}{{ assocActive.nomAr }}
            {% else %}{{ assocActive.nom }}{% endif %}
          {% else %}{{ 'proj.page_title'|trans }}{% endif %}
        </h1>
        {% if assocActive and assocActive.nomAr and app.request.locale != 'ar' %}
          <div class="ph-title-ar">{{ assocActive.nomAr }}</div>
        {% endif %}
        <div class="ph-sub">
          {% if assocActive %}
            {% if assocActive.sigle %}<strong>{{ assocActive.sigle }}</strong><span class="ph-sub-dot">·</span>{% endif %}
            {% if assocActive.ville %}<span>{{ assocActive.ville }}</span><span class="ph-sub-dot">·</span>{% endif %}
            <span>{{ (projetsParAssociation[assocActive.id] ?? [])|length }} {{ 'proj.stat_total'|trans }}</span>
          {% else %}
            <span>{{ associations|length }} {{ 'proj.stat_assoc'|trans }}</span>
            <span class="ph-sub-dot">·</span>
            <span>{{ totalProjets }} {{ 'proj.stat_total'|trans }}</span>
          {% endif %}
        </div>
      </div>
    </div>
    <button class="btn-hero primary" onclick="openMo('moCreate')">
      <i class="bi bi-plus-lg"></i>{{ 'proj.btn_new'|trans }}
    </button>
  </div>

  <div class="stats-strip">
    {% if assocActive %}
      {% set projs_a = projetsParAssociation[assocActive.id] ?? [] %}
      {% set budg_a = 0 %}{% for p in projs_a %}{% set budg_a = budg_a + p.coutTotal %}{% endfor %}
      {% set paye_a = 0 %}{% for p in projs_a %}{% set paye_a = paye_a + p.montantTotalPaye %}{% endfor %}
      <div class="stat-chip"><div class="sc-ico">📋</div><div><div class="sc-v">{{ projs_a|length }}</div><div class="sc-l">{{ 'proj.stat_total'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">⚙️</div><div><div class="sc-v">{{ enCours }}</div><div class="sc-l">{{ 'proj.stat_in_progress'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">✅</div><div><div class="sc-v">{{ termines }}</div><div class="sc-l">{{ 'proj.stat_done'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">💰</div><div><div class="sc-v">{{ (budg_a/1000000)|number_format(1) }}M</div><div class="sc-l">{{ 'proj.stat_budget'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">💳</div><div><div class="sc-v">{{ (paye_a/1000000)|number_format(1) }}M</div><div class="sc-l">{{ 'proj.bilan_paid'|trans }}</div></div></div>
      {% if budg_a > 0 %}
        {% set taux_global = (paye_a / budg_a * 100)|round(0) %}
        <div class="stat-chip"><div class="sc-ico">📊</div><div>
          <div class="sc-v" style="color:{{ taux_global >= 100 ? '#81C784' : (taux_global >= 50 ? '#FFD54F' : '#EF9A9A') }}">{{ taux_global }}%</div>
          <div class="sc-l">{{ 'proj.bilan_rate'|trans }}</div>
        </div></div>
      {% endif %}
    {% else %}
      <div class="stat-chip"><div class="sc-ico">🏢</div><div><div class="sc-v">{{ associations|length }}</div><div class="sc-l">{{ 'proj.stat_assoc'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">📋</div><div><div class="sc-v">{{ totalProjets }}</div><div class="sc-l">{{ 'proj.stat_total'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">⚙️</div><div><div class="sc-v">{{ enCours }}</div><div class="sc-l">{{ 'proj.stat_in_progress'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">✅</div><div><div class="sc-v">{{ termines }}</div><div class="sc-l">{{ 'proj.stat_done'|trans }}</div></div></div>
      <div class="stat-chip"><div class="sc-ico">💰</div><div><div class="sc-v">{{ (totalBudget/1000000)|number_format(1) }}M</div><div class="sc-l">{{ 'proj.stat_budget'|trans }}</div></div></div>
    {% endif %}
  </div>
</div>

{# ═══ TOOLBAR ═══ #}
<div class="crud-toolbar">
  <div class="search-box">
    <i class="bi bi-search"></i>
    <input id="q" type="text" placeholder="{{ 'proj.search_ph'|trans }}" oninput="filter()">
  </div>

  <select class="fsel" id="fStatut" onchange="filter()">
    <option value="">{{ 'proj.filter_statut'|trans }}</option>
    {% for k,v in constant('App\\Entity\\Projet::STATUTS') %}
    <option value="{{ k }}">{% if app.request.locale == 'ar' %}{{ v.label_ar }}{% else %}{{ v.label_fr }}{% endif %}</option>
    {% endfor %}
  </select>

  {% set types_used = [] %}
  {% for assoc in associations %}
    {% if assocActive is null or assocActive.id == assoc.id %}
      {% for p in projetsParAssociation[assoc.id] ?? [] %}
        {% if p.type and p.type not in types_used %}
          {% set types_used = types_used|merge([p.type]) %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}
  {% set all_types = constant('App\\Entity\\Projet::TYPES') %}
  <select class="fsel" id="fType" onchange="filter()">
    <option value="">{{ 'proj.filter_type'|trans }}</option>
    {% for k in types_used|sort %}
    <option value="{{ k }}">{{ all_types[k].label_ar ?? all_types[k].label_fr ?? k }}</option>
    {% endfor %}
  </select>

  <select class="fsel" id="fAssoc" onchange="filterOrNav(this.value)">
    <option value="">{{ 'proj.filter_assoc'|trans }}</option>
    {% for a in associations %}
      <option value="{{ a.id }}" {{ assocActive is not null and assocActive.id == a.id ? 'selected' }}>{{ a.nom }}</option>
    {% endfor %}
  </select>

  {# ── Année — pré-sélectionner la dernière ── #}
  <select class="fsel" id="fAnnee" onchange="filter()">
    <option value="">{{ 'proj.filter_annee'|trans }}</option>
    {% for y in annees|sort|reverse %}
    <option value="{{ y }}" {{ y == lastAnnee ? 'selected' }}>{{ y }}</option>
    {% endfor %}
  </select>

  <span class="tb-cnt" id="cnt">— {{ 'proj.filter_results'|trans }}</span>
  <div class="vtg">
    <button class="vb active" id="bGrid" onclick="setView('grid')" title="Grille"><i class="bi bi-grid-3x3-gap"></i></button>
    <button class="vb"        id="bList" onclick="setView('list')"  title="Liste"><i class="bi bi-list-ul"></i></button>
  </div>
</div>

{# ═══ CONTENU ═══ #}
<div class="proj-content">
  <div class="empty-grid" id="eg"><i class="bi bi-search"></i><p>{{ 'proj.no_results'|trans }}</p></div>

  {% for assoc in associations %}
  {% if assocActive is null or assocActive.id == assoc.id %}
  {% set projs = projetsParAssociation[assoc.id] ?? [] %}
  <div class="assoc-group ag" id="ag{{ assoc.id }}" data-aid="{{ assoc.id }}" data-anom="{{ assoc.nom|lower }}">
    <div class="assoc-header">
      <div class="assoc-left">
        <div class="assoc-logo">
          {% if assoc.hasLogo %}<img src="{{ asset(assoc.logoPath) }}" alt="">{% else %}🏢{% endif %}
        </div>
        <div>
          <div class="assoc-name">{{ assoc.nom }}</div>
          <div class="assoc-meta">
            {% if assoc.sigle %}<strong style="color:var(--gm)">{{ assoc.sigle }}</strong> ·{% endif %}
            {% if assoc.ville %}<i class="bi bi-geo-alt" style="font-size:.6rem"></i>{{ assoc.ville }}{% endif %}
          </div>
        </div>
      </div>
      <div class="assoc-right">
        <span class="a-badge" style="background:rgba(46,125,50,.1);color:var(--gm)">
          <i class="bi bi-folder2"></i>{{ projs|length }} {{ 'proj.stat_total'|trans }}
        </span>
        {% set ba = 0 %}{% for p in projs %}{% set ba = ba + p.coutTotal %}{% endfor %}
        {% if ba > 0 %}
        <span class="a-badge" style="background:var(--go2);color:var(--go)">
          <i class="bi bi-cash-stack"></i>{{ (ba/1000)|number_format(0) }}K MRU
        </span>
        {% endif %}
      </div>
    </div>

    <div class="proj-grid" id="pgrid{{ assoc.id }}">
      {% if projs is empty %}
      <div class="no-proj" style="grid-column:1/-1"><i class="bi bi-folder2-open"></i>{{ 'proj.no_projects'|trans }}</div>
      {% else %}
      {% for p in projs %}
      {% set taux = p.coutTotal > 0 ? (p.montantTotalPaye / p.coutTotal * 100)|round(1) : 0 %}
      {% set tauxColor = taux >= 100 ? 'var(--gm)' : (taux >= 50 ? 'var(--go)' : 'var(--rd)') %}
      {% set tauxBg = taux >= 100 ? 'rgba(46,125,50,.12)' : (taux >= 50 ? 'rgba(212,160,23,.12)' : 'rgba(211,47,47,.1)') %}
      <div class="proj-card" id="c{{ p.id }}"
           data-nom="{{ p.nom|lower }}" data-num="{{ p.numero|lower }}"
           data-statut="{{ p.statut }}" data-type="{{ p.type }}"
           data-aid="{{ assoc.id }}" data-lieu="{{ p.lieu|lower }}" data-don="{{ p.donateur|lower }}"
           data-annee="{{ p.annee }}">
        <div class="pc-cover" style="background:linear-gradient(135deg,{{ p.typeCouleur }}dd 0%,{{ p.typeCouleur }}88 100%)">
          {% if p.coverPhoto %}<img src="{{ asset(p.coverPhoto.path) }}" alt="" loading="lazy">{% endif %}
          <div class="pc-cover-ov"></div>
          <div class="pc-cover-top">
            <div class="pc-type-badge">
              <div class="pc-type-ico"><i class="bi {{ p.typeIcone }}"></i></div>
              <span class="pc-type-lbl">{% if app.request.locale == 'ar' %}{{ p.typeLabelAr ?? p.typeLabel }}{% else %}{{ p.typeLabel }}{% endif %}</span>
            </div>
            <span class="pc-statut" style="background:{{ p.statutCouleur }}35;border-color:{{ p.statutCouleur }}55">
              <i class="bi {{ p.statutIcone }}"></i>{% if app.request.locale == 'ar' %}{{ p.statutLabelAr }}{% else %}{{ p.statutLabel }}{% endif %}
            </span>
          </div>
          <div class="pc-cover-bottom">
            <span class="pc-num">{{ p.numero }}</span>
            <a href="{{ path('app_projet_show', {id: p.id}) }}" class="pc-report-btn" onclick="event.stopPropagation()">
              <i class="bi bi-box-arrow-up-right"></i>{{ 'proj.action_report'|trans }}
            </a>
          </div>
        </div>
        <div class="pc-body">
          <div class="pc-nom">{{ p.nom }}</div>
          <div class="pc-infos">
            <div class="pc-info"><i class="bi bi-geo-alt" style="color:var(--gm)"></i><span>{{ p.lieu }}{% if p.pays and p.pays != 'Mauritanie' %}, {{ p.pays }}{% endif %}</span></div>
            <div class="pc-info"><i class="bi bi-person" style="color:var(--bl)"></i><span>{{ p.donateur }}</span></div>
            <div class="pc-info"><i class="bi bi-calendar3" style="color:var(--go)"></i><span>{{ p.annee }}{% if p.duree %} · {{ p.duree }}{% endif %}</span></div>
          </div>
          <div class="pc-fin">
            <div class="pc-fin-top">
              <div>
                <div class="pc-budget-lbl">{{ 'proj.bilan_budget'|trans }}</div>
                <div class="pc-budget-val">
                  <span>{{ p.coutTotal|number_format(0, '.', ' ')|replace({' ': '&nbsp;'})|raw }}</span>
                  <span class="pc-budget-mru">MRU</span>
                </div>
              </div>
              <span class="pc-taux-badge" style="background:{{ tauxBg }};color:{{ tauxColor }}">{{ taux }}%</span>
            </div>
            <div class="pc-bar-bg"><div class="pc-bar-f" style="width:0;--pw:{{ taux }}%"></div></div>
            <div class="pc-paid-row">
              <span class="pc-paid-lbl">{{ 'proj.bilan_paid'|trans }}</span>
              <span class="pc-paid-val">{{ p.montantTotalPaye|number_format(0, '.', ' ')|replace({' ': '&nbsp;'})|raw }}&nbsp;MRU</span>
            </div>
          </div>
        </div>
        <div class="pc-footer">
          <div class="pc-media-row">
            <div class="pc-media-chips">
              <span class="pc-chip {% if p.paiements|length > 0 %}has{% endif %}" style="{% if p.paiements|length > 0 %}background:rgba(212,160,23,.1);color:var(--go);border-color:rgba(212,160,23,.2){% endif %}"><i class="bi bi-cash"></i>{{ p.paiements|length }}</span>
              <span class="pc-chip {% if p.photos|length > 0 %}has{% endif %}" style="{% if p.photos|length > 0 %}background:rgba(123,31,162,.08);color:#7B1FA2;border-color:rgba(123,31,162,.15){% endif %}"><i class="bi bi-images"></i>{{ p.photos|length }}</span>
              <span class="pc-chip {% if p.fichiers|length > 0 %}has{% endif %}" style="{% if p.fichiers|length > 0 %}background:rgba(211,47,47,.07);color:var(--rd);border-color:rgba(211,47,47,.15){% endif %}"><i class="bi bi-file-earmark-pdf"></i>{{ p.fichiers|length }}</span>
              <span class="pc-chip {% if p.videos|length > 0 %}has{% endif %}" style="{% if p.videos|length > 0 %}background:rgba(2,136,209,.07);color:var(--bl);border-color:rgba(2,136,209,.15){% endif %}"><i class="bi bi-play-circle"></i>{{ p.videos|length }}</span>
            </div>
            <span class="pc-prog-lbl">{{ p.progression }}%</span>
          </div>
          <div class="pc-actions">
            <button class="pca pca-view" onclick="ouvrirVisu({{ p.id }})" title="{{ 'proj.action_view'|trans }}"><i class="bi bi-eye"></i><span>{{ 'proj.action_view'|trans }}</span></button>
            <button class="pca pca-add" onclick="ouvrirAddDirect({{ p.id }},'photo')" title="{{ 'proj.pho_add_title'|trans }}"><i class="bi bi-camera"></i><span>Photo</span></button>
            <button class="pca pca-add pca-sep-before" onclick="ouvrirAddDirect({{ p.id }},'fichier')" title="{{ 'proj.fi_add_title'|trans }}"><i class="bi bi-file-earmark-arrow-up"></i><span>PDF</span></button>
            <button class="pca pca-edit pca-sep-before" onclick="ouvrirEdit({{ p.id }})" title="{{ 'proj.action_edit'|trans }}"><i class="bi bi-pencil"></i><span>{{ 'proj.action_edit'|trans }}</span></button>
            <button class="pca pca-del" onclick="ouvrirDelete({{ p.id }},'{{ p.nom|e('js') }}')" title="{{ 'proj.action_delete'|trans }}"><i class="bi bi-trash3"></i><span>{{ 'proj.action_delete'|trans }}</span></button>
          </div>
        </div>
      </div>

      <div class="proj-row" id="r{{ p.id }}" style="display:none"
           data-nom="{{ p.nom|lower }}" data-num="{{ p.numero|lower }}"
           data-statut="{{ p.statut }}" data-type="{{ p.type }}"
           data-aid="{{ assoc.id }}" data-lieu="{{ p.lieu|lower }}" data-don="{{ p.donateur|lower }}"
           data-annee="{{ p.annee }}">
        <div class="pr-type-ico" style="background:{{ p.typeCouleur }}18"><i class="bi {{ p.typeIcone }}" style="color:{{ p.typeCouleur }}"></i></div>
        <div class="pr-main">
          <div class="pr-nom">{{ p.nom }}</div>
          <div class="pr-sub">
            <span><i class="bi bi-hash" style="font-size:.6rem"></i>{{ p.numero }}</span>
            <span><i class="bi bi-geo-alt" style="font-size:.6rem"></i>{{ p.lieu }}</span>
            <span><i class="bi bi-person" style="font-size:.6rem"></i>{{ p.donateur }}</span>
            <span>{{ p.annee }}</span>
          </div>
        </div>
        <div class="pr-fin">
          <div class="pr-fin-top"><span>{{ p.coutTotal|number_format(0, ',', ' ') }} MRU</span><span>{{ taux }}%</span></div>
          <div class="pr-fin-bg"><div class="pr-fin-f" style="width:0;--pw:{{ taux }}%"></div></div>
        </div>
        <span class="spill" style="background:{{ p.statutCouleur }}18;color:{{ p.statutCouleur }}">
          <i class="bi {{ p.statutIcone }}"></i>{% if app.request.locale == 'ar' %}{{ p.statutLabelAr }}{% else %}{{ p.statutLabel }}{% endif %}
        </span>
        <div class="pr-actions">
          <button class="pac" onclick="ouvrirVisu({{ p.id }})"><i class="bi bi-eye"></i></button>
          <button class="pac" onclick="ouvrirAddDirect({{ p.id }},'photo')"><i class="bi bi-camera"></i></button>
          <button class="pac" onclick="ouvrirAddDirect({{ p.id }},'fichier')"><i class="bi bi-file-earmark-arrow-up"></i></button>
          <button class="pac" onclick="ouvrirAddDirect({{ p.id }},'video')"><i class="bi bi-youtube"></i></button>
          <a href="{{ path('app_projet_show', {id: p.id}) }}" class="pac"><i class="bi bi-file-earmark-text"></i></a>
          <button class="pac" onclick="ouvrirEdit({{ p.id }})"><i class="bi bi-pencil"></i></button>
          <button class="pac rd" onclick="ouvrirDelete({{ p.id }},'{{ p.nom|e('js') }}')"><i class="bi bi-trash3"></i></button>
        </div>
      </div>
      {% endfor %}
      {% endif %}
    </div>
    <div class="proj-list" id="plist{{ assoc.id }}"></div>
  </div>
  {% endif %}
  {% endfor %}
</div>

{# ═══ DONNÉES JS ═══ #}
<script>
const PROJETS = {
{% for assoc in associations %}
{% if assocActive is null or assocActive.id == assoc.id %}
  {% for p in projetsParAssociation[assoc.id] ?? [] %}
  {{ p.id }}: {
    id: {{ p.id }},
    nom: {{ p.nom|json_encode|raw }},
    numero: {{ p.numero|json_encode|raw }},
    type: {{ p.type|json_encode|raw }},
    typeLabel: {{ p.typeLabel|json_encode|raw }},
    typeIcone: {{ p.typeIcone|json_encode|raw }},
    typeCouleur: {{ p.typeCouleur|json_encode|raw }},
    statut: {{ p.statut|json_encode|raw }},
    statutLabel: {{ (app.request.locale == 'ar' ? p.statutLabelAr : p.statutLabel)|json_encode|raw }},
    statutIcone: {{ p.statutIcone|json_encode|raw }},
    statutCouleur: {{ p.statutCouleur|json_encode|raw }},
    lieu: {{ p.lieu|json_encode|raw }},
    pays: {{ p.pays|json_encode|raw }},
    donateur: {{ p.donateur|json_encode|raw }},
    coutTotal: {{ p.coutTotal }},
    montantPaye: {{ p.montantTotalPaye }},
    montantRestant: {{ p.montantRestant }},
    tauxPaiement: {{ p.tauxPaiement }},
    progression: {{ p.progression }},
    annee: {{ p.annee }},
    duree: {{ p.duree|json_encode|raw }},
    description: {{ (p.description ?? '')|json_encode|raw }},
    assocNom: {{ assoc.nom|json_encode|raw }},
    assocId: {{ assoc.id }},
    dateContrat: {{ p.dateContrat ? p.dateContrat|date('d/m/Y')|json_encode|raw : 'null' }},
    dateFin: {{ p.dateFin ? p.dateFin|date('d/m/Y')|json_encode|raw : 'null' }},
    paiements: [{% for pai in p.paiements %}{id:{{ pai.id }},montant:{{ pai.montant }},modeLabel:{{ pai.getModeLabel(app.request.locale)|json_encode|raw }},modeIcone:{{ pai.modeIcone|json_encode|raw }},modeCouleur:{{ pai.modeCouleur|json_encode|raw }},date:{{ pai.datePaiement|date('d/m/Y')|json_encode|raw }},reference:{{ (pai.reference ?? '')|json_encode|raw }},justif:{{ pai.hasJustificatif ? asset(pai.justificatifPath)|json_encode|raw : 'null' }},csrfDel:{{ csrf_token('delete_paiement_'~pai.id)|json_encode|raw }}}{% if not loop.last %},{% endif %}{% endfor %}],
    photos: [{% for ph in p.photos %}{id:{{ ph.id }},path:{{ asset(ph.path)|json_encode|raw }},legende:{{ (ph.legende ?? ph.originalName)|json_encode|raw }},csrfDel:{{ csrf_token('delete_photo_'~ph.id)|json_encode|raw }}}{% if not loop.last %},{% endif %}{% endfor %}],
    fichiers: [{% for fi in p.fichiers %}{id:{{ fi.id }},nom:{{ fi.originalName|json_encode|raw }},cat:{{ (app.request.locale == 'ar' ? fi.categorieLabelAr : fi.categorieLabel)|json_encode|raw }},catCouleur:{{ fi.categorieCouleur|json_encode|raw }},catIcone:{{ fi.categorieIcone|json_encode|raw }},path:{{ asset(fi.path)|json_encode|raw }},taille:{{ (fi.tailleFormatee ?? '')|json_encode|raw }},csrfDel:{{ csrf_token('delete_fichier_'~fi.id)|json_encode|raw }}}{% if not loop.last %},{% endif %}{% endfor %}],
    videos: [{% for vi in p.videos %}{id:{{ vi.id }},titre:{{ (vi.titre ?? '')|json_encode|raw }},url:{{ vi.url|json_encode|raw }},thumb:{{ (vi.thumbnailUrl ?? '')|json_encode|raw }},csrfDel:{{ csrf_token('delete_video_'~vi.id)|json_encode|raw }}}{% if not loop.last %},{% endif %}{% endfor %}],
    csrfEdit:{{ csrf_token('projet_edit_'~p.id)|json_encode|raw }},
    csrfDel:{{ csrf_token('delete_projet_'~p.id)|json_encode|raw }},
    csrfPaiement:{{ csrf_token('paiement_form_'~p.id)|json_encode|raw }},
    csrfPhoto:{{ csrf_token('photo_form_'~p.id)|json_encode|raw }},
    csrfFichier:{{ csrf_token('fichier_form_'~p.id)|json_encode|raw }},
    csrfVideo:{{ csrf_token('video_form_'~p.id)|json_encode|raw }},
    urlEdit:{{ path('app_projet_edit',{id:p.id})|json_encode|raw }},
    urlDel:{{ path('app_projet_delete',{id:p.id})|json_encode|raw }},
    urlPaiementCreate:{{ path('app_projet_paiement_create',{id:p.id})|json_encode|raw }},
    urlPhotoCreate:{{ path('app_projet_photo_create',{id:p.id})|json_encode|raw }},
    urlFichierCreate:{{ path('app_projet_fichier_create',{id:p.id})|json_encode|raw }},
    urlVideoCreate:{{ path('app_projet_video_create',{id:p.id})|json_encode|raw }}
  },
  {% endfor %}
{% endif %}
{% endfor %}
};
const ROUTES_PAIEMENT_DEL = '{{ path('app_projet_paiement_delete',{id:0})|replace({'0':'__ID__'}) }}';
const ROUTES_PHOTO_DEL    = '{{ path('app_projet_photo_delete',{id:0})|replace({'0':'__ID__'}) }}';
const ROUTES_FICHIER_DEL  = '{{ path('app_projet_fichier_delete',{id:0})|replace({'0':'__ID__'}) }}';
const ROUTES_VIDEO_DEL    = '{{ path('app_projet_video_delete',{id:0})|replace({'0':'__ID__'}) }}';
const T = {
  info_number:{{ 'proj.info_number'|trans|json_encode|raw }},info_assoc:{{ 'proj.info_assoc'|trans|json_encode|raw }},
  info_type:{{ 'proj.info_type'|trans|json_encode|raw }},info_statut:{{ 'proj.info_statut'|trans|json_encode|raw }},
  info_location:{{ 'proj.info_location'|trans|json_encode|raw }},info_donor:{{ 'proj.info_donor'|trans|json_encode|raw }},
  info_duration:{{ 'proj.info_duration'|trans|json_encode|raw }},info_contract:{{ 'proj.info_contract'|trans|json_encode|raw }},
  info_end_date:{{ 'proj.info_end_date'|trans|json_encode|raw }},info_progression:{{ 'proj.info_progression'|trans|json_encode|raw }},
  info_description:{{ 'proj.info_description'|trans|json_encode|raw }},pai_none:{{ 'proj.pai_none'|trans|json_encode|raw }},
  pai_del:{{ 'proj.pai_delete_confirm'|trans|json_encode|raw }},pho_none:{{ 'proj.pho_none'|trans|json_encode|raw }},
  pho_del:{{ 'proj.pho_delete_confirm'|trans|json_encode|raw }},pho_cover:{{ 'proj.pho_cover'|trans|json_encode|raw }},
  fi_none:{{ 'proj.fi_none'|trans|json_encode|raw }},fi_del:{{ 'proj.fi_delete_confirm'|trans|json_encode|raw }},
  vi_none:{{ 'proj.vi_none'|trans|json_encode|raw }},vi_del:{{ 'proj.vi_delete_confirm'|trans|json_encode|raw }},
  bilan_rate:{{ 'proj.bilan_rate'|trans|json_encode|raw }},delete_msg:{{ 'proj.delete_msg'|trans|json_encode|raw }},
};
const ASSOC_ACTIVE_ID = {{ assocActive ? assocActive.id : 'null' }};
const DEFAULT_ANNEE   = {{ lastAnnee ? lastAnnee : 'null' }};
</script>
{% endblock %}

{% block modals %}
{# ═══ MODALE CRÉER ═══ #}
<div class="mo" id="moCreate">
  <div class="md md-lg">
    <div class="mh">
      <div class="mh-l"><div class="mi g"><i class="bi bi-folder-plus"></i></div><div><div class="mt">{{ 'proj.btn_new'|trans }}</div><div class="ms">{{ 'proj.create_sub'|trans }}</div></div></div>
      <button class="mcls" onclick="closeMo('moCreate')"><i class="bi bi-x-lg"></i></button>
    </div>
    <form method="POST" action="{{ path('app_projet_create') }}">
      <input type="hidden" name="_token" value="{{ csrf_token('projet_create') }}">
      <div class="mb">
        <div class="frow c3">
          <div>
            <label>{{ 'proj.field_assoc'|trans }} <span class="req">*</span></label>
            <select name="association_id" id="createAssoc" class="fc" required>
              <option value="">{{ 'proj.field_assoc_ph'|trans }}</option>
              {% for a in associations %}<option value="{{ a.id }}">{{ a.nom }}</option>{% endfor %}
            </select>
            <div id="createAssocHint" style="display:none;align-items:center;gap:5px;margin-top:5px;font-size:.68rem;color:var(--gm);font-weight:600;background:rgba(46,125,50,.07);border-radius:7px;padding:4px 8px;border:1px solid rgba(46,125,50,.15)">
              <i class="bi bi-check-circle-fill" style="font-size:.72rem;flex-shrink:0"></i>
              <span id="createAssocHintNom">{% if assocActive %}{{ assocActive.nom }}{% endif %}</span>
            </div>
          </div>
          <div>
            <label>{{ 'proj.field_type'|trans }} <span class="req">*</span></label>
            <input type="text" name="type" class="fc" required placeholder="{{ 'proj.field_type_ph'|trans }}" list="typesSugg" autocomplete="off">
            <datalist id="typesSugg">
