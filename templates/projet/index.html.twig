          <div class="vc-sec"><i class="bi bi-info-circle"></i>{{ 'proj.tab_infos'|trans }}</div>
          <div id="visuInfos" style="font-size:.78rem"></div>
        </div>

        {# ── COL MILIEU : Médias (photos, fichiers, vidéos) ── #}
        <div class="visu-col-mid">
          {# Tabs médias #}
          <div class="vmtabs">
            <button class="vmtab active" onclick="vmTab('photos',this)">
              <i class="bi bi-images"></i>{{ 'proj.tab_photos'|trans }}
              <span class="cnt" id="vtcPho">0</span>
            </button>
            <button class="vmtab" onclick="vmTab('fichiers',this)">
              <i class="bi bi-file-earmark-pdf"></i>{{ 'proj.tab_fichiers'|trans }}
              <span class="cnt" id="vtcFi">0</span>
            </button>
            <button class="vmtab" onclick="vmTab('videos',this)">
              <i class="bi bi-play-circle"></i>{{ 'proj.tab_videos'|trans }}
              <span class="cnt" id="vtcVi">0</span>
            </button>
          </div>
          {# Bouton ajouter contextuel #}
          <button class="btn btn-p btn-sm" id="vmAddBtn" style="width:100%" onclick="vmAdd()">
            <i class="bi bi-plus-lg"></i><span id="vmAddLbl">{{ 'proj.pho_add_title'|trans }}</span>
          </button>
          {# Panneaux médias #}
          <div class="vmpanel active" id="vm-photos">
            <div class="pgal3" id="visuPhotos"></div>
          </div>
          <div class="vmpanel" id="vm-fichiers">
            <div id="visuFichiers"></div>
          </div>
          <div class="vmpanel" id="vm-videos">
            <div id="visuVideos"></div>
          </div>
        </div>

        {# ── COL DROITE : Paiements ── #}
