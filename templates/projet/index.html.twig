          <div class="vc-sec"><i class="bi bi-cash-stack"></i>{{ 'proj.tab_paiements'|trans }} <span id="vtcPai" style="background:var(--green-mid);color:#fff;font-size:.55rem;padding:1px 6px;border-radius:8px;font-weight:700;margin-left:2px">0</span></div>
          <button class="btn btn-p btn-sm" style="width:100%;margin-bottom:8px" onclick="ouvrirAddPaiement()">
            <i class="bi bi-plus-lg"></i>{{ 'proj.pai_add_title'|trans }}
          </button>
          <div id="visuPaiements" style="font-size:.78rem"></div>
        </div>

      </div>{# /visu-grid #}

      {# ── PLAQUE DRAPEAUX (inspirée de la photo) ── #}
      <div class="visu-plaque">
        <div class="vp-flags">
          <div class="vp-flag">🇦🇪</div>
          <div class="vp-flag">🇲🇷</div>
        </div>
        <div class="vp-info">
          <div class="vp-num" id="vpNum">—</div>
          <div class="vp-titre" id="vpNom">—</div>
          <div class="vp-lieu" id="vpLieu">—</div>
          <div class="vp-assoc" id="vpAssoc">—</div>
        </div>
        <div class="vp-logos" id="vpLogos">
          {# Logo association injecté en JS #}
        </div>
      </div>

    </div>{# /mb #}
  </div>{# /md #}
</div>{# /mo #}

