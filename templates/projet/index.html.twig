<div class="mo" id="moDel">
  <div class="md md-sm">
    <div class="mh"><div class="mh-l"><div class="mi r"><i class="bi bi-trash3"></i></div><div><div class="mt" style="color:var(--red)">{{ 'proj.delete_title'|trans }}</div><div class="ms">{{ 'proj.delete_subtitle'|trans }}</div></div></div><button class="mcls" onclick="closeMo('moDel')"><i class="bi bi-x-lg"></i></button></div>
    <div class="mb"><div class="del-prev"><div class="di" id="delIcon">🗑️</div><p id="delMsg">{{ 'proj.delete_title'|trans }} ?</p></div></div>
    <div class="mf"><button class="btn btn-s" onclick="closeMo('moDel')">{{ 'proj.btn_cancel'|trans }}</button><form id="delForm" method="POST" style="display:inline"><input type="hidden" name="_token" id="delToken"><button type="submit" class="btn btn-d"><i class="bi bi-trash3"></i>{{ 'proj.btn_delete'|trans }}</button></form></div>
  </div>
</div>

<div class="lb" id="lb" onclick="closeLB()">
  <button class="lb-cls" onclick="closeLB()"><i class="bi bi-x-lg"></i></button>
  <img id="lbImg" src="" alt="">
</div>
{% endblock %}

{% block javascripts %}
<script>
let curView = 'grid', curProjetId = null;

if (typeof openMo === 'undefined') {
  window.openMo  = id => { document.getElementById(id)?.classList.add('open');    document.body.style.overflow='hidden' };
  window.closeMo = id => { document.getElementById(id)?.classList.remove('open'); document.body.style.overflow='' };
  document.querySelectorAll('.mo').forEach(m => m.addEventListener('click', e => { if(e.target===m) closeMo(m.id) }));
}

(function() {
  const _orig = window.openMo;
  window.openMo = function(moId) {
    if (moId === 'moCreate') {
      const sel = document.getElementById('createAssoc');
      if (sel) {
        const fAssocSel = document.getElementById('fAssoc');
        const targetId  = ASSOC_ACTIVE_ID ? String(ASSOC_ACTIVE_ID) : (fAssocSel && fAssocSel.value ? fAssocSel.value : '');
        sel.value = targetId;
        const hint = document.getElementById('createAssocHint'), hintNom = document.getElementById('createAssocHintNom');
        if (sel.value && sel.value === targetId) {
          sel.style.cssText = 'border-color:var(--gm)!important;background:rgba(46,125,50,.04)!important';
          if (hint && hintNom) { const opt = sel.querySelector(`option[value="${targetId}"]`); if (opt) hintNom.textContent = opt.textContent.trim(); hint.style.display = 'flex'; }
          sel.addEventListener('change', function onChg() { sel.style.cssText=''; if(hint) hint.style.display='none'; sel.removeEventListener('change',onChg); });
        } else { sel.style.cssText=''; if(hint) hint.style.display='none'; }
      }
    }
    _orig(moId);
  };
})();

function setView(v) {
  curView = v;
  document.getElementById('bGrid').classList.toggle('active', v==='grid');
  document.getElementById('bList').classList.toggle('active', v==='list');
  filter();
}

function filter() {
  const q   = document.getElementById('q').value.toLowerCase();
  const st  = document.getElementById('fStatut').value;
  const ty  = document.getElementById('fType').value;
  const aid = document.getElementById('fAssoc').value;
  const an  = document.getElementById('fAnnee')?.value || '';
  let vis   = 0;

  document.querySelectorAll('[id^="c"]').forEach(el => {
    if (!/^c\d+$/.test(el.id)) return;
    const show = (!q  || el.dataset.nom.includes(q) || el.dataset.num.includes(q) || el.dataset.lieu.includes(q) || el.dataset.don.includes(q)) &&
                 (!st || el.dataset.statut===st) && (!ty || el.dataset.type===ty) &&
                 (!aid || el.dataset.aid===aid)  && (!an  || el.dataset.annee===an);
    el.style.display = show && curView==='grid' ? '' : 'none';
    if (show) vis++;
  });
  document.querySelectorAll('[id^="r"]').forEach(el => {
    if (!/^r\d+$/.test(el.id)) return;
    const show = (!q  || el.dataset.nom.includes(q) || el.dataset.num.includes(q) || el.dataset.lieu.includes(q) || el.dataset.don.includes(q)) &&
                 (!st || el.dataset.statut===st) && (!ty || el.dataset.type===ty) &&
                 (!aid || el.dataset.aid===aid)  && (!an  || el.dataset.annee===an);
    el.style.display = show && curView==='list' ? 'flex' : 'none';
  });
  document.querySelectorAll('[id^="pgrid"]').forEach(g => { g.style.display = curView==='grid' ? 'grid' : 'none' });
  document.querySelectorAll('[id^="plist"]').forEach(l => { l.style.display = curView==='list' ? 'flex'  : 'none' });
  document.querySelectorAll('.ag').forEach(ag => {
    const aMatch = !aid || ag.dataset.aid===aid;
    const hasVis = aMatch && Array.from(ag.querySelectorAll('[id^="c"],[id^="r"]')).some(e => e.style.display!=='none');
    ag.style.display = hasVis ? '' : 'none';
  });
  document.getElementById('cnt').textContent = vis + ' {{ 'proj.filter_results'|trans }}';
  document.getElementById('eg').classList.toggle('vis', vis===0);
}

function spUpdate(radio, couleur) {
  const grid = radio.closest('.statut-grid'); if (!grid) return;
  grid.querySelectorAll('.sp-pill').forEach(p => { p.classList.remove('active'); p.style.background=''; p.style.borderColor=''; p.style.color=''; });
  const pill = radio.nextElementSibling, c = couleur || pill.dataset.c;
  pill.classList.add('active'); pill.style.background=c+'1A'; pill.style.borderColor=c; pill.style.color=c;
}
function editSlide(v) {
  document.getElementById('editProgLabel').textContent = v + '%';
  const bar = document.getElementById('editProgBar'); if (bar) bar.style.width = v + '%';
}

/* ── Tab médias colonne milieu ── */
let curVmTab = 'photos';
function vmTab(name, btn) {
  curVmTab = name;
  document.querySelectorAll('.vmpanel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.vmtab').forEach(b => b.classList.remove('active'));
  document.getElementById('vm-'+name).classList.add('active');
  btn.classList.add('active');
  // Mettre à jour le bouton ajouter
  const labels = {
    photos:   '{{ 'proj.pho_add_title'|trans }}',
    fichiers: '{{ 'proj.fi_add_title'|trans }}',
    videos:   '{{ 'proj.vi_add_title'|trans }}'
  };
  const lbl = document.getElementById('vmAddLbl');
  if (lbl) lbl.textContent = labels[name] || labels.photos;
}
function vmAdd() {
  if (curVmTab === 'photos')   ouvrirAddPhoto();
  else if (curVmTab === 'fichiers') ouvrirAddFichier();
  else if (curVmTab === 'videos')   ouvrirAddVideo();
}

function ouvrirVisu(id) {
  const p = PROJETS[id]; if (!p) return;
  curProjetId = id;

  // ── Header ──
  document.getElementById('visuTitre').textContent = p.nom;
  document.getElementById('visuSub').textContent   = p.numero + ' · ' + p.assocNom;
  document.getElementById('visuRapportLink').href  = `/projet/${id}`;

  // ── Bilan financier ──
  const fmt = n => Number(n).toLocaleString('fr-FR',{maximumFractionDigits:0}) + ' MRU';
  document.getElementById('vBudget').textContent  = fmt(p.coutTotal);
  document.getElementById('vPaye').textContent    = fmt(p.montantPaye);
  document.getElementById('vRestant').textContent = fmt(p.montantRestant);
  document.getElementById('vTaux').textContent    = p.tauxPaiement.toFixed(1) + '%';
  const bar = document.getElementById('vProgBar'); bar.style.width = '0%';
  setTimeout(() => { bar.style.width = p.tauxPaiement + '%' }, 200);

  // ── Compteurs ──
  document.getElementById('vtcPai').textContent = p.paiements.length;
  document.getElementById('vtcPho').textContent = p.photos.length;
  document.getElementById('vtcFi').textContent  = p.fichiers.length;
  document.getElementById('vtcVi').textContent  = p.videos.length;

  // ── COL GAUCHE : Infos ──
  document.getElementById('visuInfos').innerHTML = `
    <div class="irow"><span class="ilbl">${T.info_number}</span><span class="ival" style="font-family:monospace;font-weight:700">${p.numero}</span></div>
    <div class="irow"><span class="ilbl">${T.info_assoc}</span><span class="ival">${p.assocNom}</span></div>
    <div class="irow"><span class="ilbl">${T.info_type}</span><span class="ival"><i class="bi ${p.typeIcone}" style="color:${p.typeCouleur};margin-right:4px"></i>${p.typeLabel}</span></div>
    <div class="irow"><span class="ilbl">${T.info_statut}</span><span class="ival"><span class="spill" style="background:${p.statutCouleur}18;color:${p.statutCouleur}"><i class="bi ${p.statutIcone}"></i>${p.statutLabel}</span></span></div>
    <div class="irow"><span class="ilbl">${T.info_location}</span><span class="ival">${p.lieu}, ${p.pays}</span></div>
    <div class="irow"><span class="ilbl">${T.info_donor}</span><span class="ival">${p.donateur}</span></div>
    <div class="irow"><span class="ilbl">${T.info_duration}</span><span class="ival">${p.duree||'—'}</span></div>
    <div class="irow"><span class="ilbl">${T.info_contract}</span><span class="ival">${p.dateContrat||'—'}</span></div>
    <div class="irow"><span class="ilbl">${T.info_end_date}</span><span class="ival">${p.dateFin||'—'}</span></div>
    <div class="irow"><span class="ilbl">${T.info_progression}</span><span class="ival">${p.progression}%</span></div>
    ${p.description ? `<div class="irow"><span class="ilbl">${T.info_description}</span><span class="ival" style="line-height:1.6;font-size:.75rem">${p.description}</span></div>` : ''}`;

  // ── COL MILIEU : Photos ──
  const emptyBlock = (ico,msg) => `<div style="text-align:center;padding:24px;color:var(--txt3);font-size:.75rem"><i class="bi bi-${ico}" style="font-size:1.6rem;opacity:.18;display:block;margin-bottom:8px"></i>${msg}</div>`;

  document.getElementById('visuPhotos').innerHTML = p.photos.length === 0
    ? emptyBlock('images', T.pho_none)
    : p.photos.map((ph, i) => `
        <div class="pgal3-item" onclick="openLB('${ph.path}')">
          <img src="${ph.path}" alt="${ph.legende}" loading="lazy">
          ${i===0 ? `<span style="position:absolute;top:4px;left:4px;background:var(--go);color:#fff;font-size:.52rem;font-weight:700;padding:2px 5px;border-radius:5px">${T.pho_cover}</span>` : ''}
          <form method="POST" action="${ROUTES_PHOTO_DEL.replace('__ID__',ph.id)}" style="position:absolute;top:4px;right:4px;display:inline" onclick="event.stopPropagation()">
            <input type="hidden" name="_token" value="${ph.csrfDel}">
            <button type="submit" class="pac rd" style="width:22px;height:22px;border-radius:5px;font-size:.6rem" onclick="return confirm(T.pho_del)"><i class="bi bi-trash3"></i></button>
          </form>
        </div>`).join('');

  // ── COL MILIEU : Fichiers ──
  document.getElementById('visuFichiers').innerHTML = p.fichiers.length === 0
    ? emptyBlock('file-earmark', T.fi_none)
    : p.fichiers.map(fi => `
        <div class="frow2">
          <div class="f-ico" style="background:${fi.catCouleur}18"><i class="bi ${fi.catIcone}" style="color:${fi.catCouleur}"></i></div>
          <div style="flex:1;min-width:0">
            <div class="f-name">${fi.nom}</div>
            <div class="f-sub"><span style="background:${fi.catCouleur}18;color:${fi.catCouleur};padding:1px 6px;border-radius:6px;font-size:.6rem">${fi.cat}</span>${fi.taille?' · '+fi.taille:''}</div>
          </div>
          <a href="${fi.path}" target="_blank" class="pac bl"><i class="bi bi-download"></i></a>
          <form method="POST" action="${ROUTES_FICHIER_DEL.replace('__ID__',fi.id)}" style="display:inline">
            <input type="hidden" name="_token" value="${fi.csrfDel}">
            <button type="submit" class="pac rd" onclick="return confirm(T.fi_del)"><i class="bi bi-trash3"></i></button>
          </form>
        </div>`).join('');

  // ── COL MILIEU : Vidéos ──
  document.getElementById('visuVideos').innerHTML = p.videos.length === 0
    ? emptyBlock('play-circle', T.vi_none)
    : p.videos.map(vi => {
        const ytId = ytExtract(vi.url);
        const thumb = vi.thumb || (ytId ? `https://img.youtube.com/vi/${ytId}/mqdefault.jpg` : '');
        return `<div class="vid-item">
          <div class="vid-thumb"><img src="${thumb}" alt="" loading="lazy">
            <div class="vid-play"><a href="${vi.url}" target="_blank" class="vid-playbtn"><i class="bi bi-play-fill"></i></a></div>
          </div>
          <div class="vid-info">
            <div class="vid-title">${vi.titre||vi.url}</div>
            <form method="POST" action="${ROUTES_VIDEO_DEL.replace('__ID__',vi.id)}" style="display:inline">
              <input type="hidden" name="_token" value="${vi.csrfDel}">
              <button type="submit" class="pac rd" onclick="return confirm(T.vi_del)"><i class="bi bi-trash3"></i></button>
            </form>
          </div>
        </div>`;
      }).join('');

  // ── COL DROITE : Paiements ──
  document.getElementById('visuPaiements').innerHTML = p.paiements.length === 0
    ? emptyBlock('cash', T.pai_none)
    : p.paiements.map(pa => `
        <div class="pair">
          <div class="pai-ico" style="background:${pa.modeCouleur}18"><i class="bi ${pa.modeIcone}" style="color:${pa.modeCouleur}"></i></div>
          <div class="pai-info">
            <div class="pai-mt">${Number(pa.montant).toLocaleString('fr-FR',{maximumFractionDigits:2})} MRU</div>
            <div class="pai-sub">${pa.date} · <span class="pmode" style="background:${pa.modeCouleur}18;color:${pa.modeCouleur}">${pa.modeLabel}</span>${pa.reference?' · '+pa.reference:''}</div>
          </div>
          ${pa.justif ? `<a href="${pa.justif}" target="_blank" class="pac bl"><i class="bi bi-file-earmark-pdf"></i></a>` : ''}
          <form method="POST" action="${ROUTES_PAIEMENT_DEL.replace('__ID__',pa.id)}" style="display:inline">
            <input type="hidden" name="_token" value="${pa.csrfDel}">
            <button type="submit" class="pac rd" onclick="return confirm(T.pai_del)"><i class="bi bi-trash3"></i></button>
          </form>
        </div>`).join('');

  // ── PLAQUE DRAPEAUX ──
  document.getElementById('vpNum').textContent   = p.numero;
  document.getElementById('vpNom').textContent   = p.nom;
  document.getElementById('vpLieu').textContent  = p.lieu + (p.pays && p.pays !== 'Mauritanie' ? ', ' + p.pays : '');
  document.getElementById('vpAssoc').textContent = p.assocNom;

  // Réinitialiser tabs médias sur photos
  vmTab('photos', document.querySelector('.vmtab'));

  openMo('moVisu');
}

function ouvrirAddDirect(id, type) {
  curProjetId = id;
  if (type==='photo') ouvrirAddPhoto(); else if (type==='fichier') ouvrirAddFichier(); else if (type==='video') ouvrirAddVideo();
}
function ouvrirAddPaiement() { const p=PROJETS[curProjetId]; if(!p) return; document.getElementById('paiSub').textContent=p.nom; document.getElementById('paiToken').value=p.csrfPaiement; document.getElementById('paiForm').action=p.urlPaiementCreate; resetFileSmart('justifF','uzJustif','frJustif'); openMo('moAddPai'); }
function ouvrirAddPhoto()    { const p=PROJETS[curProjetId]; if(!p) return; document.getElementById('phoSub').textContent=p.nom; document.getElementById('phoToken').value=p.csrfPhoto; document.getElementById('phoForm').action=p.urlPhotoCreate; phoClear(); openMo('moAddPho'); }
function ouvrirAddFichier()  { const p=PROJETS[curProjetId]; if(!p) return; document.getElementById('fiSub').textContent=p.nom; document.getElementById('fiToken').value=p.csrfFichier; document.getElementById('fiForm').action=p.urlFichierCreate; resetFileSmart('fichierF','uzFichier','frFichier'); openMo('moAddFi'); }
function ouvrirAddVideo()    { const p=PROJETS[curProjetId]; if(!p) return; document.getElementById('viSub').textContent=p.nom; document.getElementById('viToken').value=p.csrfVideo; document.getElementById('viForm').action=p.urlVideoCreate; openMo('moAddVi'); }

function ouvrirEdit(id) {
  const p = PROJETS[id]; if (!p) return; curProjetId = id;
  document.getElementById('editSub').textContent = p.numero;
  document.getElementById('editForm').action     = p.urlEdit;
  document.getElementById('editToken').value     = p.csrfEdit;
  const en = document.getElementById('editNumero'); if(en) en.value=p.numero;
  document.getElementById('editNom').value      = p.nom;
  document.getElementById('editDonateur').value = p.donateur;
  document.getElementById('editBudget').value   = p.coutTotal;
  document.getElementById('editLieu').value     = p.lieu;
  document.getElementById('editDuree').value    = p.duree||'';
  document.getElementById('editDesc').value     = p.description||'';
  const rng = document.getElementById('editProg'); if(rng){rng.value=p.progression;editSlide(p.progression);}
  const sel = (eid,val) => {const s=document.getElementById(eid);if(s)[...s.options].forEach(o=>o.selected=o.value===val)};
  sel('editAssoc', String(p.assocId));
  const et=document.getElementById('editType'); if(et) et.value=p.type;
  const ea=document.getElementById('editAnnee'); if(ea) ea.value=p.annee;
  openMo('moEdit');
}
function ouvrirDelete(id, nom) {
  document.getElementById('delMsg').innerHTML = T.delete_msg ? T.delete_msg.replace('%nom%',nom) : `Supprimer <strong>${nom}</strong> ?`;
  document.getElementById('delForm').action   = PROJETS[id]?.urlDel||'#';
  document.getElementById('delToken').value   = PROJETS[id]?.csrfDel||'';
  openMo('moDel');
}

function filterOrNav(val) {
  const url = new URL(window.location.href);
  if (val) url.searchParams.set('assoc',val); else url.searchParams.delete('assoc');
  window.location.href = url.toString();
}

function fileReadySmart(inputId,uznId,frId) {
  const inp=document.getElementById(inputId),uzn=document.getElementById(uznId),fr=document.getElementById(frId);
  if(!inp||!inp.files.length) return;
  const f=inp.files[0];
  const nameEl=document.getElementById(frId+'Name'),sizeEl=document.getElementById(frId+'Size');
  if(nameEl) nameEl.textContent=f.name; if(sizeEl) sizeEl.textContent=formatSize(f.size);
  uzn.style.display='none'; fr.classList.add('vis');
}
function resetFileSmart(inputId,uznId,frId) {
  const inp=document.getElementById(inputId),uzn=document.getElementById(uznId),fr=document.getElementById(frId);
  if(inp) inp.value=''; uzn.style.display=''; if(fr) fr.classList.remove('vis');
}
function handleDropSmart(e,inputId,uznId,frId) {
  e.preventDefault(); document.getElementById(uznId)?.classList.remove('drag');
  const inp=document.getElementById(inputId);
  if(inp&&e.dataTransfer.files.length){try{inp.files=e.dataTransfer.files}catch(ex){}fileReadySmart(inputId,uznId,frId);}
}
function formatSize(bytes) {
  if(bytes<1024) return bytes+' o'; if(bytes<1024*1024) return (bytes/1024).toFixed(0)+' Ko'; return (bytes/(1024*1024)).toFixed(1)+' Mo';
}
function phoPreview(files) {
  const thumbs=document.getElementById('phoThumbs'),count=document.getElementById('phoCount'),btn=document.getElementById('phoBtnSend'),num=document.getElementById('phoSendCount'),uzn=document.getElementById('phoUzn'),ready=document.getElementById('phoReady');
  if(!files||files.length===0){phoClear();return;}
  thumbs.innerHTML=''; const n=Math.min(files.length,20);
  for(let i=0;i<n;i++){const f=files[i];const div=document.createElement('div');div.style.cssText='position:relative;aspect-ratio:1;border-radius:8px;overflow:hidden;background:var(--sand-dark)';const img=document.createElement('img');img.style.cssText='width:100%;height:100%;object-fit:cover;display:block';const src=URL.createObjectURL(f);img.src=src;img.onload=()=>URL.revokeObjectURL(src);div.appendChild(img);if(i===0){const badge=document.createElement('span');badge.textContent='Couverture';badge.style.cssText='position:absolute;top:3px;left:3px;background:var(--go);color:#fff;font-size:.52rem;font-weight:700;padding:1px 5px;border-radius:5px';div.appendChild(badge);}thumbs.appendChild(div);}
  count.textContent=n+' photo'+(n>1?'s':'')+' sélectionnée'+(n>1?'s':''); num.textContent=n; btn.disabled=false; uzn.style.display='none'; ready.style.display='block';
}
function phoClear() {
  const btn=document.getElementById('phoBtnSend'),uzn=document.getElementById('phoUzn'),ready=document.getElementById('phoReady'),th=document.getElementById('phoThumbs');
  if(th) th.innerHTML=''; if(btn) btn.disabled=true;
  const num=document.getElementById('phoSendCount'); if(num) num.textContent='0';
  if(uzn) uzn.style.display=''; if(ready) ready.style.display='none';
  const inp=document.getElementById('photoF'); if(inp) inp.value='';
}
function phoHandleDrop(e) {
  e.preventDefault(); const uzn=document.getElementById('phoUzn'); if(uzn) uzn.classList.remove('drag');
  const files=e.dataTransfer?.files; if(files&&files.length){try{document.getElementById('photoF').files=files}catch(ex){}phoPreview(files);}
}
function ytExtract(url) {
  if(!url) return null; const m=url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/); return m?m[1]:null;
}
function previewYT(url) {
  const id=ytExtract(url),prev=document.getElementById('ytPrev'),thumb=document.getElementById('ytThumb');
  if(id){thumb.src=`https://img.youtube.com/vi/${id}/mqdefault.jpg`;prev.style.display='block'} else prev.style.display='none';
}
function openLB(src) { document.getElementById('lbImg').src=src; document.getElementById('lb').classList.add('open'); document.body.style.overflow='hidden' }
function closeLB()   { document.getElementById('lb').classList.remove('open'); document.body.style.overflow='' }

document.addEventListener('DOMContentLoaded', () => {
  /* ── Pré-sélectionner la dernière année et appliquer le filtre ── */
  if (DEFAULT_ANNEE) {
    const sel = document.getElementById('fAnnee');
    if (sel) sel.value = String(DEFAULT_ANNEE);
  }
  filter();

  /* ── Animer barres de progression ── */
  document.querySelectorAll('.pc-bar-f, .pr-fin-f').forEach(b => {
    const pw = getComputedStyle(b).getPropertyValue('--pw').trim();
    b.style.width = '0';
    setTimeout(() => { b.style.width = pw }, 300 + Math.random() * 200);
  });
});
</script>
{% endblock %}
