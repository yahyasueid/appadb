{% block javascripts %}
<script>

/**
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║  plaquePdf()  —  Générateur de plaque projet PDF                ║
 * ║  Technique : Canvas HTML5 → image PNG → jsPDF A5 paysage        ║
 * ║  Pourquoi canvas ? jsPDF ne supporte pas l'arabe nativement.    ║
 * ║  Le navigateur, lui, reshape l'arabe correctement via canvas.   ║
 * ╚══════════════════════════════════════════════════════════════════╝
 */
function plaquePdf() {

  var btn = document.getElementById('plaquePdfBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> ...'; }

  var numero     = {{ projet.numero|json_encode|raw }};
  var nom        = {{ projet.nom|json_encode|raw }};
  var donateur   = {{ projet.donateur|json_encode|raw }};
  var lieu       = {{ projet.lieu|json_encode|raw }};
  var pays       = {{ projet.pays|json_encode|raw }};
  var assocNomAr = {{ projet.association.nomAr|default(projet.association.nom)|json_encode|raw }};
  var annee      = {{ projet.annee|json_encode|raw }};
  var assocLogo  = {{ projet.association.hasLogo ? asset(projet.association.logoPath)|json_encode|raw : 'null' }};
  var logo1 = "{{ asset('img/uae_aid.png') }}";
  var logo2 = "{{ asset('img/flag_mr.png') }}";
  var logo3 = "{{ asset('img/sharjah_charity.png')}}";
  var logo4 = "{{ asset('img/logo.png') }}";

  var hijriYear = Math.round(((annee || new Date().getFullYear()) - 622) * (33/32));
  var paysAr = (!pays || pays === 'Mauritanie' || pays === 'Mauritania')
               ? '\u0645\u0648\u0631\u064a\u062a\u0627\u0646\u064a\u0627' : pays;
  var assocAr = '\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0648\u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u062e\u064a\u0631\u064a';

  function loadImg(url) {
    return new Promise(function(resolve) {
      if (!url || url === 'null') { resolve(null); return; }
      fetch(url)
        .then(function(r) { return r.blob(); })
        .then(function(blob) {
          var img = new Image();
          img.onload  = function() { resolve(img); };
          img.onerror = function() { resolve(null); };
          img.src = URL.createObjectURL(blob);
        })
        .catch(function() { resolve(null); });
    });
  }

  function loadScript(src) {
    return new Promise(function(resolve) {
      if (document.querySelector('script[src="'+src+'"]')) { resolve(); return; }
      var s = document.createElement('script');
      s.src = src; s.onload = resolve;
      document.head.appendChild(s);
    });
  }

  Promise.all([
    loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js'),
    loadImg(logo1),     /* [0] UAE AID     */
    loadImg(logo2),     /* [1] Drapeau MR  */
    loadImg(assocLogo), /* [2] Sharjah     */
    loadImg(logo4)      /* [3] logo ADB-MR */
  ]).then(function(res) {

    var imgs = res.slice(1);
    var { jsPDF } = window.jspdf;

    var W = 210, H = 148, D = 200;
    var cv = document.createElement('canvas');
    cv.width  = Math.round(W * D / 25.4);
    cv.height = Math.round(H * D / 25.4);
    var ctx = cv.getContext('2d');
    ctx.scale(D / 25.4, D / 25.4);
    var AR = '"Noto Kufi Arabic","Noto Sans Arabic","Arial Unicode MS",Arial';
    var mg = 5;

    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, W, H);

    ctx.strokeStyle = '#004d00'; ctx.lineWidth = 1.8;
    ctx.strokeRect(mg, mg, W-mg*2, H-mg*2);
    ctx.strokeStyle = '#006600'; ctx.lineWidth = 0.35;
    ctx.strokeRect(mg+2.5, mg+2.5, W-(mg+2.5)*2, H-(mg+2.5)*2);

    function drawImg(img, bx, by, bw, bh) {
      if (!img) return;
      var pad = 2, mW = bw-pad*2, mH = bh-pad*2;
      var r  = Math.min(mW/img.naturalWidth, mH/img.naturalHeight);
      var iW = img.naturalWidth*r, iH = img.naturalHeight*r;
      ctx.drawImage(img, bx+(bw-iW)/2, by+(bh-iH)/2, iW, iH);
    }

    /* ══ LOGOS : 2 gauche + 2 droite ══ */
    var LY  = mg+4;
    var LH  = 22;
    var LW  = 38;
    var GAP = 4;
    var LW4 = 48;
    var LH4 = 27;
    var LY4 = LY - (LH4-LH)/2;

    var lx1 = mg+6;
    var lx2 = lx1+LW+GAP;
    var rx1 = W-mg-6-LW-GAP-LW4;
    var rx2 = rx1+LW+GAP;

    drawImg(imgs[0], lx1, LY,  LW,  LH);
    drawImg(imgs[1], lx2, LY,  LW,  LH);
    drawImg(imgs[2], rx1, LY,  LW,  LH);
    drawImg(imgs[3], rx2, LY4, LW4, LH4);

    ctx.textBaseline = 'top'; ctx.direction = 'ltr'; ctx.textAlign = 'center';
    ctx.fillStyle = '#003300'; ctx.font = 'bold 3.2pt ' + AR;
    var legY = LY+LH+1.5;
    ctx.fillText('', lx1+LW/2, legY);
    ctx.fillText('', lx2+LW/2, legY);
    ctx.fillText('', rx1+LW/2, legY);
    ctx.fillText('', rx2+LW4/2, legY);

    var Y1 = LY+LH+6.5;
    ctx.strokeStyle = '#004d00'; ctx.lineWidth = 0.7;
    ctx.beginPath(); ctx.moveTo(mg+4, Y1); ctx.lineTo(W-mg-4, Y1); ctx.stroke();

    /* Titre rouge */
    ctx.direction = 'rtl'; ctx.textAlign = 'center';
    ctx.fillStyle = '#cc0000'; ctx.textBaseline = 'middle';
    var titleY = Y1+8;
    var title  = nom;
    var maxTW  = W-18;
    var ts = 9;
    ctx.font = 'bold '+ts+'pt '+AR;
    while (ctx.measureText(title).width > maxTW && ts > 5.5) {
      ts -= 0.5;
      ctx.font = 'bold '+ts+'pt '+AR;
    }
    if (ctx.measureText(title).width > maxTW) {
      var wds = nom.split(' '), mid = Math.ceil(wds.length/2);
      ctx.fillText(wds.slice(0,mid).join(' '), W/2, titleY);
      ctx.fillText(wds.slice(mid).join(' '),   W/2, titleY+ts*1.6);
      titleY += ts*0.8;
    } else {
      ctx.fillText(title, W/2, titleY);
    }

    var Y2 = titleY+ts*1.5;
    ctx.strokeStyle = '#aaaaaa'; ctx.lineWidth = 0.28;
    ctx.beginPath(); ctx.moveTo(mg+5, Y2); ctx.lineTo(W-mg-5, Y2); ctx.stroke();

    /* ══════════════════════════════════════════════════════
       LIGNES D'INFO — retour à la ligne + taille auto
       ══════════════════════════════════════════════════════ */
    ctx.textBaseline = 'middle';
    var rH = 10, rG = 2.5;
    var cY = Y2+6;
    var bx = mg+6, bw = W-(mg+6)*2;
    var xR = bx+bw-3;
    var AR_FL = 'bold 6.5pt '+AR;
    var AR_FV = '6.5pt '+AR;

    function divider(y) {
      ctx.strokeStyle = '#dddddd'; ctx.lineWidth = 0.2;
      ctx.beginPath(); ctx.moveTo(bx, y); ctx.lineTo(bx+bw, y); ctx.stroke();
    }

    /*
     * infoLine — label gras à droite + valeur avec retour à la ligne auto
     * Si la valeur dépasse l'espace disponible :
     *   1. Réduit la police par pas de 0.5pt jusqu'à 5pt
     *   2. Si toujours trop long, coupe sur 2 lignes
     * Retourne la hauteur totale consommée (rH ou rH*2)
     */
    function infoLine(label, value, y) {
      /* Largeur du label */
      ctx.font = AR_FL;
      ctx.direction = 'rtl'; ctx.textAlign = 'right';
      var lblW  = ctx.measureText(label).width;
      var maxVW = bw - lblW - 6;  /* espace dispo pour la valeur */

      /* Taille auto pour la valeur */
      var vs = 6.5;
      ctx.font = vs+'pt '+AR;
      while (ctx.measureText(value).width > maxVW && vs > 5) {
        vs -= 0.5;
        ctx.font = vs+'pt '+AR;
      }

      /* Dessiner le label */
      ctx.font = AR_FL; ctx.fillStyle = '#111111';
      ctx.direction = 'rtl'; ctx.textAlign = 'right';
      ctx.fillText(label, xR, y);

      /* Valeur : 1 ou 2 lignes */
      ctx.font = vs+'pt '+AR;
      ctx.fillStyle = '#333333';
      ctx.direction = 'rtl'; ctx.textAlign = 'right';

      if (ctx.measureText(value).width <= maxVW) {
        /* 1 ligne */
        ctx.fillText(value, xR - lblW - 2, y);
        return rH;
      } else {
        /* 2 lignes — couper au milieu des mots */
        var words = value.split(' ');
        var mid   = Math.ceil(words.length / 2);
        var line1 = words.slice(0, mid).join(' ');
        var line2 = words.slice(mid).join(' ');
        var lineH = vs * 1.6;
        ctx.fillText(line1, xR - lblW - 2, y - lineH/2);
        ctx.fillText(line2, xR - lblW - 2, y + lineH/2);
        return rH + lineH;  /* hauteur consommée plus grande */
      }
    }

    /* المتبرع */
    var h = infoLine('\u0627\u0644\u0645\u062a\u0628\u0631\u0639 :', donateur, cY);
    divider(cY + h/2 + 0.5); cY += h + rG;

    /* الدولة */
    h = infoLine('\u0627\u0644\u062f\u0648\u0644\u0629 :', paysAr, cY);
    divider(cY + h/2 + 0.5); cY += h + rG;

    /* تنفيذ */
    h = infoLine('\u062a\u0646\u0641\u064a\u0630 :', assocAr, cY);
    divider(cY + h/2 + 0.5); cY += h + rG;

    /* منطقة التنفيذ */
    h = infoLine('\u0627\u0644\u0645\u0646\u0637\u0642\u0629 :', lieu+' . '+paysAr, cY);
    divider(cY + h/2 + 0.5); cY += h + rG;

    /* تحت اشراف */
    h = infoLine('\u062a\u062d\u062a \u0627\u0634\u0631\u0627\u0641 :',
                 '\u0633\u0641\u0627\u0631\u0629 \u0627\u0644\u0627\u0645\u0627\u0631\u0627\u062a \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0645\u062a\u062d\u062f\u0629', cY);
    cY += h + rG + 2;

    /* Pied — 7pt */
    ctx.font = 'bold 7pt '+AR;
    ctx.fillStyle = '#000000'; ctx.textBaseline = 'middle';
    ctx.direction = 'ltr';
    ctx.textAlign = 'left';  ctx.fillText(hijriYear+' \u0647\u0640', mg+8,   cY);
    ctx.textAlign = 'right'; ctx.fillText(annee+' \u0645',           W-mg-8, cY);

    var doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a5' });
    doc.addImage(cv.toDataURL('image/png'), 'PNG', 0, 0, W, H);
    doc.save('plaque-'+numero+'.pdf');

    if (btn) {
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> {% if app.request.locale == "ar" %}تحميل PDF{% elseif app.request.locale == "en" %}Download PDF{% else %}Télécharger PDF{% endif %}';
    }

  }).catch(function(e) {
    console.error('plaquePdf error:', e);
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> Télécharger PDF'; }
  });
}

// TABS
function showTab(n, btn) {
  document.querySelectorAll('.tpanel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tb2').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + n).classList.add('active');
  btn.classList.add('active');
}

// MODALES — fallback si sigaf.js n'expose pas openMo/closeMo
if (typeof openMo === 'undefined') {
  window.openMo  = id => { document.getElementById(id)?.classList.add('open');    document.body.style.overflow = 'hidden' };
  window.closeMo = id => { document.getElementById(id)?.classList.remove('open'); document.body.style.overflow = '' };
}
// Reset upload à chaque ouverture des modales concernées
const _origOpenMo = window.openMo;
window.openMo = function(id) {
  if (id === 'moAddPai') { resetFile('jfS','uzJfS','frJfS') }
  if (id === 'moAddPho') { phClear() }
  if (id === 'moAddFi')  { resetFile('fiF','uzFiF','frFiF') }
  _origOpenMo(id);
};
document.querySelectorAll('.mo').forEach(m => m.addEventListener('click', e => { if (e.target === m) closeMo(m.id) }));
document.addEventListener('keydown', e => { if (e.key === 'Escape') document.querySelectorAll('.mo.open').forEach(m => closeMo(m.id)) });

// UPLOAD — fonctions smart (input hors du flux)
function fmtSz(b){if(b<1024)return b+' o';if(b<1048576)return (b/1024).toFixed(0)+' Ko';return (b/1048576).toFixed(1)+' Mo'}

function showFileReady(inputId, uznId, frId, nameId, sizeId) {
  const inp = document.getElementById(inputId);
  if (!inp || !inp.files.length) return;
  const f = inp.files[0];
  document.getElementById(nameId).textContent = f.name;
  document.getElementById(sizeId).textContent = fmtSz(f.size);
  document.getElementById(uznId).style.display = 'none';
  document.getElementById(frId).classList.add('vis');
}
function resetFile(inputId, uznId, frId) {
  const inp = document.getElementById(inputId); if (inp) inp.value = '';
  document.getElementById(uznId).style.display = '';
  document.getElementById(frId).classList.remove('vis');
}
function hDropSmart(e, inputId, uznId, frId, nameId, sizeId) {
  e.preventDefault();
  document.getElementById(uznId)?.classList.remove('drag');
  const inp = document.getElementById(inputId);
  if (inp && e.dataTransfer.files.length) {
    try { inp.files = e.dataTransfer.files } catch(ex) {}
    showFileReady(inputId, uznId, frId, nameId, sizeId);
  }
}
// Reset à l'ouverture des modales
function resetModals() {
  resetFile('jfS','uzJfS','frJfS');
  resetFile('fiF','uzFiF','frFiF');
  phClear();
}
// Garder compatibilité — anciennes fonctions
function updateUL(i, l) {
  const el = document.getElementById(i), lbl = document.getElementById(l);
  if (!el || !lbl) return;
  lbl.textContent = el.files.length > 1 ? el.files.length + ' fichiers' : (el.files[0]?.name || lbl.textContent);
}
function hDrop(e, i, l) {
  e.preventDefault(); e.currentTarget.classList.remove('drag');
  const inp = document.getElementById(i);
  if (inp && e.dataTransfer.files.length) { inp.files = e.dataTransfer.files; updateUL(i, l) }
}

// PRÉVISUALISATION PHOTOS (modale show)
function phPreview(files) {
  const thumbs = document.getElementById('phThumbs');
  const count  = document.getElementById('phCount');
  const btn    = document.getElementById('phBtnSend');
  const num    = document.getElementById('phSendCount');
  const uzn    = document.getElementById('phUzn');
  const ready  = document.getElementById('phReady');
  if (!files || files.length === 0) { phClear(); return; }
  thumbs.innerHTML = '';
  const n = Math.min(files.length, 20);
  for (let i = 0; i < n; i++) {
    const f = files[i];
    const div = document.createElement('div');
    div.style.cssText = 'position:relative;aspect-ratio:1;border-radius:7px;overflow:hidden;background:var(--sd)';
    const img = document.createElement('img');
    img.style.cssText = 'width:100%;height:100%;object-fit:cover';
    img.src = URL.createObjectURL(f);
    img.onload = () => URL.revokeObjectURL(img.src);
    div.appendChild(img);
    if (i === 0) {
      const badge = document.createElement('span');
      badge.textContent = '{{ 'proj.pho_cover'|trans|e('js') }}';
      badge.style.cssText = 'position:absolute;top:3px;left:3px;background:var(--go);color:#fff;font-size:.52rem;font-weight:700;padding:1px 5px;border-radius:5px';
      div.appendChild(badge);
    }
    thumbs.appendChild(div);
  }
  count.textContent = n + ' photo' + (n > 1 ? 's' : '') + ' sélectionnée' + (n > 1 ? 's' : '');
  num.textContent   = n;
  btn.disabled      = false;
  // Swap : cacher uzn, afficher état prêt
  uzn.style.display   = 'none';
  ready.style.display = 'block';
}
function phClear() {
  const th    = document.getElementById('phThumbs');  if (th)    th.innerHTML = '';
  const btn   = document.getElementById('phBtnSend'); if (btn)   btn.disabled = true;
  const num   = document.getElementById('phSendCount'); if (num) num.textContent = '0';
  const uzn   = document.getElementById('phUzn');  if (uzn)   uzn.style.display = '';
  const ready = document.getElementById('phReady'); if (ready) ready.style.display = 'none';
  const inp   = document.getElementById('phF');    if (inp)   inp.value = '';
}
function phHandleDrop(e) {
  e.preventDefault();
  document.getElementById('phUzn')?.classList.remove('drag');
  const dt = e.dataTransfer;
  if (dt && dt.files.length) {
    try { document.getElementById('phF').files = dt.files; } catch(ex) {}
    phPreview(dt.files);
  }
}

// YOUTUBE
function esSlide(v) {
  var lbl = document.getElementById('esProgLabel');
  var bar = document.getElementById('esProgBar');
  if (lbl) lbl.textContent = v + '%';
  if (bar) bar.style.width = v + '%';
}

function previewYT(url) {
  const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/);
  const prev = document.getElementById('ytPrev'), thumb = document.getElementById('ytThumb');
  if (m) { thumb.src = `https://img.youtube.com/vi/${m[1]}/mqdefault.jpg`; prev.style.display = 'block' }
  else prev.style.display = 'none';
}

// LIGHTBOX
function openLB(src) { document.getElementById('lbImg').src = src; document.getElementById('lb').classList.add('open'); document.body.style.overflow = 'hidden' }
function closeLB()   { document.getElementById('lb').classList.remove('open'); document.body.style.overflow = '' }

// STATUT PILLS — mise à jour visuelle
function spUpdate(radio, couleur) {
  document.querySelectorAll('.sp-pill').forEach(p => {
    p.classList.remove('active');
    p.style.background = '';
    p.style.borderColor = '';
    p.style.color = '';
  });
  const pill = radio.nextElementSibling;
  const c = couleur || pill.dataset.c;
  pill.classList.add('active');
  pill.style.background = c + '1A';
  pill.style.borderColor = c;
  pill.style.color = c;
}

// PROGRESSION SLIDER
function spSlide(v) {
  document.getElementById('spLabel').textContent = v + '%';
  const bar = document.getElementById('spBar');
  if (bar) bar.style.width = v + '%';
}

// INIT — animer barres
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.hs-prog-f, .bprog-f').forEach(b => {
    const w = b.style.width; b.style.width = '0';
    setTimeout(() => { b.style.width = w }, 300 + Math.random() * 150);
  });
});
