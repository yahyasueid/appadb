{# templates/projet/show.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}{{ projet.numero }} — {{ projet.nom }}{% endblock %}

{% block stylesheets %}
<style>
/* ═══ VARIABLES ═══ */
:root{
  --gd:#14532D;--gk:#166534;--gm:#2E7D32;--gl:#4CAF50;--gp:#A5D6A7;
  --gg:rgba(46,125,50,.07);--gb:rgba(46,125,50,.15);
  --bl:#0288D1;--bl2:rgba(2,136,209,.08);
  --go:#D4A017;--go2:rgba(212,160,23,.1);
  --sa:#FBF7F0;--sd:#F0E8D8;
  --txt:#1B2A1B;--txt2:#4A6B4A;--txt3:#7A8F7A;
  --wh:#FFFFFF;--rd:#D32F2F;--rd2:rgba(211,47,47,.08);
  --pu:#7B1FA2;--pu2:rgba(123,31,162,.1);
  --radius:14px;--rsm:10px;--rxs:7px;
  --sh:0 2px 12px rgba(20,83,45,.07);
  --shm:0 8px 32px rgba(20,83,45,.14);
}

/* ═══ PAGE HEADER ═══ */
.page-header{
  background:linear-gradient(135deg,var(--gd) 0%,var(--gk) 45%,#1B5E20 100%);
  padding:30px 36px 0;position:relative;overflow:hidden;
}
.page-header::before{
  content:'';position:absolute;top:-80px;right:-80px;
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,255,255,.06) 0%,transparent 70%);
  pointer-events:none;
}
.page-header::after{
  content:'';position:absolute;bottom:-50px;left:20%;
  width:200px;height:200px;border-radius:50%;
  background:rgba(255,255,255,.03);pointer-events:none;
}
/* Grille décorative subtile */
.page-header .ph-grid{
  position:absolute;inset:0;pointer-events:none;opacity:.04;
  background-image:linear-gradient(rgba(255,255,255,.5) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.5) 1px,transparent 1px);
  background-size:32px 32px;
}
.header-inner{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;position:relative;z-index:1;flex-wrap:wrap}
.header-left{flex:1;min-width:0}

.header-breadcrumb{
  display:flex;align-items:center;gap:5px;
  font-size:.68rem;color:rgba(255,255,255,.4);
  margin-bottom:10px;flex-wrap:wrap;
}
.header-breadcrumb a{color:rgba(255,255,255,.45);text-decoration:none;transition:.15s}
.header-breadcrumb a:hover{color:rgba(255,255,255,.9)}
.header-breadcrumb .sep{color:rgba(255,255,255,.18)}

.hero-meta{display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:10px}
.hbadge{
  padding:4px 12px;border-radius:20px;font-size:.68rem;font-weight:700;
  display:inline-flex;align-items:center;gap:5px;letter-spacing:.01em;
}
.hbadge-num{
  background:rgba(255,255,255,.18);color:#fff;
  border:1px solid rgba(255,255,255,.28);
  font-family:'Courier New',monospace;font-size:.75rem;letter-spacing:.06em;
  padding:4px 13px;
}
.hero-title{
  font-size:1.45rem;font-weight:900;color:#fff;line-height:1.15;margin-bottom:6px;
  letter-spacing:-.03em;
}
.hero-sub{
  font-size:.78rem;color:rgba(255,255,255,.6);
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
}
.hero-sub .dot{color:rgba(255,255,255,.2)}
.hero-actions{display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0;padding-top:6px}

.btn-h{
  padding:9px 18px;border-radius:var(--rxs);font-size:.76rem;font-weight:700;
  border:1px solid rgba(255,255,255,.2);color:#fff;cursor:pointer;
  background:rgba(255,255,255,.1);backdrop-filter:blur(10px);
  display:inline-flex;align-items:center;gap:6px;
  text-decoration:none;transition:.2s;font-family:inherit;letter-spacing:.01em;
}
.btn-h:hover{background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.35);color:#fff;transform:translateY(-1px)}
.btn-h.primary{background:rgba(255,255,255,.95);color:var(--gd);border-color:transparent;box-shadow:0 4px 16px rgba(0,0,0,.2)}
.btn-h.primary:hover{background:#fff;transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.25)}

/* ── Stats strip redesignées ── */
.hstats{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:0;margin-top:24px;
  position:relative;z-index:1;
  border-top:1px solid rgba(255,255,255,.1);
}
.hs{
  padding:18px 20px 16px;position:relative;
  border-right:1px solid rgba(255,255,255,.08);
  transition:.2s;
}
.hs:last-child{border-right:none}
.hs:hover{background:rgba(255,255,255,.05)}
.hs-lbl{
  font-size:.6rem;color:rgba(255,255,255,.45);
  text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px;
  display:flex;align-items:center;gap:5px;
}
.hs-lbl i{font-size:.65rem}
.hs-val{
  font-size:1.25rem;font-weight:900;color:#fff;
  letter-spacing:-.03em;line-height:1;
}
.hs-val .hs-unit{font-size:.65rem;font-weight:600;color:rgba(255,255,255,.5);margin-left:3px;letter-spacing:0}
.hs-sub{font-size:.64rem;color:rgba(255,255,255,.4);margin-top:4px}
.hs-prog{height:3px;background:rgba(255,255,255,.15);border-radius:10px;overflow:hidden;margin-top:10px}
.hs-prog-f{height:100%;border-radius:10px;background:linear-gradient(90deg,#A5D6A7,#E8F5E9);transition:width 1.2s cubic-bezier(.16,1,.3,1)}
.hs-accent{
  position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);
  opacity:0;transition:.2s;
}
.hs:hover .hs-accent{opacity:1}

/* ═══ FLASH ═══ */
.flash-wrap{padding:14px 36px 0}
.flash-msg{
  display:flex;align-items:center;gap:10px;padding:11px 16px;
  border-radius:var(--rxs);font-size:.82rem;font-weight:500;margin-bottom:7px;
}
.flash-msg.success{background:rgba(46,125,50,.1);color:var(--gd);border:1px solid rgba(46,125,50,.2)}
.flash-msg.error{background:var(--rd2);color:var(--rd);border:1px solid rgba(211,47,47,.15)}

/* ═══ LAYOUT ═══ */
.show-wrap{padding:22px 36px 80px}
.show-grid{display:grid;grid-template-columns:1fr 300px;gap:20px;align-items:start}

/* ═══ PANELS ═══ */
.panel{
  background:var(--wh);border-radius:var(--radius);
  border:1.5px solid rgba(46,125,50,.1);
  box-shadow:0 1px 3px rgba(0,0,0,.05),0 4px 16px rgba(20,83,45,.06);
  overflow:hidden;margin-bottom:14px;
}
.panel:hover{box-shadow:0 2px 8px rgba(0,0,0,.06),0 8px 28px rgba(20,83,45,.1)}
.panel-header{
  padding:13px 18px;border-bottom:1px solid var(--sd);
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  background:linear-gradient(to bottom,var(--sa),var(--wh));
}
.panel-header-left{display:flex;align-items:center;gap:10px}
.panel-icon{
  width:32px;height:32px;border-radius:8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:.85rem;
}
.panel-title{font-size:.85rem;font-weight:700;color:var(--txt)}
.panel-sub{font-size:.66rem;color:var(--txt3);margin-top:1px}
.panel-body{padding:14px 18px}

/* ═══ TABS ═══ */
.tabsbar{
  display:flex;gap:3px;background:var(--wh);border-radius:var(--radius);
  padding:4px;box-shadow:var(--sh);
  border:1.5px solid rgba(46,125,50,.1);margin-bottom:16px;
  overflow-x:auto;
}
.tb2{
  flex:1;padding:9px 10px;border-radius:var(--rxs);border:none;background:none;
  font-size:.72rem;font-weight:700;color:var(--txt3);cursor:pointer;transition:.18s;
  display:flex;align-items:center;justify-content:center;gap:5px;
  white-space:nowrap;font-family:inherit;letter-spacing:.01em;
}
.tb2:hover{background:var(--sd);color:var(--txt2)}
.tb2.active{background:var(--gm);color:#fff;box-shadow:0 2px 10px rgba(46,125,50,.3)}
.tb2 .cnt{
  font-size:.58rem;font-weight:800;padding:1px 6px;border-radius:9px;
  background:rgba(255,255,255,.25);min-width:18px;text-align:center;
}
.tb2:not(.active) .cnt{background:var(--sd);color:var(--txt3)}
.tpanel{display:none}
.tpanel.active{display:block;animation:fup .22s ease}
@keyframes fup{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

/* ═══ PAIEMENTS ═══ */
.pai-row{
  display:flex;align-items:center;gap:12px;padding:10px 0;
  border-bottom:1px solid var(--sd);transition:.15s;
}
.pai-row:last-child{border-bottom:none}
.pai-row:hover{background:var(--sa);margin:0 -18px;padding-left:18px;padding-right:18px;border-radius:var(--rxs)}
.pai-ico{
  width:36px;height:36px;border-radius:10px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:.88rem;
}
.pai-amount{
  font-size:.95rem;font-weight:800;color:var(--gd);
  letter-spacing:-.02em;
  display:flex;align-items:baseline;gap:4px;
}
.pai-amount .pai-mru{font-size:.65rem;font-weight:600;color:var(--txt3);letter-spacing:0}
.pai-meta{font-size:.65rem;color:var(--txt3);margin-top:3px;display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.pai-mode{font-size:.59rem;font-weight:700;padding:2px 7px;border-radius:8px;letter-spacing:.02em}

/* ═══ PHOTOS ═══ */
.photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.photo-item{
  aspect-ratio:1;border-radius:9px;overflow:hidden;position:relative;
  cursor:zoom-in;background:var(--sd);
  border:2px solid transparent;transition:.2s;
}
.photo-item:hover{border-color:var(--gm);transform:scale(1.02);z-index:2;box-shadow:0 8px 24px rgba(20,83,45,.2)}
.photo-item img{width:100%;height:100%;object-fit:cover;transition:transform .3s}
.photo-item:hover img{transform:scale(1.05)}
.photo-ov{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(20,83,45,.8),transparent);
  opacity:0;transition:.2s;display:flex;align-items:flex-end;padding:7px;
}
.photo-item:hover .photo-ov{opacity:1}
.photo-ov span{font-size:.61rem;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cover-badge{
  position:absolute;top:5px;left:5px;background:var(--go);color:#fff;
  font-size:.56rem;font-weight:800;padding:2px 7px;border-radius:7px;
  text-transform:uppercase;letter-spacing:.04em;
}
.photo-del{
  position:absolute;top:5px;right:5px;width:24px;height:24px;
  background:rgba(211,47,47,.85);color:#fff;border:none;border-radius:6px;
  cursor:pointer;font-size:.62rem;opacity:0;transition:.15s;
  display:flex;align-items:center;justify-content:center;
}
.photo-item:hover .photo-del{opacity:1}

/* ═══ FICHIERS ═══ */
.fi-row{
  display:flex;align-items:center;gap:10px;padding:9px 12px;
  border-radius:var(--rxs);background:var(--sa);margin-bottom:6px;transition:.15s;
  border:1px solid transparent;
}
.fi-row:hover{background:var(--sd);border-color:var(--gb)}
.fi-ico{width:34px;height:34px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.88rem}
.fi-name{font-size:.77rem;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fi-sub{font-size:.62rem;color:var(--txt3);margin-top:2px;display:flex;align-items:center;gap:5px;flex-wrap:wrap}

/* ═══ VIDÉOS ═══ */
.vid-card{background:var(--sa);border-radius:var(--rsm);overflow:hidden;margin-bottom:9px;border:1px solid var(--sd);transition:.15s}
.vid-card:hover{border-color:var(--gb);box-shadow:var(--sh)}
.vid-thumb{position:relative;aspect-ratio:16/9;overflow:hidden}
.vid-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.vid-card:hover .vid-thumb img{transform:scale(1.03)}
.vid-play-ov{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.25)}
.vid-play-btn{
  width:44px;height:44px;border-radius:50%;
  background:rgba(255,255,255,.93);
  display:flex;align-items:center;justify-content:center;
  font-size:.95rem;color:var(--rd);padding-left:2px;text-decoration:none;transition:.2s;
  box-shadow:0 4px 16px rgba(0,0,0,.3);
}
.vid-play-btn:hover{transform:scale(1.12);background:#fff}
.vid-info{padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px}
.vid-title{font-size:.75rem;font-weight:600;color:var(--txt)}
.vid-date{font-size:.61rem;color:var(--txt3);margin-top:2px}

/* ═══ BILAN SIDEBAR ═══ */
.bilan{
  background:linear-gradient(145deg,var(--gd) 0%,#1A5C32 50%,var(--gm) 100%);
  border-radius:var(--radius);padding:0;color:#fff;margin-bottom:14px;
  overflow:hidden;box-shadow:0 8px 28px rgba(20,83,45,.25);
  border:1px solid rgba(255,255,255,.08);
}
.bilan-head{
  padding:16px 18px 14px;
  border-bottom:1px solid rgba(255,255,255,.1);
  display:flex;align-items:center;gap:8px;
}
.bilan-head-ico{
  width:32px;height:32px;border-radius:8px;
  background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;
  font-size:.85rem;
}
.bilan-head-t{font-size:.72rem;font-weight:700;color:rgba(255,255,255,.9);letter-spacing:.02em}
.bilan-head-s{font-size:.6rem;color:rgba(255,255,255,.45)}
.bilan-body{padding:14px 18px}
.brow{display:flex;justify-content:space-between;align-items:center;padding:5px 0}
.blbl{font-size:.72rem;color:rgba(255,255,255,.65)}
.bval{
  font-size:.88rem;font-weight:800;letter-spacing:-.02em;
  display:flex;align-items:baseline;gap:3px;
}
.bval .bmru{font-size:.58rem;font-weight:600;color:rgba(255,255,255,.45);letter-spacing:0}
.bsep{height:1px;background:rgba(255,255,255,.12);margin:6px 0}
.brow-total{
  background:rgba(255,255,255,.07);border-radius:8px;
  padding:8px 10px;margin:8px 0;display:flex;justify-content:space-between;align-items:center;
} 
.bprog{margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.1)}
.bprog-l{display:flex;justify-content:space-between;font-size:.63rem;color:rgba(255,255,255,.5);margin-bottom:5px}
.bprog-bg{height:6px;background:rgba(255,255,255,.15);border-radius:10px;overflow:hidden}
.bprog-f{height:100%;background:linear-gradient(90deg,#A5D6A7,#E8F5E9);border-radius:10px;transition:width 1.2s cubic-bezier(.16,1,.3,1)}

/* ═══ INFO ROWS ═══ */
.irow{display:flex;gap:8px;padding:7px 0;border-bottom:1px solid var(--sd)}
.irow:last-child{border-bottom:none}
.ilbl{font-size:.64rem;color:var(--txt3);min-width:90px;flex-shrink:0;padding-top:2px;font-weight:500}
.ival{font-size:.74rem;font-weight:600;color:var(--txt);min-width:0;line-height:1.4}

/* ═══ BOUTONS ═══ */
.btn{
  padding:8px 16px;border-radius:var(--rxs);border:none;
  font-size:.78rem;font-weight:700;cursor:pointer;transition:.2s;
  display:inline-flex;align-items:center;gap:6px;font-family:inherit;
  text-decoration:none;letter-spacing:.01em;
}
.btn-primary{background:linear-gradient(135deg,var(--gk),var(--gm));color:#fff;box-shadow:0 3px 12px rgba(46,125,50,.22)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(46,125,50,.32)}
.btn-secondary{background:var(--sa);color:var(--txt2);border:1.5px solid var(--sd)}
.btn-secondary:hover{border-color:var(--gm);color:var(--gm)}
.btn-danger{background:var(--rd2);color:var(--rd);border:1px solid rgba(211,47,47,.15)}
.btn-danger:hover{background:var(--rd);color:#fff}
.btn-sm{padding:5px 12px;font-size:.7rem}

.btn-add{
  display:flex;align-items:center;justify-content:center;gap:7px;
  padding:9px;border-radius:var(--rxs);
  background:var(--gg);border:1.5px dashed var(--gb);
  color:var(--gm);font-size:.73rem;font-weight:700;
  cursor:pointer;transition:.18s;width:100%;font-family:inherit;margin-top:10px;
}
.btn-add:hover{background:rgba(46,125,50,.12);border-color:var(--gm)}

.icon-btn{
  width:28px;height:28px;border-radius:7px;
  border:1px solid var(--gb);background:none;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:.72rem;color:var(--txt3);transition:.15s;text-decoration:none;flex-shrink:0;
}
.icon-btn:hover{background:var(--sa);color:var(--gm)}
.icon-btn.danger:hover{background:var(--rd2);color:var(--rd);border-color:rgba(211,47,47,.2)}

.empty-state{text-align:center;padding:36px 18px;color:var(--txt3)}
.empty-state i{font-size:2.2rem;opacity:.18;display:block;margin-bottom:10px}
.empty-state p{font-size:.76rem}

.spill{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 9px;border-radius:10px;font-size:.67rem;font-weight:700;
}

/* ═══ MODALES ═══ */
.mo{
  position:fixed;inset:0;background:rgba(20,83,45,.35);
  backdrop-filter:blur(6px);z-index:1050;
  display:none;align-items:center;justify-content:center;padding:16px;
}
.mo.open{display:flex;animation:moIn .2s ease}
@keyframes moIn{from{opacity:0}to{opacity:1}}
.md{
  background:var(--wh);border-radius:18px;width:100%;
  box-shadow:0 24px 80px rgba(20,83,45,.2);
  animation:mdIn .28s cubic-bezier(.16,1,.3,1);
  max-height:85vh;display:flex;flex-direction:column;overflow:hidden;
}
@keyframes mdIn{from{opacity:0;transform:translateY(18px) scale(.97)}to{opacity:1;transform:none}}
.md-sm{max-width:420px}.md-md{max-width:620px}.md-lg{max-width:800px}

.mh{
  padding:20px 24px 16px;border-bottom:1px solid var(--sd);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.mh-l{display:flex;align-items:center;gap:10px}
.mi{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0}
.mi.g{background:rgba(46,125,50,.1);color:var(--gm)}
.mi.b{background:rgba(2,136,209,.1);color:var(--bl)}
.mi.r{background:rgba(211,47,47,.1);color:var(--rd)}
.mi.o{background:rgba(212,160,23,.1);color:var(--go)}
.mi.p{background:rgba(123,31,162,.1);color:var(--pu)}
.mt{font-size:.95rem;font-weight:700;color:var(--txt);letter-spacing:-.02em}
.ms{font-size:.71rem;color:var(--txt3);margin-top:1px}
.mc-btn{
  width:34px;height:34px;border-radius:8px;border:none;
  background:var(--sa);color:var(--txt3);
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.95rem;transition:.15s;
}
.mc-btn:hover{background:var(--rd2);color:var(--rd)}

.mb{padding:22px 24px;overflow-y:auto;flex:1;min-height:0}
.mf{
  padding:14px 24px;border-top:1px solid var(--sd);
  display:flex;align-items:center;justify-content:flex-end;
  gap:9px;flex-shrink:0;background:var(--sa);position:sticky;bottom:0;z-index:2;
}

.fs{margin-bottom:18px}
.fg{display:grid;gap:12px}
.fg.c2{grid-template-columns:1fr 1fr}
.fgrp{display:flex;flex-direction:column;gap:5px}
.fgrp label{font-size:.73rem;font-weight:600;color:var(--txt2)}
.fgrp label .req{color:var(--rd);font-size:.67rem}
.fc{
  background:var(--sa);border:1.5px solid transparent;
  border-radius:var(--rxs);padding:10px 12px;
  font-size:.83rem;font-family:inherit;color:var(--txt);
  outline:none;transition:.22s;width:100%;
}
.fc:focus{background:var(--wh);border-color:var(--gm);box-shadow:0 0 0 3px rgba(46,125,50,.07)}
.fc::placeholder{color:var(--txt3);font-weight:300}
select.fc{appearance:none;cursor:pointer}
textarea.fc{resize:vertical;min-height:72px}

.uzn{
  border:2px dashed var(--gb);border-radius:var(--rsm);
  padding:22px;text-align:center;cursor:pointer;transition:.2s;background:var(--sa);
}
.uzn:hover,.uzn.drag{border-color:var(--gm);background:var(--gg)}
.uzn i{font-size:1.4rem;color:var(--gp);display:block;margin-bottom:6px}
.uz-t{font-size:.75rem;font-weight:600;color:var(--txt2)}
.uz-s{font-size:.63rem;color:var(--txt3);margin-top:3px}
/* NOTE : plus d'input dans .uzn — ils sont sortis dans le DOM */

/* État fichier prêt (remplace la uzn après sélection) */
.file-ready{
  display:none;align-items:center;gap:12px;
  background:linear-gradient(135deg,rgba(46,125,50,.06),rgba(46,125,50,.03));
  border:1.5px solid rgba(46,125,50,.25);border-radius:var(--rsm);
  padding:14px 16px;
}
.file-ready.vis{display:flex}
.fr-ico{width:42px;height:42px;border-radius:10px;flex-shrink:0;
  background:rgba(46,125,50,.12);display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;color:var(--gm);}
.fr-info{flex:1;min-width:0}
.fr-name{font-size:.82rem;font-weight:700;color:var(--txt);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fr-sub{font-size:.68rem;color:var(--txt3);margin-top:2px;display:flex;align-items:center;gap:6px}
.fr-ok{font-size:.65rem;font-weight:700;color:var(--gm);background:rgba(46,125,50,.1);
  padding:1px 7px;border-radius:8px;display:flex;align-items:center;gap:3px}
.fr-chg{flex-shrink:0;border:none;background:var(--sd);color:var(--txt2);
  border-radius:7px;padding:5px 10px;font-size:.7rem;font-weight:600;
  cursor:pointer;transition:.15s;font-family:inherit;display:flex;align-items:center;gap:4px;}
.fr-chg:hover{background:var(--gb);color:var(--txt)}

/* ── Design améliorations ── */
/* Header — grid décorative plus visible */
.page-header::before{
  content:'';position:absolute;top:-80px;right:-80px;
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,255,255,.08) 0%,transparent 70%);
  pointer-events:none;
}
/* Panels — ombre plus sophistiquée */
.panel{
  box-shadow:0 1px 3px rgba(0,0,0,.04),0 4px 20px rgba(20,83,45,.07);
  transition:box-shadow .22s,transform .22s;
}
.panel:hover{
  box-shadow:0 2px 8px rgba(0,0,0,.06),0 10px 32px rgba(20,83,45,.12);
  transform:translateY(-1px);
}
/* Stats strip hstats — fond légèrement contrasté au hover */
.hs:hover{background:rgba(255,255,255,.07)}
/* Tabs — style pill amélioré */
.tabsbar{background:linear-gradient(to bottom,#fff,#fafdf9);box-shadow:0 1px 3px rgba(0,0,0,.05),0 4px 16px rgba(20,83,45,.07)}
.tb2.active{box-shadow:0 3px 14px rgba(46,125,50,.35)}
/* Bilan sidebar — dégradé plus profond */
.bilan{box-shadow:0 8px 32px rgba(20,83,45,.28),0 2px 8px rgba(0,0,0,.12)}
/* pai-row — hover plus propre */
.pai-row:hover{background:linear-gradient(90deg,var(--sa),transparent);border-radius:var(--rxs)}
/* Photo item — ombre subtile */
.photo-item{box-shadow:0 1px 4px rgba(0,0,0,.08)}
/* fi-row — bordure left colorée au hover */
.fi-row:hover{border-left:2.5px solid var(--gm);padding-left:10px}
/* btn-h primary — reflet */
.btn-h.primary{box-shadow:0 4px 18px rgba(0,0,0,.2),inset 0 1px 0 rgba(255,255,255,.2)}

/* Lightbox */
.lb{
  position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.92);
  display:none;align-items:center;justify-content:center;cursor:zoom-out;
}
.lb.open{display:flex;animation:moIn .18s ease}
.lb img{max-width:90vw;max-height:85vh;border-radius:var(--rsm);object-fit:contain;box-shadow:0 16px 60px rgba(0,0,0,.5)}
.lb-cls{
  position:fixed;top:16px;right:16px;width:38px;height:38px;border-radius:50%;
  background:rgba(255,255,255,.1);border:none;color:#fff;
  font-size:.95rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:.15s;
}
.lb-cls:hover{background:var(--rd)}

/* ═══ STATUT PILLS ═══ */
.statut-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:6px;
}
.sp-lbl{position:relative;cursor:pointer}
.sp-pill{
  display:flex;align-items:center;gap:6px;
  padding:8px 10px;border-radius:9px;
  font-size:.71rem;font-weight:700;
  border:1.5px solid var(--sd);background:var(--sa);color:var(--txt3);
  transition:.18s;white-space:nowrap;overflow:hidden;
  user-select:none;
}
.sp-pill:hover{border-color:var(--gb);color:var(--txt2);background:var(--sd)}
.sp-pill.active{font-weight:800}
.sp-pill i{font-size:.8rem;flex-shrink:0}
.sp-text{overflow:hidden;text-overflow:ellipsis}


/* ═══ MODALE EDIT SHOW — layout 2 colonnes ═══ */
.edit-layout {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
  align-items:start;
}
.edit-fields { display:flex;flex-direction:column;gap:0 }
.edit-section {
  padding-bottom:14px;margin-bottom:14px;
  border-bottom:1px solid var(--sd);
}
.edit-section:last-child { border-bottom:none;margin-bottom:0;padding-bottom:0 }
.edit-sec-title {
  display:flex;align-items:center;gap:6px;
  font-size:.65rem;font-weight:800;color:var(--txt3);
  text-transform:uppercase;letter-spacing:.09em;
  margin-bottom:10px;
}
.edit-sec-title i { font-size:.8rem;color:var(--gm) }
.edit-row2 {
  display:grid;grid-template-columns:1fr 1fr;gap:10px;
}
/* Col droite description */
.edit-desc-col {
  display:flex;flex-direction:column;gap:10px;
  position:sticky;top:0;
}
.edit-desc-ta {
  flex:1;min-height:180px;resize:none;
  line-height:1.65;font-size:.84rem;
}
.edit-desc-hint {
  display:flex;align-items:flex-start;gap:6px;
  font-size:.68rem;color:var(--txt3);line-height:1.5;
  background:rgba(212,160,23,.06);border-radius:7px;
  padding:8px 10px;border:1px solid rgba(212,160,23,.15);
}
.edit-prog-block {
  background:var(--gg);border:1px solid var(--gb);
  border-radius:10px;padding:14px 16px;
}
@media(max-width:768px){
  .edit-layout { grid-template-columns:1fr }
  .edit-desc-col { position:static }
  .edit-desc-ta { min-height:100px }
}


/* ═══ PLAQUE PROJET ═══════════════════════════════════════════════ */
.plaque-wrap { margin-bottom:16px }

.plaque-panel-hd {
  display:flex;align-items:center;justify-content:space-between;
  padding:13px 18px;border-bottom:1px solid var(--sd);
  background:linear-gradient(to bottom,var(--sa),var(--wh));
}
.plaque-panel-hd-left { display:flex;align-items:center;gap:10px }
.plaque-panel-ico {
  width:32px;height:32px;border-radius:8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:.85rem;
  background:rgba(212,160,23,.1);color:var(--go);
}
.plaque-panel-title { font-size:.85rem;font-weight:700;color:var(--txt) }

/* La plaque physique */
.plaque {
  margin:14px;
  background:#ffffff;
  border:3px solid #c0b090;border-radius:10px;
  padding:18px 22px 16px;position:relative;
  font-family:var(--font-ar-display,'Noto Kufi Arabic',sans-serif);
  box-shadow:0 2px 0 #a09060,0 4px 0 #c0b090,0 8px 28px rgba(0,0,0,.14);
}

/* 4 logos en haut */
.plaque-top-logos {
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:8px;margin-bottom:12px;padding-bottom:10px;
  border-bottom:2px solid #c8b880;
}
.plaque-top-logo {
  background:#fff;border-radius:6px;padding:8px;
  display:flex;align-items:center;justify-content:center;
  min-height:60px;
  border:1px solid #e0d0b0;
}
.plaque-top-logo img {
  max-width:100%;max-height:44px;object-fit:contain;display:block;
}
.plaque-top-logo-empty {
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;color:rgba(160,140,100,.5);font-size:.62rem;
  width:100%;min-height:44px;
  border:1.5px dashed rgba(180,155,100,.35);border-radius:5px;
}
.plaque-top-logo-empty i { font-size:1.1rem }

/* Corps infos — taille identique au PDF */
.plaque-body { direction:rtl;text-align:center;padding:4px 0 }
.plaque-line {
  display:flex;align-items:baseline;justify-content:center;
  gap:8px;flex-wrap:wrap;margin-bottom:4px;
}
.plaque-line.lg { margin-bottom:7px }
.plaque-key {
  font-size:1.05rem;font-weight:800;color:#0a0500;white-space:nowrap;
}
.plaque-val { font-size:1.05rem;font-weight:600;color:#0a0500 }
.plaque-line.lg .plaque-key,
.plaque-line.lg .plaque-val { font-size:1.18rem;font-weight:800 }
.plaque-hr {
  width:60%;margin:8px auto;border:none;
  border-top:1.5px solid #c8b880;
}

/* Pied — collé en bas, pas d'espace vide */
.plaque-foot {
  display:flex;justify-content:space-around;align-items:center;
  flex-wrap:wrap;gap:10px;
  margin-top:10px;padding-top:8px;
  border-top:2px solid #c8b880;direction:rtl;
}
.plaque-foot-item {
  display:flex;align-items:center;gap:6px;
  font-size:.9rem;font-weight:700;color:#0a0500;
}
.plaque-foot-item strong { font-weight:900 }

/* Bouton PDF */
.plaque-pdf-btn {
  display:inline-flex;align-items:center;gap:7px;
  padding:7px 16px;border-radius:8px;
  border:1.5px solid var(--gb);background:var(--wh);color:var(--gm);
  font-size:.75rem;font-weight:700;cursor:pointer;
  font-family:inherit;transition:.18s;text-decoration:none;
}
.plaque-pdf-btn:hover { background:var(--gg);border-color:var(--gm) }
.plaque-pdf-btn:disabled { opacity:.6;cursor:default }

@media(max-width:768px){
  .plaque { margin:12px;padding:16px 14px }
  .plaque-foot { gap:14px }
  .plaque-key,.plaque-val { font-size:.8rem }
}
@media(max-width:480px){
  .plaque { margin:10px;padding:14px 12px }
  .plaque-top-logos { gap:6px }
  .plaque-top-logo { min-height:48px;padding:5px }
}
/* ═══ PRINT ═══ */
@media print{
  .hero-actions,.tabsbar,.btn-add,.icon-btn,.photo-del,.mo,.page-header .ph-grid{display:none!important}
  .panel{box-shadow:none;border:1px solid #ddd}
  .photo-grid{grid-template-columns:repeat(4,1fr)}
  .show-grid{grid-template-columns:1fr}
  .sidebar-col{display:none}
}

/* ═══ RESPONSIVE ═══ */
@media(max-width:1100px){
  .show-grid{grid-template-columns:1fr}
  .sidebar-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start}
}
@media(max-width:768px){
  .page-header,.flash-wrap,.show-wrap{padding-left:16px;padding-right:16px}
  .hstats{grid-template-columns:1fr 1fr}
  .header-inner{flex-direction:column;align-items:flex-start}
  .hero-actions{width:100%}
  .fg.c2{grid-template-columns:1fr}
  .photo-grid{grid-template-columns:repeat(2,1fr)}
  .sidebar-col{grid-template-columns:1fr}
  .md-lg{max-width:100%}
  .page-header{padding-bottom:0}
}
</style>
{% endblock %}

{% block body %}

{# ── Flash ── #}
{# {% for label, messages in app.flashes %}
  {% for msg in messages %}
  <div class="flash-wrap">
    <div class="flash-msg {{ label }}">
      <i class="bi bi-{{ label == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>{{ msg }}
    </div>
  </div>
  {% endfor %}
{% endfor %} #}

{# ═══════════════════════════════════════════════════
   PAGE HEADER
═══════════════════════════════════════════════════ #}
<div class="page-header">
  <div class="ph-grid"></div>
  <div class="header-inner">
    <div class="header-left">
      <div class="header-breadcrumb">
        <a href="{{ path('app_dashboard') }}">ADB-MR</a>
        <span class="sep">/</span>
        <a href="{{ path('app_projets') }}">{{ 'proj.breadcrumb'|trans }}</a>
        <span class="sep">/</span>
        <span style="color:rgba(255,255,255,.7)">{{ projet.numero }}</span>
      </div>
      <div class="hero-meta">
        <span class="hbadge hbadge-num">
          <i class="bi bi-upc-scan"></i>{{ projet.numero }}
        </span>
        <span class="hbadge" style="background:rgba(255,255,255,.12);color:rgba(255,255,255,.9);border:1px solid rgba(255,255,255,.18)">
          <i class="bi {{ projet.typeIcone }}"></i>{{ projet.typeLabel }}
        </span>
        <span class="hbadge" style="background:{{ projet.statutCouleur }}35;color:#fff;border:1px solid {{ projet.statutCouleur }}50">
          <i class="bi {{ projet.statutIcone }}"></i>{% if app.request.locale == 'ar' %}{{ projet.statutLabelAr }}{% else %}{{ projet.statutLabel }}{% endif %}
        </span>
      </div>
      <div class="hero-title">{{ projet.nom }}</div>
      <div class="hero-sub">
        <span><i class="bi bi-building"></i> {{ projet.association.nom }}</span>
        <span class="dot">·</span>
        <span><i class="bi bi-geo-alt"></i> {{ projet.lieu }}</span>
        <span class="dot">·</span>
        <span><i class="bi bi-calendar3"></i> {{ projet.annee }}</span>
      </div>
    </div>
    <div class="hero-actions">
      <button class="btn-h primary" onclick="openMo('moEditShow')">
        <i class="bi bi-pencil"></i>{{ 'proj.action_edit'|trans }}
      </button>
      <a href="{{ path('app_projets') }}" class="btn-h">
        <i class="bi bi-arrow-left"></i>{{ 'common.back'|trans }}
      </a>
      <button class="btn-h" onclick="window.print()">
        <i class="bi bi-printer"></i>{{ 'common.print'|trans }}
      </button>
    </div>
  </div>

  {# Stats #}
  {% set taux = projet.coutTotal > 0 ? projet.tauxPaiement : 0 %}
  <div class="hstats">
    <div class="hs">
      <div class="hs-accent"></div>
      <div class="hs-lbl"><i class="bi bi-wallet2"></i>{{ 'proj.bilan_budget'|trans }}</div>
      <div class="hs-val">{{ projet.coutTotal|number_format(0, ' ', ',') }}<span class="hs-unit">MRU</span></div>
      <div class="hs-sub">Budget total alloué</div>
    </div>
    <div class="hs">
      <div class="hs-accent"></div>
      <div class="hs-lbl"><i class="bi bi-check-circle"></i>{{ 'proj.bilan_paid'|trans }}</div>
      <div class="hs-val" style="color:#A5D6A7">{{ projet.montantTotalPaye|number_format(0, ' ', ',') }}<span class="hs-unit" style="color:rgba(165,214,167,.6)">MRU</span></div>
      <div class="hs-sub">{{ taux|round(1) }}% du budget</div>
    </div>
    <div class="hs">
      <div class="hs-accent"></div>
      <div class="hs-lbl"><i class="bi bi-hourglass-split"></i>{{ 'proj.bilan_remaining'|trans }}</div>
      <div class="hs-val" style="color:#FFCDD2">{{ projet.montantRestant|number_format(0, ' ', ',') }}<span class="hs-unit" style="color:rgba(255,205,210,.5)">MRU</span></div>
      <div class="hs-sub">Reste à financer</div>
    </div>
    <div class="hs">
      <div class="hs-accent"></div>
      <div class="hs-lbl"><i class="bi bi-bar-chart-line"></i>{{ 'proj.progression_label'|trans }}</div>
      <div class="hs-val">{{ projet.progression }}<span class="hs-unit">%</span></div>
      <div class="hs-prog"><div class="hs-prog-f" style="width:{{ projet.progression }}%"></div></div>
    </div>
  </div>
</div>

{# ═══════════════════════════════════════════════════
   CONTENU
═══════════════════════════════════════════════════ #}
<div class="show-wrap">
<div class="show-grid">

{# ─── COLONNE PRINCIPALE ─── #}
<div>
  {# Tabs #}
  <div class="tabsbar">
    <button class="tb2 active" onclick="showTab('paiements',this)">
      <i class="bi bi-cash-stack"></i>{{ 'proj.tab_paiements'|trans }}<span class="cnt">{{ projet.paiements|length }}</span>
    </button>
    <button class="tb2" onclick="showTab('photos',this)">
      <i class="bi bi-images"></i>{{ 'proj.tab_photos'|trans }}<span class="cnt">{{ projet.photos|length }}</span>
    </button>
    <button class="tb2" onclick="showTab('fichiers',this)">
      <i class="bi bi-file-earmark-pdf"></i>{{ 'proj.tab_fichiers'|trans }}<span class="cnt">{{ projet.fichiers|length }}</span>
    </button>
    <button class="tb2" onclick="showTab('videos',this)">
      <i class="bi bi-play-circle"></i>{{ 'proj.tab_videos'|trans }}<span class="cnt">{{ projet.videos|length }}</span>
    </button>
  </div>

  {# ══ PAIEMENTS ══ #}
  <div class="tpanel active" id="tab-paiements">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <div class="panel-icon" style="background:var(--blue-light);color:var(--blue)"><i class="bi bi-cash-stack"></i></div>
          <div>
            <div class="panel-title">{{ 'proj.tab_paiements'|trans }}</div>
            <div class="panel-sub">{{ projet.paiements|length }} {{ 'proj.pai_count'|trans }}</div>
          </div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openMo('moAddPai')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.pai_add_title'|trans }}
        </button>
      </div>
      <div class="panel-body">
        {% if projet.paiements is empty %}
        <div class="empty-state"><i class="bi bi-cash"></i><p>{{ 'proj.pai_none'|trans }}</p></div>
        {% else %}
        {% for pai in projet.paiements %}
        <div class="pai-row">
          <div class="pai-ico" style="background:{{ pai.modeCouleur }}18">
            <i class="bi {{ pai.modeIcone }}" style="color:{{ pai.modeCouleur }}"></i>
          </div>
          <div style="flex:1;min-width:0">
            <div class="pai-amount">{{ pai.montant|number_format(0, ' ', ',') }}<span class="pai-mru">MRU</span></div>
            <div class="pai-meta">
              <i class="bi bi-calendar3"></i>{{ pai.datePaiement|date('d/m/Y') }}
              <span class="pai-mode" style="background:{{ pai.modeCouleur }}18;color:{{ pai.modeCouleur }}">
                {{ pai.getModeLabel(app.request.locale) }}
              </span>
              {% if pai.reference %}<span>· {{ pai.reference }}</span>{% endif %}
              {% if pai.notes %}<span>· {{ pai.notes }}</span>{% endif %}
            </div>
          </div>
          <div style="display:flex;gap:4px">
            {% if pai.hasJustificatif %}
            <a href="{{ asset(pai.justificatifPath) }}" target="_blank" class="icon-btn" title="{{ 'proj.fi_download'|trans }}">
              <i class="bi bi-file-earmark-pdf"></i>
            </a>
            {% endif %}
            <form method="POST" action="{{ path('app_projet_paiement_delete', {id: pai.id}) }}" style="display:inline">
              <input type="hidden" name="_token" value="{{ csrf_token('delete_paiement_'~pai.id) }}">
              <input type="hidden" name="_from" value="show">
              <button type="submit" class="icon-btn danger"
                      onclick="return confirm('{{ 'proj.pai_delete_confirm'|trans|e('js') }}')">
                <i class="bi bi-trash3"></i>
              </button>
            </form>
          </div>
        </div>
        {% endfor %}
        {% endif %}
        <button class="btn-add" onclick="openMo('moAddPai')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.pai_add_title'|trans }}
        </button>
      </div>
    </div>
  </div>

  {# ══ PHOTOS ══ #}
  <div class="tpanel" id="tab-photos">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <div class="panel-icon" style="background:rgba(123,31,162,.1);color:#7B1FA2"><i class="bi bi-images"></i></div>
          <div>
            <div class="panel-title">{{ 'proj.tab_photos'|trans }}</div>
            <div class="panel-sub">{{ projet.photos|length }}/20 · {{ 'proj.pho_cover_hint'|trans }}</div>
          </div>
        </div>
        {% if projet.canAddPhoto %}
        <button class="btn btn-primary btn-sm" onclick="openMo('moAddPho')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.pho_add_title'|trans }}
        </button>
        {% endif %}
      </div>
      <div class="panel-body">
        {% if projet.photos is empty %}
        <div class="empty-state"><i class="bi bi-images"></i><p>{{ 'proj.pho_none'|trans }}</p></div>
        {% else %}
        <div class="photo-grid">
          {% for ph in projet.photos %}
          <div class="photo-item" onclick="openLB('{{ asset(ph.path) }}')">
            <img src="{{ asset(ph.path) }}" alt="{{ ph.legende ?? ph.originalName }}" loading="lazy">
            {% if loop.first %}<span class="cover-badge">{{ 'proj.pho_cover'|trans }}</span>{% endif %}
            <div class="photo-ov"><span>{{ ph.legende ?? ph.originalName }}</span></div>
            <form method="POST" action="{{ path('app_projet_photo_delete', {id: ph.id}) }}" style="display:inline">
              <input type="hidden" name="_token" value="{{ csrf_token('delete_photo_'~ph.id) }}">
              <input type="hidden" name="_from" value="show">
              <button type="submit" class="photo-del"
                      onclick="event.stopPropagation();return confirm('{{ 'proj.pho_delete_confirm'|trans|e('js') }}')">
                <i class="bi bi-trash3"></i>
              </button>
            </form>
          </div>
          {% endfor %}
        </div>
        {% endif %}
        {% if projet.canAddPhoto %}
        <button class="btn-add" onclick="openMo('moAddPho')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.pho_add_title'|trans }}
        </button>
        {% endif %}
      </div>
    </div>
  </div>

  {# ══ FICHIERS ══ #}
  <div class="tpanel" id="tab-fichiers">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <div class="panel-icon" style="background:rgba(212,160,23,.1);color:var(--gold)"><i class="bi bi-file-earmark-pdf"></i></div>
          <div>
            <div class="panel-title">{{ 'proj.tab_fichiers'|trans }}</div>
            <div class="panel-sub">{{ 'proj.fi_count_hint'|trans({'%r%': projet.countRapports(), '%t%': projet.countTransferts()}) }}</div>
          </div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openMo('moAddFi')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.fi_add_title'|trans }}
        </button>
      </div>
      <div class="panel-body">
        {% if projet.fichiers is empty %}
        <div class="empty-state"><i class="bi bi-file-earmark"></i><p>{{ 'proj.fi_none'|trans }}</p></div>
        {% else %}
        {% for fi in projet.fichiers %}
        <div class="fi-row">
          <div class="fi-ico" style="background:{{ fi.categorieCouleur }}18">
            <i class="bi {{ fi.categorieIcone }}" style="color:{{ fi.categorieCouleur }}"></i>
          </div>
          <div style="flex:1;min-width:0">
            <div class="fi-name">{{ fi.originalName }}</div>
            <div class="fi-sub">
              <span style="background:{{ fi.categorieCouleur }}18;color:{{ fi.categorieCouleur }};padding:1px 6px;border-radius:6px;font-size:.6rem;font-weight:600">
                {% if app.request.locale == 'ar' %}{{ fi.categorieLabelAr }}{% else %}{{ fi.categorieLabel }}{% endif %}
              </span>
              {% if fi.taille %} · {{ fi.tailleFormatee }}{% endif %}
              · {{ fi.uploadedAt|date('d/m/Y') }}
            </div>
          </div>
          <a href="{{ asset(fi.path) }}" target="_blank" class="icon-btn" title="{{ 'proj.fi_download'|trans }}">
            <i class="bi bi-download"></i>
          </a>
          <form method="POST" action="{{ path('app_projet_fichier_delete', {id: fi.id}) }}" style="display:inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_fichier_'~fi.id) }}">
            <input type="hidden" name="_from" value="show">
            <button type="submit" class="icon-btn danger"
                    onclick="return confirm('{{ 'proj.fi_delete_confirm'|trans|e('js') }}')">
              <i class="bi bi-trash3"></i>
            </button>
          </form>
        </div>
        {% endfor %}
        {% endif %}
        <button class="btn-add" onclick="openMo('moAddFi')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.fi_add_title'|trans }}
        </button>
      </div>
    </div>
  </div>

  {# ══ VIDÉOS ══ #}
  <div class="tpanel" id="tab-videos">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <div class="panel-icon" style="background:var(--red-light);color:var(--red)"><i class="bi bi-play-circle"></i></div>
          <div>
            <div class="panel-title">{{ 'proj.tab_videos'|trans }}</div>
            <div class="panel-sub">{{ projet.videos|length }} {{ 'proj.vi_count'|trans }}</div>
          </div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openMo('moAddVi')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.vi_add_title'|trans }}
        </button>
      </div>
      <div class="panel-body">
        {% if projet.videos is empty %}
        <div class="empty-state"><i class="bi bi-play-circle"></i><p>{{ 'proj.vi_none'|trans }}</p></div>
        {% else %}
        {% for vi in projet.videos %}
        <div class="vid-card">
          <div class="vid-thumb">
            <img src="{{ vi.thumbnailUrl ?? 'https://img.youtube.com/vi/default/mqdefault.jpg' }}"
                 alt="{{ vi.titre }}" loading="lazy">
            <div class="vid-play-ov">
              <a href="{{ vi.url }}" target="_blank" class="vid-play-btn"><i class="bi bi-play-fill"></i></a>
            </div>
          </div>
          <div class="vid-info">
            <div>
              <div class="vid-title">{{ vi.titre ?? vi.url }}</div>
              <div class="vid-date">{{ vi.addedAt|date('d/m/Y') }}</div>
            </div>
            <form method="POST" action="{{ path('app_projet_video_delete', {id: vi.id}) }}" style="display:inline">
              <input type="hidden" name="_token" value="{{ csrf_token('delete_video_'~vi.id) }}">
              <input type="hidden" name="_from" value="show">
              <button type="submit" class="icon-btn danger"
                      onclick="return confirm('{{ 'proj.vi_delete_confirm'|trans|e('js') }}')">
                <i class="bi bi-trash3"></i>
              </button>
            </form>
          </div>
        </div>
        {% endfor %}
        {% endif %}
        <button class="btn-add" onclick="openMo('moAddVi')">
          <i class="bi bi-plus-lg"></i>{{ 'proj.vi_add_title'|trans }}
        </button>
      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════════════════
     PLAQUE PROJET
  ══════════════════════════════════════════════════════ #}
  <div class="panel plaque-wrap">
    <div class="plaque-panel-hd">
      <div class="plaque-panel-hd-left">
        <div class="plaque-panel-ico"><i class="bi bi-award"></i></div>
        <div class="plaque-panel-title">
          {% if app.request.locale == 'ar' %}لوحة المشروع
          {% elseif app.request.locale == 'en' %}Project Plaque
          {% else %}Plaque du projet{% endif %}
        </div>
      </div>
      <button class="plaque-pdf-btn" id="plaquePdfBtn" onclick="plaquePdf()">
        <i class="bi bi-file-earmark-pdf"></i>
        {% if app.request.locale == 'ar' %}تحميل PDF
        {% elseif app.request.locale == 'en' %}Download PDF
        {% else %}Télécharger PDF{% endif %}
      </button>
    </div>

    <div class="plaque" id="plaqueEl">

      {# ── 4 logos en haut ── #}
      <div class="plaque-top-logos">
        {# Logo 1 : UAE AID #}
        <div class="plaque-top-logo">
          <img src="{{ asset('img/use_aid.png') }}" alt="UAE AID"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="plaque-top-logo-empty" style="display:none">
            <i class="bi bi-image"></i><span>UAE AID</span>
          </div>
        </div>
        {# Logo 2 : Drapeau Mauritanie #}
        <div class="plaque-top-logo">
          <img src="{{ asset('img/flag_mr.png') }}" alt="Mauritanie"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="plaque-top-logo-empty" style="display:none">
            <i class="bi bi-image"></i><span>MR</span>
          </div>
        </div>
        {# Logo 3 : Association #}
        <div class="plaque-top-logo">
          {% if projet.association.hasLogo %}
            <img src="{{ asset(projet.association.logoPath) }}"
                 alt="{{ projet.association.nom }}"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="plaque-top-logo-empty" style="display:none">
              <i class="bi bi-building"></i>
              <span>{{ projet.association.sigle ?? projet.association.nom|slice(0,8) }}</span>
            </div>
          {% else %}
            <div class="plaque-top-logo-empty">
              <i class="bi bi-building"></i>
              <span>{{ projet.association.sigle ?? projet.association.nom|slice(0,8) }}</span>
            </div>
          {% endif %}
        </div>
        {# Logo 4 : Sharjah Charity #}
        <div class="plaque-top-logo">
          <img src="{{ asset('img/sharjah_charity.png') }}" alt="Sharjah Charity"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="plaque-top-logo-empty" style="display:none">
            <i class="bi bi-image"></i><span>SCI</span>
          </div>
        </div>
      </div>

      {# ── Corps ── #}
      <div class="plaque-body">
        <div class="plaque-line lg">
          <span class="plaque-key">رقم المشروع :</span>
          <span class="plaque-val" style="direction:ltr;font-family:monospace">{{ projet.numero }}</span>
        </div>
        <div class="plaque-line lg">
          <span class="plaque-key">اسم المتبرع :</span>
          <span class="plaque-val">{{ projet.donateur }}</span>
        </div>
        <div class="plaque-line lg">
          <span class="plaque-key">اسم المشروع :</span>
          <span class="plaque-val">{{ projet.nom }}</span>
        </div>
        <hr class="plaque-hr">
        <div class="plaque-line">
          <span class="plaque-key">المنطقة :</span>
          <span class="plaque-val">{{ projet.lieu }}{% if projet.pays and projet.pays != 'Mauritanie' %} — {{ projet.pays }}{% endif %}</span>
        </div>
        {% if projet.dateContrat %}
        <div class="plaque-line">
          <span class="plaque-key">تاريخ العقد :</span>
          <span class="plaque-val" style="direction:ltr;font-family:monospace">{{ projet.dateContrat|date('Y / m / d') }}</span>
        </div>
        {% endif %}
      </div>

      {# ── Pied ── #}
      <div class="plaque-foot">
        <div class="plaque-foot-item">
          اشراف : <strong>{{ projet.association.nom }}</strong>
        </div>
        <div class="plaque-foot-item">
          تنفيذ : <strong>{{ projet.association.nom }}</strong>
        </div>
      </div>
    </div>{# /plaque #}
  </div>{# /panel plaque-wrap #}

</div>{# /colonne principale #}

{# ─── SIDEBAR ─── #}
<div class="sidebar-col">

  {# Bilan financier #}
  <div class="bilan">
    <div class="bilan-head">
      <div class="bilan-head-ico"><i class="bi bi-graph-up-arrow"></i></div>
      <div>
        <div class="bilan-head-t">{{ 'proj.bilan_title'|trans }}</div>
        <div class="bilan-head-s">{{ projet.paiements|length }} paiement(s) enregistré(s)</div>
      </div>
    </div>
    <div class="bilan-body">
      <div class="brow">
        <span class="blbl"><i class="bi bi-wallet2" style="opacity:.6;margin-right:4px"></i>{{ 'proj.bilan_budget'|trans }}</span>
        <span class="bval">{{ projet.coutTotal|number_format(0, ' ', ',') }}<span class="bmru">MRU</span></span>
      </div>
      <div class="brow">
        <span class="blbl"><i class="bi bi-check2-circle" style="opacity:.6;margin-right:4px"></i>{{ 'proj.bilan_paid'|trans }}</span>
        <span class="bval" style="color:#A5D6A7">{{ projet.montantTotalPaye|number_format(0, ' ', ',') }}<span class="bmru" style="color:rgba(165,214,167,.5)">MRU</span></span>
      </div>
      <div class="bsep"></div>
      <div class="brow-total">
        <span class="blbl" style="color:rgba(255,255,255,.85);font-weight:700">{{ 'proj.bilan_remaining'|trans }}</span>
        <span class="bval" style="color:#FFCDD2;font-size:.95rem">{{ projet.montantRestant|number_format(0, ' ', ',') }}<span class="bmru" style="color:rgba(255,205,210,.45)">MRU</span></span>
      </div>
      <div class="bprog">
        <div class="bprog-l">
          <span>{{ 'proj.bilan_rate'|trans }}</span>
          <span style="color:rgba(255,255,255,.8);font-weight:700">{{ taux|round(1) }}%</span>
        </div>
        <div class="bprog-bg"><div class="bprog-f" style="width:{{ taux }}%"></div></div>
      </div>
    </div>
  </div>

  {# Informations #}
  <div class="panel">
    <div class="panel-header">
      <div class="panel-header-left">
        <div class="panel-icon" style="background:var(--green-ghost);color:var(--green-mid)"><i class="bi bi-info-circle"></i></div>
        <div class="panel-title">{{ 'proj.tab_infos'|trans }}</div>
      </div>
    </div>
    <div class="panel-body" style="padding:10px 16px">
      <div class="irow"><span class="ilbl">{{ 'proj.info_assoc'|trans }}</span><span class="ival">{{ projet.association.nom }}</span></div>
      <div class="irow"><span class="ilbl">{{ 'proj.info_donor'|trans }}</span><span class="ival">{{ projet.donateur }}</span></div>
      <div class="irow"><span class="ilbl">{{ 'proj.info_location'|trans }}</span><span class="ival">{{ projet.lieu }}, {{ projet.pays }}</span></div>
      <div class="irow"><span class="ilbl">{{ 'proj.info_duration'|trans }}</span><span class="ival">{{ projet.duree }}</span></div>
      <div class="irow"><span class="ilbl">{{ 'proj.info_contract'|trans }}</span><span class="ival">{{ projet.dateContrat|date('d/m/Y') }}</span></div>
      {% if projet.dateFin %}
      <div class="irow"><span class="ilbl">{{ 'proj.info_end_date'|trans }}</span><span class="ival">{{ projet.dateFin|date('d/m/Y') }}</span></div>
      {% endif %}
      <div class="irow"><span class="ilbl">{{ 'proj.show_created_by'|trans }}</span><span class="ival">{{ projet.creePar.fullName ?? '—' }}</span></div>
      {% if projet.validePar %}
      <div class="irow"><span class="ilbl">{{ 'proj.show_validated_by'|trans }}</span><span class="ival">{{ projet.validePar.fullName }}</span></div>
      {% endif %}
      <div class="irow"><span class="ilbl">{{ 'proj.show_updated_at'|trans }}</span><span class="ival">{{ projet.updatedAt|date('d/m/Y H:i') }}</span></div>
    </div>
  </div>

  {# Description #}
  {% if projet.description %}
  <div class="panel">
    <div class="panel-header">
      <div class="panel-header-left">
        <div class="panel-icon" style="background:var(--green-ghost);color:var(--green-mid)"><i class="bi bi-text-paragraph"></i></div>
        <div class="panel-title">{{ 'proj.field_description'|trans }}</div>
      </div>
    </div>
    <div class="panel-body">
      <p style="font-size:.78rem;color:var(--text-mid);line-height:1.7">{{ projet.description }}</p>
    </div>
  </div>
  {% endif %}

  {# Statut & progression #}
  <div class="panel">
    <div class="panel-header">
      <div class="panel-header-left">
        <div class="panel-icon" style="background:rgba(212,160,23,.1);color:var(--gold)"><i class="bi bi-arrow-repeat"></i></div>
        <div class="panel-title">{{ 'proj.show_statut_card'|trans }}</div>
      </div>
    </div>
    <div class="panel-body">
      <form method="POST" action="{{ path('app_projet_statut', {id: projet.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('proj_statut_'~projet.id) }}">
        <input type="hidden" name="_from" value="show">
        {# ── Statut — boutons radio visuels ── #}
        <div class="fgrp" style="margin-bottom:16px">
          <label style="font-size:.67rem;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;display:block">
            {{ 'proj.statut_label'|trans }}
          </label>
          <div class="statut-grid">
            {% for k,v in constant('App\\Entity\\Projet::STATUTS') %}
            {% set active = (projet.statut == k) %}
            <label class="sp-lbl" title="{{ v.label_fr }}">
              <input type="radio" name="statut" value="{{ k }}"
                     {{ active ? 'checked' : '' }}
                     style="position:absolute;opacity:0;width:0;height:0"
                     onchange="spUpdate(this,'{{ v.couleur }}')">
              <span class="sp-pill {{ active ? 'active' : '' }}"
                    data-c="{{ v.couleur }}"
                    style="{% if active %}background:{{ v.couleur }}1A;border-color:{{ v.couleur }};color:{{ v.couleur }}{% endif %}">
                <i class="bi {{ v.icone }}"></i>
                <span class="sp-text">{% if app.request.locale == 'ar' %}{{ v.label_ar }}{% else %}{{ v.label_fr }}{% endif %}</span>
              </span>
            </label>
            {% endfor %}
          </div>
        </div>

        {# ── Progression — slider amélioré ── #}
        <div class="fgrp" style="margin-bottom:16px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
            <label style="font-size:.67rem;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.07em;margin:0">
              {{ 'proj.progression_label'|trans }}
            </label>
            <span id="spLabel" style="font-size:1.1rem;font-weight:900;color:var(--gm);letter-spacing:-.03em">{{ projet.progression }}%</span>
          </div>
          {# Barre de progression visuelle #}
          <div style="position:relative;height:6px;background:var(--sd);border-radius:10px;margin-bottom:10px;overflow:hidden">
            <div id="spBar" style="position:absolute;left:0;top:0;height:100%;
              background:linear-gradient(90deg,var(--gm),var(--gl));border-radius:10px;
              transition:width .2s;width:{{ projet.progression }}%"></div>
          </div>
          <input type="range" name="progression" id="spRange" min="0" max="100"
                 value="{{ projet.progression }}"
                 style="width:100%;accent-color:var(--gm);height:4px"
                 oninput="spSlide(this.value)">
          {# Ticks 0 / 50 / 100 #}
          <div style="display:flex;justify-content:space-between;font-size:.59rem;color:var(--txt3);margin-top:4px">
            <span>0%</span><span>50%</span><span>100%</span>
          </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center">
          <i class="bi bi-check-lg"></i>{{ 'proj.btn_save'|trans }}
        </button>
      </form>
    </div>
  </div>

</div>{# /sidebar-col #}
</div>{# /show-grid #}
</div>{# /show-wrap #}

{# ─── LIGHTBOX ─── #}
<div class="lb" id="lb" onclick="closeLB()">
  <button class="lb-cls" onclick="closeLB()"><i class="bi bi-x-lg"></i></button>
  <img id="lbImg" src="" alt="">
</div>

{% endblock %}

{% block modals %}

{# ═══════════════════════════════════════════════════
   MODALE — MODIFIER PROJET
═══════════════════════════════════════════════════ #}
<div class="mo" id="moEditShow">
  <div class="md md-xl">

    {# ── Header ── #}
    <div class="mh">
      <div class="mh-l">
        <div class="mi g"><i class="bi bi-pencil-square"></i></div>
        <div>
          <div class="mt">{{ 'proj.edit_title'|trans }}</div>
          <div class="ms">
            <span style="font-family:monospace;letter-spacing:.04em;color:var(--gm);font-weight:700">{{ projet.numero }}</span>
            <span style="margin:0 5px;opacity:.4">·</span>
            {{ projet.nom|slice(0,40) }}{% if projet.nom|length > 40 %}…{% endif %}
          </div>
        </div>
      </div>
      <button class="mc-btn" onclick="closeMo('moEditShow')"><i class="bi bi-x-lg"></i></button>
    </div>

    <form method="POST" action="{{ path('app_projet_edit', {id: projet.id}) }}">
      <input type="hidden" name="_token" value="{{ csrf_token('projet_edit_'~projet.id) }}">
      <input type="hidden" name="_from" value="show">

      <div class="mb">

        {# ── Layout 2 colonnes : formulaire | description ── #}
        <div class="edit-layout">

          {# COL GAUCHE — Champs #}
          <div class="edit-fields">

            {# Section : Identité #}
            <div class="edit-section">
              <div class="edit-sec-title"><i class="bi bi-info-circle"></i>{{ 'proj.tab_infos'|trans }}</div>
              <div class="fgrp">
                <label>{{ 'proj.field_nom'|trans }} <span class="req">*</span></label>
                <input type="text" name="nom" class="fc" value="{{ projet.nom }}" required>
              </div>
              <div class="edit-row2">
                <div class="fgrp">
                  <label>{{ 'proj.field_type'|trans }}</label>
                  <select name="type" class="fc">
                    {% for k,v in constant('App\\Entity\\Projet::TYPES') %}
                    <option value="{{ k }}" {{ projet.type == k ? 'selected' : '' }}>
                      {% if app.request.locale == 'ar' %}{{ v.label_ar ?? v.label_fr }}{% else %}{{ v.label_fr }}{% endif %}
                    </option>
                    {% endfor %}
                  </select>
                </div>
                <div class="fgrp">
                  <label>{{ 'proj.field_annee'|trans }}</label>
                  <input type="number" name="annee" class="fc" value="{{ projet.annee }}" min="2000" max="2099">
                </div>
              </div>
            </div>

            {# Section : Financement #}
            <div class="edit-section">
              <div class="edit-sec-title"><i class="bi bi-cash-stack"></i>{{ 'proj.bilan_title'|trans }}</div>
              <div class="fgrp">
                <label>{{ 'proj.field_donor'|trans }}</label>
                <input type="text" name="donateur" class="fc" value="{{ projet.donateur }}">
              </div>
              <div class="fgrp">
                <label>{{ 'proj.field_budget'|trans }}</label>
                <div style="position:relative">
                  <input type="number" name="coutTotal" class="fc" value="{{ projet.coutTotal }}" step="0.01" min="0" style="padding-right:52px">
                  <span style="position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:.72rem;font-weight:700;color:var(--txt3);pointer-events:none">MRU</span>
                </div>
              </div>
            </div>

            {# Section : Localisation & Dates #}
            <div class="edit-section">
              <div class="edit-sec-title"><i class="bi bi-geo-alt"></i>{{ 'proj.info_location'|trans }}</div>
              <div class="fgrp">
                <label>{{ 'proj.field_location'|trans }}</label>
                <input type="text" name="lieu" class="fc" value="{{ projet.lieu }}">
              </div>
              <div class="edit-row2">
                <div class="fgrp">
                  <label>{{ 'proj.field_contract_date'|trans }}</label>
                  <input type="date" name="dateContrat" class="fc" value="{{ projet.dateContrat ? projet.dateContrat|date('Y-m-d') : '' }}">
                </div>
                <div class="fgrp">
                  <label>{{ 'proj.field_end_date'|trans }}</label>
                  <input type="date" name="dateFin" class="fc" value="{{ projet.dateFin ? projet.dateFin|date('Y-m-d') : '' }}">
                </div>
              </div>
              <div class="fgrp">
                <label>{{ 'proj.field_duration'|trans }}</label>
                <input type="text" name="duree" class="fc" value="{{ projet.duree }}" placeholder="ex: 6 mois">
              </div>
            </div>

          </div>{# /edit-fields #}

          {# COL DROITE — Description #}
          <div class="edit-desc-col">
            <div class="edit-sec-title"><i class="bi bi-text-left"></i>{{ 'proj.field_description'|trans }}</div>
            <textarea name="description" class="fc edit-desc-ta">{{ projet.description }}</textarea>
            <div class="edit-desc-hint">
              <i class="bi bi-lightbulb" style="color:var(--go)"></i>
              {% if app.request.locale == 'ar' %}
                أدخل وصفاً تفصيلياً للمشروع — الأهداف والمراحل والملاحظات.
              {% elseif app.request.locale == 'en' %}
                Detailed project description — objectives, phases, notes.
              {% else %}
                Description détaillée du projet — objectifs, phases, remarques.
              {% endif %}
            </div>

            {# Progression #}
            <div class="edit-prog-block">
