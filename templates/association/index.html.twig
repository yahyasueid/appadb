                <input type="hidden" name="_token" value="{{ csrf_token('delete_association') }}">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> {{ 'assoc.btn_delete_confirm'|trans }}</button>
            </form>
        </div>
    </div>
</div>

{# ── Données JS ── #}
<script>
const ADATA = {{ associations|map(a => {
    id: a.id,
    nom: a.nom,
    nomAr: a.nomAr,
    sigle: a.sigle,
    adresse: a.adresse,
    ville: a.ville,
    pays: a.pays,
    telephone: a.telephone,
    email: a.email,
    siteWeb: a.siteWeb,
    numeroAgrement: a.numeroAgrement,
    dateCreation: a.dateCreation ? a.dateCreation|date('Y-m-d') : null,
    responsable: a.responsable,
    isActive: a.isActive,
    logoPath: a.logoPath,
    projetsCount: a.projets|length
})|json_encode|raw }};

const ROUTES = {
    create: "{{ path('app_association_create') }}",
    edit:   (id) => `/association/${id}/edit`,
    delete: (id) => `/association/${id}/delete`,
};

// Traductions JS
const T = {
    active:   "{{ 'assoc.status_active'|trans }}",
    inactive: "{{ 'assoc.status_inactive'|trans }}",
    create_title: "{{ 'assoc.modal_create_title'|trans }}",
    create_sub:   "{{ 'assoc.modal_create_sub'|trans }}",
    edit_title:   "{{ 'assoc.modal_edit_title'|trans }}",
    btn_create:   "{{ 'assoc.btn_create'|trans }}",
    btn_save:     "{{ 'assoc.btn_save'|trans }}",
    projects:     "{{ 'assoc.projects_label'|trans }}",
    entries:      "{{ 'assoc.entries'|trans }}",
    label_fields: {
        responsable:  "{{ 'assoc.field_responsable'|trans }}",
        date:         "{{ 'assoc.field_date_creation'|trans }}",
        telephone:    "{{ 'assoc.field_tel'|trans }}",
        email:        "{{ 'assoc.field_email'|trans }}",
        web:          "{{ 'assoc.field_web'|trans }}",
        adresse:      "{{ 'assoc.field_adresse'|trans }}",
        ville:        "{{ 'assoc.field_ville'|trans }}",
        pays:         "{{ 'assoc.field_pays'|trans }}",
        agrement:     "{{ 'assoc.field_agrement'|trans }}",
        projects:     "{{ 'assoc.col_projects'|trans }}",
        status:       "{{ 'assoc.col_status'|trans }}",
    }
};
</script>
{% endblock %}

{% block javascripts %}
<script>
/* ═══════════════ MODALES ═══════════════ */
function openMo(id){document.getElementById(id).classList.add('open');document.body.style.overflow='hidden'}
function closeMo(id){document.getElementById(id).classList.remove('open');document.body.style.overflow=''}
document.querySelectorAll('.mo').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeMo(this.id)}));
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.mo.open').forEach(m=>closeMo(m.id))});

/* ═══════════════ RESET FORM ═══════════════ */
function resetForm(){
    document.getElementById('assocForm').reset();
    document.getElementById('fId').value='';
    document.getElementById('fMethod').value='POST';
    document.getElementById('assocForm').action=ROUTES.create;
    document.getElementById('fmTitle').textContent=T.create_title;
    document.getElementById('fmSub').textContent=T.create_sub;
    document.getElementById('fmIcon').className='bi bi-building-add';
    document.getElementById('submitLbl').textContent=T.btn_create;
    document.getElementById('luPrev').innerHTML='<i class="bi bi-image" style="font-size:1.4rem;color:var(--green-pale)"></i>';
    document.getElementById('luArea').classList.remove('has');
    document.getElementById('togLbl').textContent=T.active;
    document.getElementById('fActive').checked=true;
    document.querySelectorAll('.fc.err').forEach(f=>f.classList.remove('err'));
    document.getElementById('fPays').value='Mauritanie';
}

/* ═══════════════ CRÉER ═══════════════ */
function openCreate(){resetForm();openMo('moForm')}

/* ═══════════════ ÉDITER ═══════════════ */
function openEdit(id){
    const a=ADATA.find(x=>x.id===id);if(!a)return;
    resetForm();
    document.getElementById('fId').value=a.id;
    document.getElementById('fMethod').value='PUT';
    document.getElementById('assocForm').action=ROUTES.edit(id);
    document.getElementById('fNom').value=a.nom||'';
    document.getElementById('fNomAr').value=a.nomAr||'';
    document.getElementById('fSigle').value=a.sigle||'';
    document.getElementById('fAdresse').value=a.adresse||'';
    document.getElementById('fVille').value=a.ville||'';
    document.getElementById('fPays').value=a.pays||'Mauritanie';
    document.getElementById('fTel').value=a.telephone||'';
    document.getElementById('fEmail').value=a.email||'';
    document.getElementById('fWeb').value=a.siteWeb||'';
    document.getElementById('fAgrement').value=a.numeroAgrement||'';
    document.getElementById('fDateCreation').value=a.dateCreation||'';
    document.getElementById('fResp').value=a.responsable||'';
    document.getElementById('fActive').checked=a.isActive;
    document.getElementById('togLbl').textContent=a.isActive?T.active:T.inactive;
    if(a.logoPath){
        document.getElementById('luPrev').innerHTML=`<img src="/${a.logoPath}" style="width:100%;height:100%;object-fit:contain">`;
        document.getElementById('luArea').classList.add('has');
    }
    document.getElementById('fmTitle').textContent=T.edit_title;
    document.getElementById('fmSub').textContent=a.sigle?`${a.sigle} — ${a.nom}`:a.nom;
    document.getElementById('fmIcon').className='bi bi-pencil';
    document.getElementById('submitLbl').textContent=T.btn_save;
    openMo('moForm');
}

/* ═══════════════ VOIR ═══════════════ */
function openView(id){
    const a=ADATA.find(x=>x.id===id);if(!a)return;
    document.getElementById('vSub').textContent=(a.sigle||'')+(a.ville?' · '+a.ville:'');
    document.getElementById('vEditBtn').onclick=()=>{closeMo('moView');openEdit(id)};
    const logo=a.logoPath
        ?`<img src="/${a.logoPath}" style="width:90%;height:90%;object-fit:contain">`
        :`<span class="nls">${(a.sigle||a.nom||'?').substring(0,2).toUpperCase()}</span>`;
    const f=(l,v,full=false)=>v
        ?`<div class="vf"${full?' style="grid-column:1/-1"':''}>
            <div class="vf-l">${l}</div>
            <div class="vf-v">${v}</div>
           </div>`:'';
    const locale=document.documentElement.lang||'fr';
    const fmtDate=v=>v?new Date(v).toLocaleDateString(locale==='ar'?'ar-MR':locale==='en'?'en-US':'fr-FR'):null;
    const statusHtml=`<span class="badge-s ${a.isActive?'on':'off'}">${a.isActive?T.active:T.inactive}</span>`;
    document.getElementById('vBody').innerHTML=`
        <div class="vh">
            <div class="vl">${logo}</div>
            <div>
                <div class="vn">${a.nom||'—'}</div>
                ${a.nomAr?`<div class="vna" dir="rtl">${a.nomAr}</div>`:''}
                ${a.sigle?`<span class="vsg">${a.sigle}</span>`:''}
            </div>
        </div>
        <div class="vgrid">
            ${f(T.label_fields.responsable, a.responsable)}
            ${f(T.label_fields.date, fmtDate(a.dateCreation))}
            ${f(T.label_fields.telephone, a.telephone)}
            ${f(T.label_fields.email, a.email?`<a href="mailto:${a.email}">${a.email}</a>`:null)}
            ${f(T.label_fields.web, a.siteWeb?`<a href="${a.siteWeb}" target="_blank">${a.siteWeb}</a>`:null)}
            ${f(T.label_fields.adresse, a.adresse, true)}
            ${f(T.label_fields.ville, a.ville)}
            ${f(T.label_fields.pays, a.pays)}
            ${f(T.label_fields.agrement, a.numeroAgrement)}
            ${f(T.label_fields.projects, `<strong style="color:var(--green-mid)">${a.projetsCount}</strong> ${T.projects}`)}
            ${f(T.label_fields.status, statusHtml)}
        </div>`;
    openMo('moView');
}

/* ═══════════════ SUPPRIMER ═══════════════ */
function openDelete(id,name){
    document.getElementById('delName').textContent=name;
    document.getElementById('delForm').action=ROUTES.delete(id);
    openMo('moDelete');
}

/* ═══════════════ VALIDATION & SUBMIT ═══════════════ */
function submitForm(){
    const form=document.getElementById('assocForm');
    let ok=true;
    form.querySelectorAll('[required]').forEach(f=>{
        if(!f.value.trim()){f.classList.add('err');ok=false}
        else f.classList.remove('err');
    });
    if(ok) form.submit();
}

/* ═══════════════ TOGGLE LABEL ═══════════════ */
document.getElementById('fActive').addEventListener('change',function(){
    document.getElementById('togLbl').textContent=this.checked?T.active:T.inactive;
});

/* ═══════════════ LOGO PREVIEW ═══════════════ */
function previewLogo(input){
    if(input.files&&input.files[0]){
        const r=new FileReader();
        r.onload=e=>{
            document.getElementById('luPrev').innerHTML=`<img src="${e.target.result}" style="width:100%;height:100%;object-fit:contain">`;
            document.getElementById('luArea').classList.add('has');
        };
        r.readAsDataURL(input.files[0]);
    }
}

/* ═══════════════ FILTRE TABLE ═══════════════ */
function filterTbl(){
    const q=(document.getElementById('sInput').value||'').toLowerCase();
    const s=document.getElementById('fStatus').value||'';
    const v=document.getElementById('fVille').value||'';
    let n=0;
    document.querySelectorAll('#mainTbl tbody tr').forEach(tr=>{
        const show=(!q||tr.dataset.search.includes(q))&&(!s||tr.dataset.status===s)&&(!v||tr.dataset.ville===v);
        tr.style.display=show?'':'none';
        if(show)n++;
    });
    const tot=document.querySelectorAll('#mainTbl tbody tr').length;
    const el=document.getElementById('tCount');
    if(el)el.textContent=n+' '+T.entries+(n<tot?` / ${tot}`:'');
}

/* ═══════════════ EXPORT CSV ═══════════════ */
function exportCSV(){
    const h=['ID','Nom','Nom AR','Sigle','Responsable','Email','Tél','Ville','Pays','Agrément','Projets','Statut'];
    const rows=ADATA.map(a=>[
        a.id,`"${(a.nom||'').replace(/"/g,'""')}"`,
        `"${(a.nomAr||'').replace(/"/g,'""')}"`,
        a.sigle||'',a.responsable||'',a.email||'',a.telephone||'',
        a.ville||'',a.pays||'',a.numeroAgrement||'',a.projetsCount,
        a.isActive?T.active:T.inactive
    ]);
    const csv=[h,...rows].map(r=>r.join(',')).join('\n');
    const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'});
    const el=document.createElement('a');
    el.href=URL.createObjectURL(blob);
    el.download=`associations_${new Date().toISOString().slice(0,10)}.csv`;
    el.click();
}
</script>
