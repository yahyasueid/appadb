{# ══════════════════════════════════════════════
   JAVASCRIPT
══════════════════════════════════════════════ #}
{% block javascripts %}
<script>
// ── Modales ───────────────────────────────────
function openMo(id)  { document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden' }
function closeMo(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow='' }
document.querySelectorAll('.mo').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) closeMo(m.id) })
})
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.mo.open').forEach(m => closeMo(m.id))
})

// ── Ouvrir modale Nouveau ──────────────────────
function openMoNew(assocId) {
  // Pré-sélectionner l'association si fournie
  if (assocId) {
    const sel = document.getElementById('nAssoc')
    if (sel) sel.value = assocId
  }
  openMo('moNew')
}

// ── Ouvrir modale Modifier (charge les données via JSON) ──
function openMoEdit(ficheId) {
  // Réinitialiser l'état
  document.getElementById('editLoading').style.display = 'flex'
  document.getElementById('editContent').style.display = 'none'
  document.getElementById('editSub').textContent = 'Chargement…'

  // Action du formulaire
  document.getElementById('fEdit').action = '/parrainage/orphelin/' + ficheId + '/edit'

  openMo('moEdit')

  // Charger les données
  fetch('/parrainage/orphelin/' + ficheId + '/data')
    .then(r => {
      if (!r.ok) throw new Error('Erreur serveur')
      return r.json()
    })
    .then(d => {
      // Remplir les champs
      document.getElementById('editSub').textContent  = d.nomComplet ?? '—'
      document.getElementById('eNom').value           = d.nomComplet    ?? ''
      document.getElementById('eCin').value           = d.cin           ?? ''
      document.getElementById('eDn').value            = d.dateNaissance ?? ''
      document.getElementById('eLieu').value          = d.lieuNaissance ?? ''
      document.getElementById('eGenre').value         = d.genre         ?? 'masculin'
      document.getElementById('eType').value          = d.typeOrphelin  ?? 'pere_decede'
      document.getElementById('eAdresse').value       = d.adresse       ?? ''
      document.getElementById('eTel').value           = d.telephone     ?? ''
      document.getElementById('eSante').value         = d.etatSante     ?? ''
      document.getElementById('eMere').value          = d.nomMere       ?? ''
      document.getElementById('eTuteur').value        = d.nomTuteur     ?? ''
      document.getElementById('eRelation').value      = d.relationTuteur ?? ''
      document.getElementById('eFreres').value        = d.nbFreres      ?? 0
      document.getElementById('eSoeurs').value        = d.nbSoeurs      ?? 0
      document.getElementById('eMariee').value        = d.mereMariee ? '1' : '0'
      document.getElementById('eEcole').value         = d.ecole         ?? ''
      document.getElementById('eNiveau').value        = d.niveauScolaire ?? ''
      document.getElementById('eRaison').value        = d.raisonNonScolarisation ?? ''

      // Afficher le contenu
      document.getElementById('editLoading').style.display = 'none'
      document.getElementById('editContent').style.display = 'block'
    })
    .catch(() => {
      document.getElementById('editSub').textContent = 'Erreur de chargement'
    })
}

// ── Approuver : جديد → معتمدة ─────────────────
function openMoApprouver(ficheId, nom) {
  document.getElementById('appSub').textContent = nom
  document.getElementById('fApprouver').action = '/parrainage/orphelin/' + ficheId + '/approuver'
  openMo('moApprouver')
}

// ── Activer : معتمدة → مكفول ──────────────────
function openMoActiver(ficheId, nom) {
  document.getElementById('actSub').textContent = nom
  document.getElementById('fActiver').action = '/parrainage/orphelin/' + ficheId + '/activer'
  openMo('moActiver')
}

// ── Supprimer ─────────────────────────────────
function openMoDel(ficheId, nom) {
  document.getElementById('delSub').textContent = nom
  document.getElementById('fDel').action = '/parrainage/orphelin/' + ficheId + '/delete'
  openMo('moDel')
}

// ── Filtre externe sur DataTables ─────────────
function doFilter() {
  const fS = document.getElementById('fStatut')?.value ?? ''
  const fT = document.getElementById('fType')?.value   ?? ''
  let total = 0

  $('table.dtable').each(function () {
    const dt = $(this).DataTable()
    // col 4 = statut, col 2 = type (data-type sur la ligne)
    dt.column(4).search(fS, false, false)
    dt.column(2).search(fT, false, false)
    dt.draw()
    total += dt.rows({ search: 'applied' }).count()
  })

  const info = document.getElementById('filterInfo')
  if (info) info.textContent = total > 0 ? total + ' résultat' + (total > 1 ? 's' : '') : 'Aucun résultat'
}

// ── Upload photo ──────────────────────────────
function prvFile(inp, uzId, frId, nameId) {
  if (!inp.files[0]) return
  document.getElementById(uzId).style.display = 'none'
  document.getElementById(frId).classList.add('vis')
  document.getElementById(nameId).textContent = inp.files[0].name
}
function rstFile(uzId, frId, inpId) {
  document.getElementById(uzId).style.display = ''
  document.getElementById(frId).classList.remove('vis')
  document.getElementById(inpId).value = ''
}
function dzOv(e, id) { e.preventDefault(); document.getElementById(id).classList.add('drag') }
function dzOt(id)    { document.getElementById(id).classList.remove('drag') }
function dzDp(e, uzId, inpId, frId) {
  e.preventDefault(); dzOt(uzId)
  const dt = new DataTransfer(); dt.items.add(e.dataTransfer.files[0])
  const inp = document.getElementById(inpId); inp.files = dt.files
  inp.dispatchEvent(new Event('change'))
}
</script>
{% endblock %} 
