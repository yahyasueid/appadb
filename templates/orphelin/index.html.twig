            </div>
            <div>
              <label>{{ 'orp.lbl_relation_court'|trans }}</label>
              <select id="eRelation" name="relation_tuteur" class="fc">
                <option value="">{{ 'orp.opt_relation_vide'|trans }}</option>
                <option value="mere">{{ 'orp.opt_mere_simple'|trans }}</option>
                <option value="frere">{{ 'orp.opt_frere_simple'|trans }}</option>
                <option value="oncle">{{ 'orp.opt_oncle_simple'|trans }}</option>
                <option value="grand_pere">{{ 'orp.opt_grand_pere_simple'|trans }}</option>
                <option value="autre">{{ 'orp.opt_autre_court'|trans }}</option>
              </select>
            </div>
          </div>
          <div class="g3">
            <div>
              <label>{{ 'orp.lbl_freres'|trans }}</label>
              <input type="number" id="eFreres" name="nb_freres" class="fc" min="0" value="0">
            </div>
            <div>
              <label>{{ 'orp.lbl_soeurs'|trans }}</label>
              <input type="number" id="eSoeurs" name="nb_soeurs" class="fc" min="0" value="0">
            </div>
            <div>
              <label>{{ 'orp.lbl_mere_remariee_court'|trans }}</label>
              <select id="eMariee" name="mere_mariee" class="fc">
                <option value="0">{{ 'orp.opt_non'|trans }}</option>
                <option value="1">{{ 'orp.opt_oui_mere'|trans }}</option>
              </select>
            </div>
          </div>
        </div>

        {# Scolarité #}
        <div class="fsec">
          <div class="fsec-title"><i class="bi bi-mortarboard"></i>{{ 'orp.sec_scolarite_court'|trans }}</div>
          <div class="g3">
            <div>
              <label>{{ 'orp.lbl_ecole_court'|trans }}</label>
              <input type="text" id="eEcole" name="ecole" class="fc">
            </div>
            <div>
              <label>{{ 'orp.lbl_niveau_court'|trans }}</label>
              <input type="text" id="eNiveau" name="niveau_scolaire" class="fc">
            </div>
            <div>
              <label>{{ 'orp.lbl_raison_court'|trans }}</label>
              <input type="text" id="eRaison" name="raison_non_scolarisation" class="fc">
            </div>
          </div>
        </div>

        {# Photo #}
        <div class="fsec">
          <div class="fsec-title"><i class="bi bi-image"></i>{{ 'orp.sec_photo_modif'|trans }} <span style="font-weight:400;color:var(--txt3)">{{ 'orp.photo_vide_hint'|trans }}</span></div>
          <input type="file" name="photo" class="fc" accept="image/*">
        </div>
      </form>
    </div>

    <div class="mf">
      <button class="btn btn-s" onclick="closeMo('moEdit')"><i class="bi bi-x"></i>{{ 'orp.btn_annuler'|trans }}</button>
      <button class="btn btn-p" onclick="document.getElementById('fEdit').submit()">
        <i class="bi bi-check2"></i>{{ 'orp.btn_enreg_modif'|trans }}
      </button>
    </div>
  </div>
</div>


{# ─────────────────────────────────────────────
   MODALE : APPROUVER — جديد → معتمدة
───────────────────────────────────────────── #}
<div class="mo" id="moApprouver">
  <div class="md md-sm">
    <div class="mh">
      <div class="mh-l">
        <div class="mi mi-b"><i class="bi bi-check-circle"></i></div>
        <div>
          <div class="mt">{{ 'orp.mo_app_title'|trans }}</div>
          <div class="ms" id="appSub">—</div>
        </div>
      </div>
      <button class="mcls" onclick="closeMo('moApprouver')"><i class="bi bi-x-lg"></i></button>
