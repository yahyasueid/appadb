  </div>
</div>

<div class="mo" id="moDelPay">
  <div class="md md-sm">
    <div class="mh"><div class="mh-l"><div class="mi mi-r"><i class="bi bi-trash3"></i></div><div><div class="mt">{{ 'orp.mo_del_pay_title'|trans }}</div><div class="ms" id="delPaySub">—</div></div></div><button class="mcls" onclick="closeMo('moDelPay')"><i class="bi bi-x-lg"></i></button></div>
    <div class="mb"><div class="abox" style="background:rgba(211,47,47,.08);border:1px solid rgba(211,47,47,.2)"><i class="bi bi-exclamation-triangle-fill" style="color:var(--rd)"></i><div><div class="at" style="color:#C62828">{{ 'orp.del_pay_titre'|trans }}</div><div class="as">{{ 'orp.del_pay_desc'|trans }}</div></div></div>
      <form id="fDelPay" method="post"><input type="hidden" name="_token" value="{{ csrf_token('paiement_delete') }}"></form>
    </div>
    <div class="mf"><button class="btn btn-s" onclick="closeMo('moDelPay')">{{ 'orp.btn_annuler'|trans }}</button><button class="btn btn-d" onclick="document.getElementById('fDelPay').submit()"><i class="bi bi-trash3"></i>{{ 'orp.btn_del_vers_confirm'|trans }}</button></div>
  </div>
</div>

<div class="mo" id="moRapport">
  <div class="md md-md">
    <div class="mh"><div class="mh-l"><div class="mi mi-p"><i class="bi bi-file-earmark-text"></i></div><div><div class="mt">{{ 'orp.mo_rapport_title'|trans }}</div><div class="ms">{{ fiche.nomComplet }}</div></div></div><button class="mcls" onclick="closeMo('moRapport')"><i class="bi bi-x-lg"></i></button></div>
    <div class="mb">
      <form id="fRpt" action="{{ path('app_parrainage_orphelin_rapport', {id: fiche.id}) }}" method="post" enctype="multipart/form-data">
        <input type="hidden" name="_token" value="{{ csrf_token('orphelin_rapport') }}">
        <div class="g2"><div class="frow"><label>{{ 'orp.lbl_annee_req'|trans }} <span class="req">*</span></label><input type="number" name="annee" class="fc" value="{{ 'now'|date('Y') }}" required min="2020" max="2099"></div><div class="frow"><label>{{ 'orp.lbl_semestre_req'|trans }} <span class="req">*</span></label><select name="semestre" class="fc" required><option value="1">{{ 'orp.opt_s1'|trans }}</option><option value="2">{{ 'orp.opt_s2'|trans }}</option></select></div></div>
        <div class="frow"><label>{{ 'orp.lbl_situation'|trans }}</label><textarea name="situation_generale" class="fc" rows="3" placeholder="Mise à jour de la situation du bénéficiaire…"></textarea></div>
        <div class="frow"><label>{{ 'orp.lbl_scolarite_rpt'|trans }}</label><textarea name="resultats_scolarite" class="fc" rows="2" placeholder="Passage en classe, résultats…"></textarea></div>
        <div class="frow"><label>{{ 'orp.lbl_sante_rpt'|trans }}</label><textarea name="situation_sante" class="fc" rows="2" placeholder="État de santé…"></textarea></div>
        <div class="frow"><label>{{ 'orp.lbl_msg_parrain'|trans }}</label><textarea name="message_parrain" class="fc" rows="2" placeholder="Remerciements, nouvelles…"></textarea></div>
        <div class="frow"><label>{{ 'orp.lbl_doc'|trans }}</label><input type="file" name="document" class="fc" accept=".pdf,image/*"></div>
      </form>
    </div>
    <div class="mf"><button class="btn btn-s" onclick="closeMo('moRapport')">{{ 'orp.btn_annuler'|trans }}</button><button class="btn btn-pu" onclick="document.getElementById('fRpt').submit()"><i class="bi bi-check2"></i>{{ 'orp.btn_creer_rpt'|trans }}</button></div>
  </div>
</div>

<div class="mo" id="moDelRpt">
  <div class="md md-sm">
    <div class="mh"><div class="mh-l"><div class="mi mi-r"><i class="bi bi-trash3"></i></div><div><div class="mt">{{ 'orp.mo_del_rpt_title'|trans }}</div><div class="ms" id="delRptSub">—</div></div></div><button class="mcls" onclick="closeMo('moDelRpt')"><i class="bi bi-x-lg"></i></button></div>
    <div class="mb"><div class="abox" style="background:rgba(211,47,47,.08);border:1px solid rgba(211,47,47,.2)"><i class="bi bi-exclamation-triangle-fill" style="color:var(--rd)"></i><div><div class="at" style="color:#C62828">{{ 'orp.del_irrev'|trans }}</div><div class="as">{{ 'orp.del_rpt_desc'|trans }}</div></div></div>
      <form id="fDelRpt" method="post"><input type="hidden" name="_token" value="{{ csrf_token('rapport_delete') }}"></form>
    </div>
    <div class="mf"><button class="btn btn-s" onclick="closeMo('moDelRpt')">{{ 'orp.btn_annuler'|trans }}</button><button class="btn btn-d" onclick="document.getElementById('fDelRpt').submit()"><i class="bi bi-trash3"></i>{{ 'orp.btn_del_rpt_confirm'|trans }}</button></div>
  </div>
</div>

<div class="mo" id="moDel">
  <div class="md md-sm">
    <div class="mh"><div class="mh-l"><div class="mi mi-r"><i class="bi bi-trash3"></i></div><div><div class="mt">Supprimer le dossier</div><div class="ms">{{ fiche.nomComplet }}</div></div></div><button class="mcls" onclick="closeMo('moDel')"><i class="bi bi-x-lg"></i></button></div>
    <div class="mb"><div class="abox" style="background:rgba(211,47,47,.08);border:1px solid rgba(211,47,47,.2)"><i class="bi bi-exclamation-triangle-fill" style="color:var(--rd);font-size:1.4rem"></i><div><div class="at" style="color:#C62828">{{ 'orp.del_irrev'|trans }}</div><div class="as">{{ 'orp.del_warn_show'|trans }}</div></div></div>
      <form id="fDel" action="{{ path('app_parrainage_orphelin_delete', {id: fiche.id}) }}" method="post"><input type="hidden" name="_token" value="{{ csrf_token('orphelin_delete') }}"></form>
    </div>
    <div class="mf"><button class="btn btn-s" onclick="closeMo('moDel')">{{ 'orp.btn_annuler'|trans }}</button><button class="btn btn-d" onclick="document.getElementById('fDel').submit()"><i class="bi bi-trash3"></i>{{ 'orp.btn_del_confirm'|trans }}</button></div>
  </div>
</div>

{% endblock %}


{% block javascripts %}
<script>
function openMo(id)  { document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden' }
function closeMo(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow='' }
document.querySelectorAll('.mo').forEach(m => m.addEventListener('click', e => { if(e.target===m) closeMo(m.id) }))
document.addEventListener('keydown', e => { if(e.key==='Escape') document.querySelectorAll('.mo.open').forEach(m => closeMo(m.id)) })
const vd = document.getElementById('vDate'); if(vd) vd.valueAsDate = new Date()
function openMoDelPay(payId, montant) { document.getElementById('delPaySub').textContent=montant+' MRU'; document.getElementById('fDelPay').action='/parrainage/paiement/'+payId+'/delete'; openMo('moDelPay') }
function openMoDelRpt(rptId, annee, semestre) { document.getElementById('delRptSub').textContent='Rapport S'+semestre+' '+annee; document.getElementById('fDelRpt').action='/rapport/parrainage/'+rptId+'/delete'; openMo('moDelRpt') }
function switchTab(btn, paneId) { document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('act')); document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('act')); btn.classList.add('act'); document.getElementById(paneId).classList.add('act') }
</script>
{% endblock %}
